<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="elevenlabs_connector.VoiceAssistantWidget" owl="1">
        <div class="o_voice_assistant_widget p-4">
            <div class="text-center mb-4">
                <h2>Voice Assistant</h2>
                <p class="text-muted">Ask questions using your voice</p>
            </div>
            
            <div class="text-center mb-4">
                <button 
                    t-attf-class="btn btn-lg rounded-circle #{state.isRecording ? 'btn-danger' : 'btn-primary'}"
                    t-on-click="toggleRecording"
                    t-att-disabled="state.isProcessing"
                    style="width: 100px; height: 100px;">
                    <i t-attf-class="fa fa-#{state.isRecording ? 'stop' : 'microphone'} fa-3x"></i>
                </button>
            </div>
            
            <div class="text-center mb-4">
                <p class="text-muted" style="font-size: 16px;">
                    <t t-if="state.isRecording">Recording... Click to stop</t>
                    <t t-elif="state.isProcessing">Processing your request...</t>
                    <t t-else="">Click to start recording</t>
                </p>
            </div>

            <div t-if="state.error" class="alert alert-danger mt-3">
                <i class="fa fa-exclamation-triangle me-2"></i>
                <t t-out="state.error"/>
            </div>

            <!-- Current Conversation Results - Appears directly below recording -->
            <div t-if="state.transcribedText || state.aiResponse" class="mt-4" id="current-conversation-result">
                <div class="card shadow-sm border-primary">
                    <div class="card-body">
                        <div t-if="state.transcribedText" class="mb-3">
                            <h6 class="text-primary mb-2">
                                <i class="fa fa-microphone me-2"></i>You said:
                            </h6>
                            <p class="mb-0 p-2 bg-light rounded" style="white-space: pre-wrap; word-wrap: break-word;" t-out="state.transcribedText"/>
                        </div>
                        
                        <div t-if="state.aiResponse" class="mt-3">
                            <h6 class="text-success mb-2">
                                <i class="fa fa-robot me-2"></i>AI Response:
                            </h6>
                            <div class="p-3 bg-success bg-opacity-10 rounded border border-success border-opacity-25" style="white-space: pre-wrap; word-wrap: break-word;" t-out="state.aiResponse"/>
                        </div>
                        
                        <div class="mt-3 text-center">
                            <button class="btn btn-sm btn-outline-secondary" t-on-click="clearConversation()">
                                <i class="fa fa-times me-1"></i>
                                Clear
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Conversation History - Separate section below -->
            <div class="mt-5 pt-4 border-top">
                <h5 class="mb-3">
                    <i class="fa fa-history me-2"></i>Recent Conversations
                </h5>
                <div t-if="state.conversations.length === 0" class="text-muted text-center py-3">
                    <p class="mb-0">No previous conversations. Start by recording a question!</p>
                </div>
                <div t-else="" class="list-group">
                    <div t-foreach="state.conversations" t-as="conv" t-key="conv.id" class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <h6 class="mb-1 text-primary" t-out="conv.user_input"/>
                                <p class="mb-1 text-muted small" style="white-space: pre-wrap;" t-out="conv.final_response"/>
                                <small class="text-muted" t-out="conv.conversation_date"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>

