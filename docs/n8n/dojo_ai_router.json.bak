    {
      "parameters": {
        "jsCode": "// ── Format response for Odoo normalisation ──\nconst raw = $input.first().json;\nconst agent = $('Discovery').item.json.agent || 'unknown';\n\nreturn [{\n  json: {\n    success: raw.success !== false,\n    state: raw.state || 'executed',\n    response: raw.response || raw.output || raw.text || '',\n    intent: raw.intent || null,\n    result: raw.result || null,\n    session_key: raw.session_key || null,\n    agent: agent,\n    agent_name: $('Discovery').item.json.agent_name || null\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1640, 80],
      "id": "a0000001-0001-4001-8001-000000000020",
      "name": "Format Response"
    },
    {
      "parameters": {
        "jsCode": "// ── Return validation or discovery error ──\nconst input = $input.first().json;\nreturn [{\n  json: {\n    success: false,\n    state: 'error',\n    response: input.response || input.error || 'An error occurred during processing.',\n    error: input.error || 'processing_error',\n    intent: null,\n    result: null,\n    session_key: null,\n    agent: null\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, 200],
      "id": "a0000001-0001-4001-8001-000000000021",
      "name": "Error Response"
    }
