{
  "name": "Dojo AI Router",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "ai-query",
        "responseMode": "lastNode",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [0, 0],
      "id": "a0000001-0001-4001-8001-000000000001",
      "name": "Webhook",
      "webhookId": "ed853e5d-4fa7-48b1-aba8-f793b62cfe92"
    },
    {
      "parameters": {
        "jsCode": "// ── Validate & normalise incoming request ──\nconst body = $input.first().json.body || $input.first().json;\n\nconst text = (body.text || '').trim();\nif (!text) {\n  return [{ json: { success: false, state: 'error', response: 'Missing required field: text', error: 'validation_error' } }];\n}\n\nconst VALID_ROLES = ['admin', 'instructor', 'kiosk'];\nconst role = VALID_ROLES.includes(body.role) ? body.role : 'instructor';\n\nconst session_id = body.session_id || `auto_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`;\n\nlet context_window = parseInt(body.context_window, 10);\nif (isNaN(context_window) || context_window < 1) context_window = 10;\nif (context_window > 50) context_window = 50;\n\nconst channel = body.channel || null;\n\nreturn [{ json: { text, role, session_id, context_window, channel, _valid: true } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 0],
      "id": "a0000001-0001-4001-8001-000000000002",
      "name": "Validate Input"
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "" },
          "conditions": [
            {
              "id": "cond-valid",
              "leftValue": "={{ $json._valid }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "true" }
            }
          ],
          "combinator": "and"
        }
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [440, 0],
      "id": "a0000001-0001-4001-8001-000000000003",
      "name": "Is Valid?"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://web:8069/api/v1/ai/discover",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ text: $('Validate Input').item.json.text, role: $('Validate Input').item.json.role, include_prompt: true }) }}",
        "options": {
          "timeout": 15000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [660, -80],
      "id": "a0000001-0001-4001-8001-000000000004",
