          }
        }
      },
      {
        "parameters": {
          "toolDescription": "Log a completed agent step to Odoo. Call this AFTER each specialist agent completes — not before. Provide: step_num (1-based integer, increment per agent called), agent_display_name (human-readable name e.g. 'Subscriptions Agent'), agent_tool_name (exact tool name e.g. 'SubscriptionsAgent'), result_summary (1-3 sentences of what the agent returned — include key data: names, amounts, counts), reasoning (why you routed this sub-task to this agent).",
          "method": "POST",
          "url": "http://web:8069/dojo/ai/step",
          "sendBody": true,
          "specifyBody": "json",
          "jsonBody": "={{ JSON.stringify({ pipeline_key: $('Trigger').item.json.pipeline_key || '', step_num: parseInt($fromAI('step_num', 'Step number, 1-based integer, increment for each agent')) || 1, name: $fromAI('agent_display_name', 'Human-readable agent name e.g. Subscriptions Agent'), agent_name: $fromAI('agent_tool_name', 'Exact tool name used e.g. SubscriptionsAgent'), detail: $fromAI('result_summary', 'What the agent returned - include key data like names amounts counts. 1-3 sentences.') + ' | Why: ' + $fromAI('reasoning', 'Why you routed this sub-task to this agent') }) }}",
          "options": {
            "timeout": 3000,
            "response": {
              "response": {
                "neverError": true
              }
            }
          }
        },
