      "id": "a0000001-0001-4001-8001-000000000004",
      "name": "Discovery",
      "credentials": {
        "httpHeaderAuth": {
          "id": "MGTS1e0OnNIkltBl",
          "name": "Odoo API Key"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Merge Build History (user request context) with Discovery (agent routing).\n// After the Switch node, $('Build History') is no longer accessible,\n// so we unify everything into one item here.\nconst bh = $('Build History').item.json;\nconst disc = $input.first().json;\nreturn [{ json: {\n  text: bh.text,\n  role: bh.role,\n  session_id: bh.session_id,\n  context_window: bh.context_window,\n  conversation_history: bh.conversation_history || '',\n  agent: disc.agent || null,\n  agent_name: disc.agent_name || null,\n  system_prompt: disc.system_prompt || '',\n  valid_intent_types: disc.valid_intent_types || [],\n  db_context: disc.db_context || '',\n  intents: disc.intents || [],\n  intent_count: disc.intent_count || 0,\n  system_prompt_available: disc.system_prompt_available || false\n} }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1328,
        -80
      ],
      "id": "a0000001-0001-4001-8001-000000000032",
      "name": "Merge Context"
    },
    {
      "parameters": {
        "jsCode": "// \u2500\u2500 Format response for Odoo normalisation \u2500\u2500\nconst raw = $input.first().json;\nconst agent = $('Merge Context').item.json.agent || 'unknown';\n\nreturn [{\n  json: {\n    success: raw.success !== false,\n    state: raw.state || 'executed',\n    response: raw.response || raw.output || raw.text || '',\n    intent: raw.intent || null,\n    result: raw.result || null,\n    session_key: raw.session_key || null,\n    agent: agent,\n    agent_name: $('Merge Context').item.json.agent_name || null\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2080,
        80
      ],
      "id": "a0000001-0001-4001-8001-000000000020",
      "name": "Format Response"
    },
    {
