    {
      "parameters": {
        "jsCode": "const AGENT_MAP = {attendance:'LQOtAQyhya19709W',enrollment:'y7ppFz99vG2KYtcM',core:'nqa29YJh4DmonXVD',subscriptions:'DKv7tyjq9drKI0lz',communications:'KhKhlTLen6FSLUfL'};\nconst GENERAL_ID = 'bFYiBJlup2jo6Yr1';\nconst d = $input.first().json;\nconst agent = (d.agent || '').toLowerCase();\nconst workflowId = AGENT_MAP[agent] || GENERAL_ID;\nreturn [{ json: { ...d, _workflowId: workflowId } }];"
      },
