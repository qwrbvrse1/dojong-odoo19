        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ session_id: $('Merge Context').item.json.session_id, user_message: $('Merge Context').item.json.text, assistant_message: $('Format Response').item.json.response || '' }) }}",
        "options": {
