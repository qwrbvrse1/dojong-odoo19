    {
      "parameters": {
        "jsCode": "// \u2500\u2500 Return validation or discovery error \u2500\u2500\nconst input = $input.first().json;\nreturn [{\n  json: {\n    success: false,\n    state: 'error',\n    response: input.response || input.error || 'An error occurred during processing.',\n    error: input.error || 'processing_error',\n    intent: null,\n    result: null,\n    session_key: null,\n    agent: null\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1552,
