    },
    {
      "parameters": {
        "jsCode": "// \u2500\u2500 Return the formatted response (Save Turn result is discarded) \u2500\u2500\nconst resp = $('Format Response').item.json;\nreturn [{ json: resp }];"
      },
      "type": "n8n-nodes-base.code",
