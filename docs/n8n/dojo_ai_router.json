    },
    {
      "parameters": {
        "jsCode": "// \u2500\u2500 Validate & normalise incoming request \u2500\u2500\nconst body = $input.first().json.body || $input.first().json;\n\nconst text = (body.text || '').trim();\nif (!text) {\n  return [{ json: { success: false, state: 'error', response: 'Missing required field: text', error: 'validation_error' } }];\n}\n\nconst VALID_ROLES = ['admin', 'instructor', 'kiosk'];\nconst role = VALID_ROLES.includes(body.role) ? body.role : 'instructor';\n\nconst session_id = body.session_id || ('auto_' + Date.now() + '_' + Math.random().toString(36).slice(2, 8));\n\nlet context_window = parseInt(body.context_window, 10);\nif (isNaN(context_window) || context_window < 1) context_window = 10;\nif (context_window > 50) context_window = 50;\n\nconst channel = body.channel || null;\n\nreturn [{ json: { text, role, session_id, context_window, channel, _valid: true } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        0
      ],
      "id": "a0000001-0001-4001-8001-000000000002",
      "name": "Validate Input"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": ""
          },
          "conditions": [
            {
              "id": "cond-valid",
              "leftValue": "={{ $json._valid }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        448,
        0
      ],
      "id": "a0000001-0001-4001-8001-000000000003",
      "name": "Is Valid?"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://web:8069/api/v1/ai/chat/history",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ session_id: $('Validate Input').item.json.session_id, limit: $('Validate Input').item.json.context_window || 20 }) }}",
        "options": {
          "timeout": 5000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        672,
        0
      ],
      "id": "a0000001-0001-4001-8001-000000000030",
      "name": "Fetch History",
      "credentials": {
        "httpHeaderAuth": {
          "id": "MGTS1e0OnNIkltBl",
          "name": "Odoo API Key"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// \u2500\u2500 Format conversation history into a prompt-friendly string \u2500\u2500\nconst histResp = $input.first().json;\nconst messages = (histResp && histResp.messages) || [];\n\nlet conversation_history = '';\nif (messages.length > 0) {\n  const lines = messages.map(m => {\n    const label = m.role === 'user' ? 'User' : 'Assistant';\n    return label + ': ' + m.content;\n  });\n  conversation_history = lines.join('\\n');\n}\n\n// Pass through all Validate Input fields plus the new history\nconst vi = $('Validate Input').item.json;\nreturn [{ json: { ...vi, conversation_history } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        0
      ],
      "id": "a0000001-0001-4001-8001-000000000031",
      "name": "Build History"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://web:8069/api/v1/ai/discover",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ text: $('Build History').item.json.text, role: $('Build History').item.json.role, include_prompt: true, conversation_history: $('Build History').item.json.conversation_history || '' }) }}",
        "options": {
          "timeout": 15000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1104,
