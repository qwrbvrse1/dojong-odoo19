[options]
addons_path = /mnt/extra-addons,/mnt/enterprise-addons,/opt/odoo/addons
data_dir = /var/lib/odoo
admin_passwd = admin_password
# Replace these placeholders for your environment. Do not add inline comments
# after values; Odoo parses the full right-hand side literally.
db_name = odoo19
db_host = db
db_port = 5432
db_user = odoo
db_password = odoo
dbfilter = ^odoo19$
list_db = True
http_interface = 0.0.0.0
gevent_port = 8072
workers = 2
