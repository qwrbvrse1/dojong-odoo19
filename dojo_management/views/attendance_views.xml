<odoo>
    <record id="action_dojo_attendance" model="ir.actions.act_window">
        <field name="name">Attendance</field>
        <field name="res_model">dojo.attendance</field>
        <field name="view_mode">list,form</field>
    </record>
    
    <record id="view_dojo_attendance_tree" model="ir.ui.view">
        <field name="name">dojo.attendance.tree</field>
        <field name="model">dojo.attendance</field>
        <field name="arch" type="xml">
            <list decoration-success="status == 'present'" decoration-danger="status == 'absent'" decoration-warning="status == 'late'" decoration-info="status == 'excused'">
                <field name="student_id"/>
                <field name="session_id"/>
                <field name="date"/>
                <field name="status" widget="badge" decoration-success="status == 'present'" decoration-danger="status == 'absent'" decoration-warning="status == 'late'" decoration-info="status == 'excused'"/>
                <field name="performance_rating"/>
            </list>
        </field>
    </record>

    <record id="view_dojo_attendance_form" model="ir.ui.view">
        <field name="name">dojo.attendance.form</field>
        <field name="model">dojo.attendance</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_present" string="Mark Present" type="object" class="btn-success"/>
                    <button name="action_mark_absent" string="Mark Absent" type="object" class="btn-danger"/>
                    <button name="action_mark_late" string="Mark Late" type="object" class="btn-warning"/>
                    <button name="action_mark_excused" string="Mark Excused" type="object" class="btn-info"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="session_id"/>
                            <field name="date"/>
                            <field name="status" widget="radio"/>
                        </group>
                        <group>
                            <field name="arrival_time" widget="float_time"/>
                            <field name="departure_time" widget="float_time"/>
                            <field name="performance_rating"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
