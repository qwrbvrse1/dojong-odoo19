<odoo>
    <!-- Student Report -->
    <record id="action_report_dojo_student" model="ir.actions.report">
        <field name="name">Student Report</field>
        <field name="model">dojo.student</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">dojo_management.report_student_template</field>
        <field name="report_file">dojo_management.report_student_template</field>
        <field name="print_report_name">(object.name or 'Student Report')</field>
    </record>

    <template id="report_student_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="student">
                <div class="page">
                    <h2>Student: <t t-esc="student.name"/></h2>
                    <p>Date of Birth: <t t-esc="student.dob"/></p>
                    <p>Email: <t t-esc="student.email"/></p>
                    <p>Phone: <t t-esc="student.phone"/></p>
                    <p>Enrollment Date: <t t-esc="student.enrollment_date"/></p>
                </div>
            </t>
        </t>
    </template>

    <!-- Payment Report -->
    <record id="action_report_dojo_payment" model="ir.actions.report">
        <field name="name">Payment Report</field>
        <field name="model">dojo.payment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">dojo_management.report_payment_template</field>
        <field name="report_file">dojo_management.report_payment_template</field>
        <field name="print_report_name">'Payment Report'</field>
    </record>

    <template id="report_payment_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="payment">
                <div class="page">
                    <h2>Payment for <t t-esc="payment.student_id.name"/></h2>
                    <p>Amount: <t t-esc="payment.amount"/></p>
                    <p>Payment Date: <t t-esc="payment.payment_date"/></p>
                    <p>Due Date: <t t-esc="payment.due_date"/></p>
                    <p>Status: <t t-esc="payment.state"/></p>
                </div>
            </t>
        </t>
    </template>

    <!-- Attendance Report -->
    <record id="action_report_dojo_attendance" model="ir.actions.report">
        <field name="name">Attendance Report</field>
        <field name="model">dojo.attendance</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">dojo_management.report_attendance_template</field>
        <field name="report_file">dojo_management.report_attendance_template</field>
        <field name="print_report_name">'Attendance Report'</field>
    </record>

    <template id="report_attendance_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="attendance">
                <div class="page">
                    <h2>Attendance for <t t-esc="attendance.student_id.name"/></h2>
                    <p>Date: <t t-esc="attendance.date"/></p>
                    <p>Status: <t t-esc="attendance.status"/></p>
                </div>
            </t>
        </t>
    </template>

    <!-- Combined Report (Student, Payments, Attendance) -->
    <record id="action_report_dojo_combined" model="ir.actions.report">
        <field name="name">Student Full Report</field>
        <field name="model">dojo.student</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">dojo_management.report_combined_template</field>
        <field name="report_file">dojo_management.report_combined_template</field>
        <field name="print_report_name">'Student Full Report'</field>
    </record>

    <template id="report_combined_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="student">
                <div class="page">
                    <h2>Student: <t t-esc="student.name"/></h2>
                    <p>Date of Birth: <t t-esc="student.dob"/></p>
                    <p>Email: <t t-esc="student.email"/></p>
                    <p>Phone: <t t-esc="student.phone"/></p>
                    <p>Enrollment Date: <t t-esc="student.enrollment_date"/></p>
                    <h3>Payments</h3>
                    <ul>
                        <t t-foreach="student.payment_ids" t-as="payment">
                            <li>
                                <t t-esc="payment.payment_date"/>: <t t-esc="payment.amount"/> (<t t-esc="payment.state"/>)
                            </li>
                        </t>
                    </ul>
                    <h3>Attendance</h3>
                    <ul>
                        <t t-foreach="student.attendance_ids" t-as="attendance">
                            <li>
                                <t t-esc="attendance.date"/>: <t t-esc="attendance.status"/>
                            </li>
                        </t>
                    </ul>
                </div>
            </t>
        </t>
    </template>
</odoo>
