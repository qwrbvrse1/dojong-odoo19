<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_attendance_wizard_form" model="ir.ui.view">
        <field name="name">attendance.wizard.form</field>
        <field name="model">attendance.wizard</field>
        <field name="arch" type="xml">
            <form string="Batch Attendance">
                <group>
                    <field name="session_id" readonly="1"/>
                </group>
                <field name="attendance_lines">
                    <list>
                        <field name="student_id" readonly="1"/>
                        <field name="status"/>
                    </list>
                </field>
                <footer>
                    <button string="Confirm" type="object" name="action_confirm" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_attendance_wizard" model="ir.actions.act_window">
        <field name="name">Batch Attendance</field>
        <field name="res_model">attendance.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_attendance_wizard_form"/>
    </record>
</odoo>
