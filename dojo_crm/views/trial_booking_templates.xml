<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         Shared layout wrapper for all trial booking pages
         ================================================================ -->
    <template id="trial_page_layout" name="Trial Booking Layout">
        <t t-call="website.layout">
            <div class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-lg-8 col-md-10">
                        <t t-raw="0"/>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ================================================================
         Token expired / invalid page
         ================================================================ -->
    <template id="trial_token_expired" name="Trial Token Expired">
        <t t-call="dojo_crm.trial_page_layout">
            <div class="text-center py-5">
                <h2 class="mb-3">Link Expired or Invalid</h2>
                <p class="lead text-muted">
                    This trial booking link has expired or is no longer valid.
                </p>
                <p>
                    Please contact us to get a new booking link, or call us directly
                    to schedule your free trial.
                </p>
            </div>
        </t>
    </template>

    <!-- ================================================================
         Already booked page
         ================================================================ -->
    <template id="trial_book_already" name="Trial Already Booked">
        <t t-call="dojo_crm.trial_page_layout">
            <div class="text-center py-4">
                <h2 class="mb-3">You Already Have a Trial Booked!</h2>
                <p class="lead">
                    Your trial is scheduled for:
                </p>
                <div class="card mx-auto" style="max-width: 400px;">
                    <div class="card-body">
                        <h5 class="card-title" t-esc="session.name"/>
                        <p class="card-text">
                            <strong>Date &amp; Time:</strong>
                            <span t-field="session.start_datetime" t-options='{"format": "EEE, MMM d, yyyy h:mm a"}'/>
                        </p>
                        <t t-if="session.instructor_profile_id">
                            <p class="card-text">
                                <strong>Instructor:</strong>
                                <span t-esc="session.instructor_profile_id.name"/>
                            </p>
                        </t>
                    </div>
                </div>
                <p class="mt-3 text-muted">
                    Need to change your booking? Contact us or use the manage link in your confirmation email.
                </p>
            </div>
        </t>
    </template>

    <!-- ================================================================
         Book trial page — session picker
         ================================================================ -->
    <template id="trial_book_page" name="Book Trial Session">
        <t t-call="dojo_crm.trial_page_layout">
            <h2 class="mb-4 text-center">Book Your Free Trial Class</h2>

            <t t-if="lead.contact_name or lead.partner_name">
                <p class="text-center lead">
                    Hi <span t-esc="lead.contact_name or lead.partner_name"/>,
                    pick a session below to reserve your spot.
                </p>
            </t>

            <t t-if="error">
                <div class="alert alert-danger" t-esc="error"/>
            </t>

            <t t-if="not sessions">
                <div class="alert alert-info text-center">
                    <strong>No trial sessions available right now.</strong><br/>
                    Please check back later or contact us to schedule directly.
                </div>
            </t>

            <t t-if="sessions">
                <form method="post" t-attf-action="/trial/book/#{lead.trial_booking_token}/confirm">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <div class="list-group mb-4">
                        <t t-foreach="sessions" t-as="s">
                            <label class="list-group-item list-group-item-action d-flex align-items-center"
                                   t-attf-for="session_#{s.id}">
                                <input type="radio" name="session_id"
                                       t-attf-id="session_#{s.id}"
                                       t-att-value="s.id"
                                       class="form-check-input me-3" required="required"/>
                                <div>
                                    <strong t-esc="s.name"/>
                                    <br/>
                                    <small class="text-muted">
                                        <span t-field="s.start_datetime" t-options='{"format": "EEE, MMM d, yyyy h:mm a"}'/> —
                                        <t t-if="s.instructor_profile_id">
                                            Instructor: <span t-esc="s.instructor_profile_id.name"/>
                                        </t>
                                        <t t-if="s.capacity">
                                            | <span t-esc="s.capacity - s.seats_taken"/> spots left
                                        </t>
                                    </small>
                                </div>
                            </label>
                        </t>
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-primary btn-lg px-5">
                            Confirm My Trial
                        </button>
                    </div>
                </form>
            </t>
        </t>
    </template>

    <!-- ================================================================
         Booking confirmation page
         ================================================================ -->
    <template id="trial_book_confirm_page" name="Trial Booking Confirmed">
        <t t-call="dojo_crm.trial_page_layout">
            <div class="text-center py-4">
                <div class="mb-4">
                    <span style="font-size: 4rem;">🥋</span>
                </div>
                <h2 class="mb-3">Your Trial is Booked!</h2>
                <div class="card mx-auto mb-4" style="max-width: 400px;">
                    <div class="card-body">
                        <h5 class="card-title" t-esc="session.name"/>
                        <p class="card-text">
                            <strong>Date &amp; Time:</strong>
                            <span t-field="session.start_datetime" t-options='{"format": "EEE, MMM d, yyyy h:mm a"}'/>
                        </p>
                        <t t-if="session.instructor_profile_id">
                            <p class="card-text">
                                <strong>Instructor:</strong>
                                <span t-esc="session.instructor_profile_id.name"/>
                            </p>
                        </t>
                    </div>
                </div>
                <p>
                    A confirmation email with a calendar invitation (.ics) has been sent to
                    <strong t-esc="lead.email_from"/>.
                </p>
                <p class="text-muted">
                    Please arrive 10 minutes early and wear comfortable workout clothes.
                </p>
                <t t-if="lead.trial_manage_url">
                    <p class="mt-3">
                        Need to cancel or reschedule?
                        <a t-att-href="lead.trial_manage_url">Manage your booking</a>.
                    </p>
                </t>
            </div>
        </t>
    </template>

    <!-- ================================================================
         Manage booking — no active booking
         ================================================================ -->
    <template id="trial_manage_no_booking" name="Trial No Active Booking">
        <t t-call="dojo_crm.trial_page_layout">
            <div class="text-center py-5">
                <h2 class="mb-3">No Active Booking Found</h2>
                <p class="lead text-muted">
                    You don't currently have an active trial booking to manage.
                </p>
                <p>Contact us to schedule a new trial.</p>
            </div>
        </t>
    </template>

    <!-- ================================================================
         Manage booking page — cancel or reschedule
         ================================================================ -->
    <template id="trial_manage_page" name="Manage Trial Booking">
        <t t-call="dojo_crm.trial_page_layout">
            <h2 class="mb-4 text-center">Manage Your Trial Booking</h2>

            <t t-if="error">
                <div class="alert alert-danger" t-esc="error"/>
            </t>
            <t t-if="success">
                <div class="alert alert-success" t-esc="success"/>
            </t>

            <!-- Current booking card -->
            <t t-if="session">
                <div class="card mb-4">
                    <div class="card-header">
                        <strong>Your Current Booking</strong>
                    </div>
                    <div class="card-body">
                        <h5 class="card-title" t-esc="session.name"/>
                        <p class="card-text">
                            <strong>Date &amp; Time:</strong>
                            <span t-field="session.start_datetime" t-options='{"format": "EEE, MMM d, yyyy h:mm a"}'/>
                        </p>
                        <t t-if="session.instructor_profile_id">
                            <p class="card-text">
                                <strong>Instructor:</strong>
                                <span t-esc="session.instructor_profile_id.name"/>
                            </p>
                        </t>
                    </div>
                </div>

                <!-- Cancel -->
                <div class="card mb-4 border-danger">
                    <div class="card-body">
                        <h5 class="card-title text-danger">Cancel Booking</h5>
                        <p>Cancel your trial and we'll release your spot.</p>
                        <form method="post"
                              t-attf-action="/trial/manage/#{lead.trial_cancel_token}/cancel">
                            <input type="hidden" name="csrf_token"
                                   t-att-value="request.csrf_token()"/>
                            <button type="submit" class="btn btn-outline-danger">
                                Cancel My Trial
                            </button>
                        </form>
                    </div>
                </div>
            </t>

            <!-- Reschedule -->
            <t t-if="sessions">
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Reschedule</h5>
                        <p>Pick a different session below:</p>
                        <form method="post"
                              t-attf-action="/trial/manage/#{lead.trial_cancel_token}/reschedule">
                            <input type="hidden" name="csrf_token"
                                   t-att-value="request.csrf_token()"/>
                            <div class="list-group mb-3">
                                <t t-foreach="sessions" t-as="s">
                                    <label class="list-group-item list-group-item-action d-flex align-items-center"
                                           t-attf-for="resched_#{s.id}">
                                        <input type="radio" name="session_id"
                                               t-attf-id="resched_#{s.id}"
                                               t-att-value="s.id"
                                               class="form-check-input me-3"
                                               required="required"/>
                                        <div>
                                            <strong t-esc="s.name"/>
                                            <br/>
                                            <small class="text-muted">
                                                <span t-field="s.start_datetime" t-options='{"format": "EEE, MMM d, yyyy h:mm a"}'/>
                                                <t t-if="s.instructor_profile_id">
                                                    — <span t-esc="s.instructor_profile_id.name"/>
                                                </t>
                                            </small>
                                        </div>
                                    </label>
                                </t>
                            </div>
                            <button type="submit" class="btn btn-primary">
                                Reschedule My Trial
                            </button>
                        </form>
                    </div>
                </div>
            </t>
        </t>
    </template>

    <!-- ================================================================
         Waiver signing page — shown between session picker and confirmation
         ================================================================ -->
    <template id="trial_waiver_page" name="Trial Booking Waiver">
        <t t-call="dojo_crm.trial_page_layout">
            <h2 class="mb-3 text-center">Sign Our Liability Waiver</h2>
            <p class="text-center text-muted mb-4">
                Before we confirm your trial, please read and sign the waiver below.
            </p>

            <!-- Error banner -->
            <t t-if="error">
                <div class="alert alert-danger" role="alert">
                    <i class="fa fa-exclamation-circle me-1"/>
                    <t t-esc="error"/>
                </div>
            </t>

            <!-- Session reminder -->
            <div class="card border-primary mb-4">
                <div class="card-body py-2">
                    <small class="text-muted">Booking for:</small>
                    <strong class="ms-2" t-esc="session.name"/>
                    <span class="ms-2 text-muted">—</span>
                    <span class="ms-1">
                        <t t-field="session.start_datetime"
                           t-options='{"format": "EEE, MMM d, yyyy h:mm a"}'/>
                    </span>
                </div>
            </div>

            <form method="post"
                  t-attf-action="/trial/book/#{lead.trial_booking_token}/waiver"
                  id="waiver_form"
                  onsubmit="return validateWaiverForm()">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <input type="hidden" name="session_id" t-att-value="session.id"/>
                <!-- Populated by JS before submit -->
                <input type="hidden" name="signature_data" id="signature_data"/>

                <!-- ── Waiver text ──────────────────────────────────────────────── -->
                <div class="card mb-4">
                    <div class="card-header fw-bold">
                        <t t-esc="waiver_config.name or 'Liability Waiver'"/>
                    </div>
                    <div class="card-body" style="max-height:350px; overflow-y:auto;">
                        <t t-out="waiver_config.content_html or ''"/>
                    </div>
                </div>

                <!-- ── Agreement checkbox ──────────────────────────────────────── -->
                <div class="form-check mb-4">
                    <input class="form-check-input" type="checkbox"
                           id="agreed" name="agreed" value="1" required="required"/>
                    <label class="form-check-label" for="agreed">
                        I have read and understood the waiver above, and I agree to its terms.
                        I confirm I have the legal authority to sign on behalf of myself
                        or the student named below.
                    </label>
                </div>

                <!-- ── Signer name ─────────────────────────────────────────────── -->
                <div class="mb-4">
                    <label class="form-label fw-bold" for="signed_by">Signing as (full name)</label>
                    <input type="text" class="form-control" id="signed_by" name="signed_by"
                           t-att-value="lead.contact_name or lead.partner_name or ''"
                           placeholder="Your full legal name" required="required"
                           autocomplete="name"/>
                    <div class="form-text text-muted">
                        If signing on behalf of a minor, enter the guardian's name.
                    </div>
                </div>

                <!-- ── Signature canvas ────────────────────────────────────────── -->
                <div class="mb-4">
                    <label class="form-label fw-bold">Draw your signature</label>
                    <div class="border rounded bg-white position-relative"
                         style="touch-action:none;">
                        <canvas id="sig_canvas"
                                width="700" height="200"
                                style="width:100%; height:200px; display:block;
                                       cursor:crosshair; border-radius:0.375rem;"/>
                    </div>
                    <div class="mt-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary"
                                onclick="clearSignature()">
                            <i class="fa fa-eraser me-1"/>Clear
                        </button>
                        <span id="sig_hint" class="ms-3 text-muted small">
                            Draw your signature in the box above.
                        </span>
                    </div>
                </div>

                <!-- ── Submit ──────────────────────────────────────────────────── -->
                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-primary btn-lg px-5">
                        Sign &amp; Book My Trial
                    </button>
                </div>
            </form>

            <!-- ── Vanilla JS signature pad ───────────────────────────────────── -->
            <script type="text/javascript">
            (function () {
                var canvas = document.getElementById('sig_canvas');
                var ctx = canvas.getContext('2d');
                var drawing = false;
                var hasMark = false;

                function scalePoint(e) {
                    var rect = canvas.getBoundingClientRect();
                    var scaleX = canvas.width / rect.width;
                    var scaleY = canvas.height / rect.height;
                    var src = e.touches ? e.touches[0] : e;
                    return {
                        x: (src.clientX - rect.left) * scaleX,
                        y: (src.clientY - rect.top) * scaleY
                    };
                }

                function startDraw(e) {
                    e.preventDefault();
                    var pt = scalePoint(e);
                    ctx.beginPath();
                    ctx.moveTo(pt.x, pt.y);
                    drawing = true;
                }

                function moveDraw(e) {
                    if (!drawing) return;
                    e.preventDefault();
                    var pt = scalePoint(e);
                    ctx.lineWidth = 2;
                    ctx.lineCap = 'round';
                    ctx.strokeStyle = '#1a1a2e';
                    ctx.lineTo(pt.x, pt.y);
                    ctx.stroke();
                    hasMark = true;
                    document.getElementById('sig_hint').style.display = 'none';
                }

                function stopDraw(e) {
                    drawing = false;
                }

                canvas.addEventListener('mousedown', startDraw);
                canvas.addEventListener('mousemove', moveDraw);
                canvas.addEventListener('mouseup', stopDraw);
                canvas.addEventListener('mouseleave', stopDraw);
                canvas.addEventListener('touchstart', startDraw, {passive: false});
                canvas.addEventListener('touchmove', moveDraw, {passive: false});
                canvas.addEventListener('touchend', stopDraw);

                window.clearSignature = function () {
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    hasMark = false;
                    document.getElementById('sig_hint').style.display = '';
                };

                window.validateWaiverForm = function () {
                    if (!hasMark) {
                        alert('Please draw your signature in the box before continuing.');
                        return false;
                    }
                    document.getElementById('signature_data').value = canvas.toDataURL('image/png');
                    return true;
                };
            })();
            </script>
        </t>
    </template>
</odoo>