<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         Shared layout wrapper for all trial booking pages
         ================================================================ -->
    <template id="trial_page_layout" name="Trial Booking Layout">
        <t t-call="website.layout">
            <div class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-lg-8 col-md-10">
                        <t t-raw="0"/>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ================================================================
         Token expired / invalid page
         ================================================================ -->
    <template id="trial_token_expired" name="Trial Token Expired">
        <t t-call="dojo_crm.trial_page_layout">
            <div class="text-center py-5">
                <h2 class="mb-3">Link Expired or Invalid</h2>
                <p class="lead text-muted">
                    This trial booking link has expired or is no longer valid.
                </p>
                <p>
                    Please contact us to get a new booking link, or call us directly
                    to schedule your free trial.
                </p>
            </div>
        </t>
    </template>

    <!-- ================================================================
         Already booked page
         ================================================================ -->
    <template id="trial_book_already" name="Trial Already Booked">
        <t t-call="dojo_crm.trial_page_layout">
            <div class="text-center py-4">
                <h2 class="mb-3">You Already Have a Trial Booked!</h2>
                <p class="lead">
                    Your trial is scheduled for:
                </p>
                <div class="card mx-auto" style="max-width: 400px;">
                    <div class="card-body">
                        <h5 class="card-title" t-esc="session.name"/>
                        <p class="card-text">
                            <strong>Date &amp; Time:</strong>
                            <span t-field="session.start_datetime" t-options='{"format": "EEE, MMM d, yyyy h:mm a"}'/>
                        </p>
                        <t t-if="session.instructor_profile_id">
                            <p class="card-text">
                                <strong>Instructor:</strong>
                                <span t-esc="session.instructor_profile_id.name"/>
                            </p>
                        </t>
                    </div>
                </div>
                <p class="mt-3 text-muted">
                    Need to change your booking? Contact us or use the manage link in your confirmation email.
                </p>
            </div>
        </t>
    </template>

    <!-- ================================================================
         Book trial page — session picker
         ================================================================ -->
    <template id="trial_book_page" name="Book Trial Session">
        <t t-call="dojo_crm.trial_page_layout">
            <h2 class="mb-4 text-center">Book Your Free Trial Class</h2>

            <t t-if="lead.contact_name or lead.partner_name">
                <p class="text-center lead">
                    Hi <span t-esc="lead.contact_name or lead.partner_name"/>,
                    pick a session below to reserve your spot.
                </p>
            </t>

            <t t-if="error">
                <div class="alert alert-danger" t-esc="error"/>
            </t>

            <t t-if="not sessions">
                <div class="alert alert-info text-center">
                    <strong>No trial sessions available right now.</strong><br/>
                    Please check back later or contact us to schedule directly.
                </div>
            </t>

            <t t-if="sessions">
                <form method="post" t-attf-action="/trial/book/#{lead.trial_booking_token}/confirm">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <div class="list-group mb-4">
                        <t t-foreach="sessions" t-as="s">
                            <label class="list-group-item list-group-item-action d-flex align-items-center"
                                   t-attf-for="session_#{s.id}">
                                <input type="radio" name="session_id"
                                       t-attf-id="session_#{s.id}"
                                       t-att-value="s.id"
                                       class="form-check-input me-3" required="required"/>
                                <div>
                                    <strong t-esc="s.name"/>
                                    <br/>
                                    <small class="text-muted">
                                        <span t-field="s.start_datetime" t-options='{"format": "EEE, MMM d, yyyy h:mm a"}'/> —
                                        <t t-if="s.instructor_profile_id">
                                            Instructor: <span t-esc="s.instructor_profile_id.name"/>
                                        </t>
                                        <t t-if="s.capacity">
                                            | <span t-esc="s.capacity - s.seats_taken"/> spots left
                                        </t>
                                    </small>
                                </div>
                            </label>
                        </t>
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-primary btn-lg px-5">
                            Confirm My Trial
                        </button>
                    </div>
                </form>
            </t>
        </t>
    </template>

    <!-- ================================================================
         Booking confirmation page
         ================================================================ -->
    <template id="trial_book_confirm_page" name="Trial Booking Confirmed">
        <t t-call="dojo_crm.trial_page_layout">
            <div class="text-center py-4">
                <div class="mb-4">
                    <span style="font-size: 4rem;">🥋</span>
                </div>
                <h2 class="mb-3">Your Trial is Booked!</h2>
                <div class="card mx-auto mb-4" style="max-width: 400px;">
                    <div class="card-body">
                        <h5 class="card-title" t-esc="session.name"/>
                        <p class="card-text">
                            <strong>Date &amp; Time:</strong>
                            <span t-field="session.start_datetime" t-options='{"format": "EEE, MMM d, yyyy h:mm a"}'/>
                        </p>
                        <t t-if="session.instructor_profile_id">
                            <p class="card-text">
                                <strong>Instructor:</strong>
                                <span t-esc="session.instructor_profile_id.name"/>
                            </p>
                        </t>
                    </div>
                </div>
                <p>
                    A confirmation email with a calendar invitation (.ics) has been sent to
                    <strong t-esc="lead.email_from"/>.
                </p>
                <p class="text-muted">
                    Please arrive 10 minutes early and wear comfortable workout clothes.
                </p>
                <t t-if="lead.trial_manage_url">
                    <p class="mt-3">
                        Need to cancel or reschedule?
                        <a t-att-href="lead.trial_manage_url">Manage your booking</a>.
                    </p>
                </t>
            </div>
        </t>
    </template>

    <!-- ================================================================
         Manage booking — no active booking
         ================================================================ -->
    <template id="trial_manage_no_booking" name="Trial No Active Booking">
        <t t-call="dojo_crm.trial_page_layout">
            <div class="text-center py-5">
                <h2 class="mb-3">No Active Booking Found</h2>
                <p class="lead text-muted">
                    You don't currently have an active trial booking to manage.
                </p>
                <p>Contact us to schedule a new trial.</p>
            </div>
        </t>
    </template>

    <!-- ================================================================
         Manage booking page — cancel or reschedule
         ================================================================ -->
    <template id="trial_manage_page" name="Manage Trial Booking">
        <t t-call="dojo_crm.trial_page_layout">
            <h2 class="mb-4 text-center">Manage Your Trial Booking</h2>

            <t t-if="error">
                <div class="alert alert-danger" t-esc="error"/>
            </t>
            <t t-if="success">
                <div class="alert alert-success" t-esc="success"/>
            </t>

            <!-- Current booking card -->
            <t t-if="session">
                <div class="card mb-4">
                    <div class="card-header">
                        <strong>Your Current Booking</strong>
                    </div>
                    <div class="card-body">
                        <h5 class="card-title" t-esc="session.name"/>
                        <p class="card-text">
                            <strong>Date &amp; Time:</strong>
                            <span t-field="session.start_datetime" t-options='{"format": "EEE, MMM d, yyyy h:mm a"}'/>
                        </p>
                        <t t-if="session.instructor_profile_id">
                            <p class="card-text">
                                <strong>Instructor:</strong>
                                <span t-esc="session.instructor_profile_id.name"/>
                            </p>
                        </t>
                    </div>
                </div>

                <!-- Cancel -->
                <div class="card mb-4 border-danger">
                    <div class="card-body">
                        <h5 class="card-title text-danger">Cancel Booking</h5>
                        <p>Cancel your trial and we'll release your spot.</p>
                        <form method="post"
                              t-attf-action="/trial/manage/#{lead.trial_cancel_token}/cancel">
                            <input type="hidden" name="csrf_token"
                                   t-att-value="request.csrf_token()"/>
                            <button type="submit" class="btn btn-outline-danger">
                                Cancel My Trial
                            </button>
                        </form>
                    </div>
                </div>
            </t>

            <!-- Reschedule -->
            <t t-if="sessions">
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Reschedule</h5>
                        <p>Pick a different session below:</p>
                        <form method="post"
                              t-attf-action="/trial/manage/#{lead.trial_cancel_token}/reschedule">
                            <input type="hidden" name="csrf_token"
                                   t-att-value="request.csrf_token()"/>
                            <div class="list-group mb-3">
                                <t t-foreach="sessions" t-as="s">
                                    <label class="list-group-item list-group-item-action d-flex align-items-center"
                                           t-attf-for="resched_#{s.id}">
                                        <input type="radio" name="session_id"
                                               t-attf-id="resched_#{s.id}"
                                               t-att-value="s.id"
                                               class="form-check-input me-3"
                                               required="required"/>
                                        <div>
                                            <strong t-esc="s.name"/>
                                            <br/>
                                            <small class="text-muted">
                                                <span t-field="s.start_datetime" t-options='{"format": "EEE, MMM d, yyyy h:mm a"}'/>
                                                <t t-if="s.instructor_profile_id">
                                                    — <span t-esc="s.instructor_profile_id.name"/>
                                                </t>
                                            </small>
                                        </div>
                                    </label>
                                </t>
                            </div>
                            <button type="submit" class="btn btn-primary">
                                Reschedule My Trial
                            </button>
                        </form>
                    </div>
                </div>
            </t>
        </t>
    </template>

    <!-- ================================================================
         Public trial sign-up form  (/trial)
         ================================================================ -->
    <template id="trial_signup_form" name="Free Trial Sign Up">
        <t t-call="dojo_crm.trial_page_layout">
            <h2 class="mb-2 text-center">Try a Free Class</h2>
            <p class="text-center text-muted mb-4">
                Fill in the form below and we'll be in touch to get you on the mat.
            </p>

            <t t-if="error">
                <div class="alert alert-danger" t-esc="error"/>
            </t>

            <form method="post" action="/trial/submit">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                <!-- Name -->
                <div class="mb-3">
                    <label for="trial_name" class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                    <input type="text" id="trial_name" name="name" class="form-control"
                           placeholder="Jane Smith" required="required" autocomplete="name"/>
                </div>

                <!-- Email -->
                <div class="mb-3">
                    <label for="trial_email" class="form-label fw-semibold">Email Address <span class="text-danger">*</span></label>
                    <input type="email" id="trial_email" name="email" class="form-control"
                           placeholder="jane@example.com" required="required" autocomplete="email"/>
                </div>

                <!-- Phone -->
                <div class="mb-3">
                    <label for="trial_phone" class="form-label fw-semibold">Phone Number</label>
                    <input type="tel" id="trial_phone" name="phone" class="form-control"
                           placeholder="+1 555 000 1234" autocomplete="tel"/>
                </div>

                <!-- Discipline -->
                <div class="mb-3">
                    <label for="trial_discipline" class="form-label fw-semibold">I'm interested in</label>
                    <select id="trial_discipline" name="discipline" class="form-select">
                        <option value="">— Select a class —</option>
                        <option value="adult_bjj">Adult BJJ</option>
                        <option value="kids_bjj">Kids BJJ</option>
                        <option value="muay_thai">Muay Thai</option>
                    </select>
                </div>

                <!-- Message -->
                <div class="mb-4">
                    <label for="trial_message" class="form-label fw-semibold">Anything else you'd like us to know?</label>
                    <textarea id="trial_message" name="message" class="form-control" rows="3"
                              placeholder="Optional — age, experience level, questions…"/>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        Request My Free Trial
                    </button>
                </div>
            </form>
        </t>
    </template>

    <!-- ================================================================
         Trial sign-up success page
         ================================================================ -->
    <template id="trial_signup_success" name="Free Trial Request Received">
        <t t-call="dojo_crm.trial_page_layout">
            <div class="text-center py-5">
                <div class="mb-4" style="font-size: 4rem;">🥋</div>
                <h2 class="mb-3">You're on the list!</h2>
                <p class="lead">
                    Thanks <t t-if="contact_name"><strong t-esc="contact_name"/></t>! We've received
                    your request and will be in touch shortly with your free trial details.
                </p>
                <p class="text-muted">
                    Keep an eye on your inbox — we'll send you a link to pick a session time
                    that works for you.
                </p>
            </div>
        </t>
    </template>
</odoo>