<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_dojo_kiosk_action_log_tree" model="ir.ui.view">
        <field name="name">dojo.kiosk.action.log.tree</field>
        <field name="model">dojo.kiosk.action.log</field>
        <field name="arch" type="xml">
            <list string="Kiosk Action Log" create="false" edit="false">
                <field name="create_date"/>
                <field name="action"/>
                <field name="member_id"/>
                <field name="session_id"/>
                <field name="is_instructor_action"/>
                <field name="summary"/>
                <field name="config_id"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_dojo_kiosk_action_log_form" model="ir.ui.view">
        <field name="name">dojo.kiosk.action.log.form</field>
        <field name="model">dojo.kiosk.action.log</field>
        <field name="arch" type="xml">
            <form string="Kiosk Action Log" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <field name="create_date"/>
                        <field name="action"/>
                        <field name="config_id"/>
                    </group>
                    <group>
                        <field name="member_id"/>
                        <field name="session_id"/>
                        <field name="is_instructor_action"/>
                    </group>
                    <group>
                        <field name="summary"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_dojo_kiosk_action_log_search" model="ir.ui.view">
        <field name="name">dojo.kiosk.action.log.search</field>
        <field name="model">dojo.kiosk.action.log</field>
        <field name="arch" type="xml">
            <search>
                <filter name="instructor_actions" string="Instructor Actions" domain="[('is_instructor_action','=',True)]"/>
                <filter name="member_actions" string="Member Actions" domain="[('is_instructor_action','=',False)]"/>
                <filter name="today" string="Today" domain="[('create_date','&gt;=', (context_today() + datetime.timedelta(days=0)).strftime('%Y-%m-%d 00:00:00'))]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_dojo_kiosk_action_log" model="ir.actions.act_window">
        <field name="name">Kiosk Action Log</field>
        <field name="res_model">dojo.kiosk.action.log</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">
                No kiosk actions logged yet
            </p>
            <p>
                This log records all kiosk interactions including check-ins, attendance marks, roster changes, and onboarding actions.
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem
        id="menu_dojo_kiosk_action_log"
        name="Action Log"
        parent="dojo_kiosk.menu_dojo_kiosk_root"
        action="action_dojo_kiosk_action_log"
        sequence="50"/>

</odoo>
