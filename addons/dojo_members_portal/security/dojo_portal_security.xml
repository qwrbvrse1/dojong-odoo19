<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="0">

    <!--
        The dojo_base module already defines row-level record rules that restrict
        portal users (group_dojo_parent_student) to their own household data for
        dojo.member, res.partner (households), dojo.class.enrollment,
        dojo.attendance.log, dojo.emergency.contact, and sale.subscription.

        Invoice access for portal users is handled entirely inside the
        DojoMemberPortal controller (controllers/main.py) using sudo() with
        explicit household-scoped ID filtering. No additional record rule is
        needed here because portal users never query account.move directly.
    -->

    <!--
        account.payment: Portal users need READ access so Odoo can resolve the
        computed field account.move.matched_payment_ids on the /my/invoices page
        without throwing an AccessError.
        The record rule below restricts visibility to payments where the partner
        is the portal user themselves, OR is another member of the same household
        (so a guardian can see all their household's payment records).
    -->
    <record id="rule_account_payment_portal" model="ir.rule">
        <field name="name">Portal: account.payment - household scope</field>
        <field name="model_id" ref="account.model_account_payment"/>
        <field name="domain_force">[
            '|',
            ('partner_id', '=', user.partner_id.id),
            '&amp;',
            ('partner_id.parent_id', '!=', False),
            ('partner_id.parent_id', '=', user.partner_id.parent_id.id if user.partner_id.parent_id else -1)
        ]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
