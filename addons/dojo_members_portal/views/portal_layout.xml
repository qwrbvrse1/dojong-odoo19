<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
         PORTAL HOME – inject dojo tiles into /my
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <template id="portal_my_home_dojo" name="Portal My Home: Dojang entries"
              inherit_id="portal.portal_my_home" customize_show="False" priority="30">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <!-- Resolve member role once for conditional tile visibility -->
            <t t-set="_dojo_member" t-value="request.env['dojo.member'].sudo().search([('partner_id', '=', request.env.user.partner_id.id)], limit=1)"/>
            <!-- Guardian-only users have no dojo.member record; check the partner flag as fallback -->
            <t t-set="_dojo_is_parent" t-value="(_dojo_member and _dojo_member.partner_id.is_guardian) or request.env.user.partner_id.is_guardian"/>

            <!-- Dojo Portal tile — rendered directly to avoid d-none count-gating -->
            <div class="o_portal_index_card col-md-6 order-2">
                <a href="/my/dojo" title="Dojang Portal" class="d-flex gap-2 gap-md-3 py-3 pe-2 px-md-3 h-100 rounded text-decoration-none bg-100">
                    <div class="o_portal_icon d-block align-self-start">
                        <img src="/dojo_members_portal/static/src/img/dojo_icon.svg"/>
                    </div>
                    <div>
                        <div class="mt-0 mb-1 fs-5 fw-normal lh-1">
                            <span>Dojang Portal</span>
                        </div>
                        <div class="opacity-75">Schedule, enrollments and attendance</div>
                    </div>
                </a>
            </div>
                            <!-- Invoices: parents / guardians only -->
            <t t-if="_dojo_is_parent">
                <div class="o_portal_index_card col-md-6 order-2">
                    <a href="/my/invoices" title="Invoices" class="d-flex gap-2 gap-md-3 py-3 pe-2 px-md-3 h-100 rounded text-decoration-none bg-100">
                        <div class="o_portal_icon d-block align-self-start">
                            <img src="/account/static/src/img/bill.svg"/>
                        </div>
                        <div>
                            <div class="mt-0 mb-1 fs-5 fw-normal lh-1">
                                <span>Invoices</span>
                            </div>
                            <div class="opacity-75">View &amp; pay subscription invoices</div>
                        </div>
                    </a>
                </div>
            </t>
            <div class="o_portal_index_card col-md-6 order-2">
                <a href="/my/dojo/household" title="My Household" class="d-flex gap-2 gap-md-3 py-3 pe-2 px-md-3 h-100 rounded text-decoration-none bg-100">
                    <div class="o_portal_icon d-block align-self-start">
                        <img src="/portal/static/src/img/portal-addresses.svg"/>
                    </div>
                    <div>
                        <div class="mt-0 mb-1 fs-5 fw-normal lh-1">
                            <span>My Household</span>
                        </div>
                        <div class="opacity-75">View your Dojang household members</div>
                    </div>
                </a>
            </div>
        </xpath>
    </template>

    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━         DOJO HOME  /my/dojo
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <template id="portal_dojo_home" name="Dojang Portal">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>

            <!-- Resolve display values: member may be False for guardian-only accounts -->
            <t t-set="_display_partner" t-value="member.partner_id if member else portal_partner"/>
            <t t-set="_display_name" t-value="member.name if member else (portal_partner.name or '?')"/>
            <t t-set="_member_number" t-value="member.member_number if member else False"/>
            <t t-set="_member_id" t-value="member.id if member else 0"/>

            <!-- ── Banner ────────────────────────────────────────────────── -->
            <div class="dojo-portal-banner mt-3"/>

            <!-- ── Welcome Hero Card (MD3) ────────────────────────────────── -->
            <div class="dojo-hero mb-4 mt-3 p-4">
                <div class="d-flex align-items-start gap-3 flex-wrap">

                    <!-- Avatar: belt colour if ranked, else role colour -->
                    <t t-set="_avatar_bg" t-value="current_rank.color if current_rank and current_rank.color else ('#1a73e8' if is_parent else '#188038')"/>
                    <div class="dojo-hero-avatar-md3" t-attf-style="background:#{_avatar_bg};">
                        <t t-out="(_display_name or '?')[0].upper()"/>
                    </div>

                    <!-- Name + meta + stat chips -->
                    <div class="flex-grow-1 min-w-0">
                        <!-- Name row -->
                        <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                            <h4 class="mb-0 fw-bold lh-1" style="color:#202124;" t-out="_display_name"/>
                            <t t-if="_display_partner.is_guardian and not _display_partner.is_student">
                                <span class="dojo-chip dojo-chip--accent">Parent</span>
                            </t>
                            <t t-elif="_display_partner.is_guardian and _display_partner.is_student">
                                <span class="dojo-chip dojo-chip--success">Standalone</span>
                            </t>
                            <t t-else="">
                                <span class="dojo-chip dojo-chip--neutral">Student</span>
                            </t>
                            <t t-if="current_rank and current_rank.color">
                                <span class="dojo-chip dojo-chip--ghost"
                                      t-attf-style="border-color:#{current_rank.color};color:#{current_rank.color};"
                                      t-out="current_rank.name"/>
                            </t>
                            <t t-if="current_rank and max_stripes and max_stripes > 0">
                                <span class="dojo-belt-stripes d-inline-flex align-items-center gap-1 ms-1" title="Belt stripes">
                                    <t t-foreach="range(max_stripes)" t-as="i">
                                        <span t-attf-style="display:inline-block;width:10px;height:10px;border-radius:50%;border:1.5px solid #{current_rank.color or '#888'};background:#{current_rank.color if i &lt; current_stripes else 'transparent'};"/>
                                    </t>
                                </span>
                            </t>
                        </div>
                        <!-- Household + member number -->
                        <div class="d-flex align-items-center gap-2 mb-3" style="color:#5f6368;font-size:.85rem;">
                            <t t-if="_display_partner.parent_id and _display_partner.parent_id.is_household">
                                <span t-out="_display_partner.parent_id.name"/>
                            </t>
                            <t t-if="_member_number">
                                <t t-if="_display_partner.parent_id and _display_partner.parent_id.is_household"><span>·</span></t>
                                <span t-out="_member_number"/>
                            </t>
                        </div>
                        <!-- Stat chips row -->
                        <div class="d-flex flex-wrap gap-2">
                            <span class="dojo-stat-chip">
                                <span class="dojo-stat-chip__val" t-out="attendance_count"/>
                                <span class="dojo-stat-chip__lbl">Sessions</span>
                            </span>
                            <span class="dojo-stat-chip">
                                <span class="dojo-stat-chip__val" t-out="upcoming_count"/>
                                <span class="dojo-stat-chip__lbl">Upcoming</span>
                            </span>
                            <t t-if="is_credit_plan">
                                <span class="dojo-stat-chip">
                                    <span class="dojo-stat-chip__val" t-out="credit_balance"/>
                                    <span class="dojo-stat-chip__lbl">Credits</span>
                                </span>
                            </t>
                            <t t-if="is_parent">
                                <a href="/my/invoices" class="dojo-stat-chip" title="View invoices">
                                    <span class="dojo-stat-chip__val"><i class="fa fa-file-text-o"/></span>
                                    <span class="dojo-stat-chip__lbl">Billing</span>
                                </a>
                            </t>
                            <t t-if="_member_number">
                                <a href="/my/dojo/badge/print" target="_blank" class="dojo-stat-chip" title="View &amp; Print Badge">
                                    <span class="dojo-stat-chip__val"><i class="fa fa-id-card"/></span>
                                    <span class="dojo-stat-chip__lbl">Badge</span>
                                </a>
                            </t>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Household saved flash ───────────────────────────────────── -->
            <t t-if="household_saved">
                <div class="alert alert-success alert-dismissible mb-3" role="alert">
                    <i class="fa fa-check-circle me-1"/> Household information saved.
                    <button type="button" class="btn-close" data-bs-dismiss="alert"/>
                </div>
            </t>
            <!-- ── Plan upgraded flash ────────────────────────────────────────── -->
            <t t-if="plan_upgraded and not invoice_warning">
                <div class="alert alert-success alert-dismissible mb-3" role="alert">
                    <i class="fa fa-check-circle me-1"/>
                    <strong>Congratulations!</strong> Your membership is now active and your first invoice has been sent.
                    <button type="button" class="btn-close" data-bs-dismiss="alert"/>
                </div>
            </t>
            <t t-if="plan_upgraded and invoice_warning">
                <div class="alert alert-warning alert-dismissible mb-3" role="alert">
                    <i class="fa fa-exclamation-triangle me-1"/>
                    <strong>Membership activated</strong>, but we could not generate your first invoice automatically.
                    Please contact the front desk or try again from the Billing tab.
                    <button type="button" class="btn-close" data-bs-dismiss="alert"/>
                </div>
            </t>
            <!-- ── JS activities mount ─────────────────────────────────────── -->
            <div id="dojo_activities_mount"
                 t-att-data-tab="initial_tab or 'programs'"
                 t-att-data-is-parent="'true' if is_parent else 'false'"
                 t-att-data-is-student-only="'true' if is_student_only else 'false'"
                 t-att-data-members="members_json"
                 t-att-data-students="students_json"
                 t-att-data-member-id="_member_id"
                 t-att-data-csrf="request.csrf_token()"
                 class="dojo-portal-root mt-3"/>
        </t>
    </template>

    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
         LANGUAGE FIX  – ensure frontend_languages is never None in portal pages
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <template id="dojo_portal_lang_fix" inherit_id="portal.language_selector" priority="1">
        <xpath expr="//t[@t-set='language_selector_visible']" position="before">
            <!-- Guard: without website module, frontend_languages is None which
                 causes len(None) crash. Replace with empty dict so the selector
                 simply hides (visible = len({}) > 1 = False). -->
            <t t-if="not frontend_languages" t-set="frontend_languages" t-value="{}"/>
        </xpath>
    </template>

    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
         DOJO PORTAL  /my/dojo/schedule  /my/dojo/enrollments  /my/dojo/attendance
         All three handled by the vanilla-JS DojoPortal component
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <template id="portal_dojo_activities" name="Dojo Portal">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>
            <!-- Resolve title in outer scope before passing into t-call -->
            <t t-if="initial_tab == 'schedule'"><t t-set="page_title">Class Schedule</t></t>
            <t t-elif="initial_tab == 'enrollments'"><t t-set="page_title">My Enrollments</t></t>
            <t t-elif="initial_tab == 'attendance'"><t t-set="page_title">Attendance History</t></t>
            <t t-else=""><t t-set="page_title">Dojo Portal</t></t>
            <t t-call="portal.portal_searchbar">
                <t t-set="title" t-value="page_title"/>
            </t>
            <!-- JS mount point; data-tab drives which tab opens first -->
            <div id="dojo_activities_mount"
                 t-att-data-tab="initial_tab or 'schedule'"
                 class="dojo-portal-root mt-3"/>
        </t>
    </template>

    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
         MY INVOICES  /my/dojo/invoices
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->


    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
         BILLING &amp; PAYMENT  /my/dojo/billing
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->


    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
         PAY INVOICE  /my/dojo/invoices/<id>/pay
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->


    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
         MY HOUSEHOLD  /my/dojo/household
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <template id="portal_my_household" name="My Household">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">My Household</t>
            </t>

            <t t-if="success">
                <div class="alert alert-success" role="alert">
                    <strong>Saved!</strong> Your household information has been updated.
                </div>
            </t>
            <t t-if="error.get('new_contact')">
                <div class="alert alert-danger" role="alert">
                    <t t-out="error['new_contact']"/>
                </div>
            </t>

            <!-- ── EDITABLE VIEW (parents / guardians) ──────────────────────────── -->
            <t t-if="can_edit">
                <form method="POST" action="/my/dojo/household" class="mt-3">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <!-- Household name -->
                    <t t-if="household">
                        <div class="card mb-4">
                            <div class="card-header"><strong>Household</strong></div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label for="household_name" class="form-label">Household Name</label>
                                    <input type="text" class="form-control" id="household_name"
                                           name="household_name"
                                           t-att-value="household.name or ''"/>
                                </div>
                            </div>
                        </div>
                    </t>

                    <!-- Emergency contacts per member -->
                    <t t-foreach="household_members" t-as="hm">
                        <div class="card mb-4">
                            <div class="card-header">
                                <strong>Emergency Contacts for <t t-out="hm.name"/></strong>
                            </div>
                            <div class="card-body">
                                <t t-if="hm.emergency_contact_ids">
                                    <table class="table table-sm mb-3">
                                        <thead>
                                            <tr>
                                                <th>Name</th><th>Relationship</th>
                                                <th>Phone</th><th>Email</th><th>Primary</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="hm.emergency_contact_ids" t-as="ec">
                                                <tr>
                                                    <td><t t-out="ec.name"/></td>
                                                    <td><t t-out="ec.relationship"/></td>
                                                    <td><t t-out="ec.phone"/></td>
                                                    <td><t t-out="ec.email or '—'"/></td>
                                                    <td>
                                                        <span t-if="ec.is_primary" class="badge bg-success">Primary</span>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-else="">
                                    <p class="text-muted">No emergency contacts on file.</p>
                                </t>
                            </div>
                        </div>
                    </t>

                    <!-- Add new emergency contact -->
                    <div class="card mb-4">
                        <div class="card-header"><strong>Add Emergency Contact</strong></div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label">For Member</label>
                                    <select name="new_contact_member_id" class="form-select">
                                        <t t-foreach="household_members" t-as="hm">
                                            <option t-att-value="hm.id" t-out="hm.name"/>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Contact Name *</label>
                                    <input type="text" class="form-control" name="new_contact_name"
                                           placeholder="Full name"/>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Relationship</label>
                                    <input type="text" class="form-control" name="new_contact_relationship"
                                           placeholder="e.g. Mother, Uncle"/>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Phone *</label>
                                    <input type="tel" class="form-control" name="new_contact_phone"
                                           placeholder="+1 555 000 0000"/>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Email</label>
                                    <input type="email" class="form-control" name="new_contact_email"
                                           placeholder="optional@email.com"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <a href="/my/dojo" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </t>

            <!-- ── READ-ONLY VIEW (students) ───────────────────────────────────── -->
            <t t-else="">
                <div class="mt-3">
                    <t t-if="household">
                        <div class="card mb-4">
                            <div class="card-header"><strong>Household</strong></div>
                            <div class="card-body">
                                <p class="mb-0"><strong>Name:</strong> <t t-out="household.name or '—'"/></p>
                            </div>
                        </div>
                    </t>

                    <t t-foreach="household_members" t-as="hm">
                        <div class="card mb-4">
                            <div class="card-header">
                                <strong>Emergency Contacts for <t t-out="hm.name"/></strong>
                            </div>
                            <div class="card-body">
                                <t t-if="hm.emergency_contact_ids">
                                    <table class="table table-sm mb-0">
                                        <thead>
                                            <tr>
                                                <th>Name</th><th>Relationship</th>
                                                <th>Phone</th><th>Email</th><th>Primary</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="hm.emergency_contact_ids" t-as="ec">
                                                <tr>
                                                    <td><t t-out="ec.name"/></td>
                                                    <td><t t-out="ec.relationship"/></td>
                                                    <td><t t-out="ec.phone"/></td>
                                                    <td><t t-out="ec.email or '—'"/></td>
                                                    <td>
                                                        <span t-if="ec.is_primary" class="badge bg-success">Primary</span>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-else="">
                                    <p class="text-muted mb-0">No emergency contacts on file.</p>
                                </t>
                            </div>
                        </div>
                    </t>

                    <div class="alert alert-info mt-2" role="alert">
                        <i class="fa fa-info-circle"/> To update household information or emergency contacts,
                        please contact the Dojang admin.
                    </div>
                    <a href="/my/dojo" class="btn btn-secondary btn-sm">Back to Dojang Home</a>
                </div>
            </t>
        </t>
    </template>

    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
         FALLBACK – user has no dojo.member record
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <template id="portal_no_member" name="No Dojang Member">
        <t t-call="portal.portal_layout">
            <div class="alert alert-warning mt-4" role="alert">
                <h4 class="alert-heading">No Member Profile Found</h4>
                <p>
                    Your account is not linked to a Dojang member profile yet.
                    Please contact the Dojang admin to get this set up.
                </p>
                <a href="/my" class="btn btn-primary">Back to My Account</a>
            </div>
        </t>
    </template>

</odoo>
