<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="dojo_instructor_dashboard.InstructorDashboard">
<div class="o_di_root" t-ref="root">

    <t t-if="state.loading">
        <div class="d-flex justify-content-center align-items-center" style="min-height:360px">
            <div class="spinner-border" style="color:#1a73e8" role="status">
                <span class="visually-hidden">Loading…</span>
            </div>
        </div>
    </t>

    <t t-else="">

        <!-- No profile state -->
        <t t-if="!state.profile">
            <div class="o_di_page_header">
                <div class="o_di_header_left">
                    <div class="o_di_header_icon o_di_header_icon_blue">
                        <i class="fa fa-user"/>
                    </div>
                    <div>
                        <div class="o_di_header_title">Instructor Dashboard</div>
                        <div class="o_di_header_date" t-out="todayLabel"/>
                    </div>
                </div>
            </div>
            <div style="padding:28px">
                <div class="o_di_card" style="max-width:480px;margin:auto">
                    <div class="o_di_card_body">
                        <div class="o_di_empty">
                            <i class="fa fa-user-times fa-2x" style="color:#d93025"/>
                            <div class="fw-semibold">No instructor profile found</div>
                            <div style="color:#5f6368;font-size:.85rem">
                                Your account is not linked to an instructor record.
                                Contact an administrator to set up your instructor profile.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>

        <t t-else="">

            <!-- ── Page Header ──────────────────────────────────────── -->
            <div class="o_di_page_header">
                <div class="o_di_header_left">
                    <div class="o_di_header_icon o_di_header_icon_blue">
                        <i class="fa fa-user"/>
                    </div>
                    <div>
                        <div class="o_di_header_title">
                            <t t-out="greeting"/>, <t t-out="state.profile.name"/>
                        </div>
                        <div class="o_di_header_date" t-out="todayLabel"/>
                    </div>
                </div>
                <div class="o_di_header_actions">
                    <button class="o_di_hdr_btn" t-on-click="openTodaysClasses">
                        <i class="fa fa-calendar-check-o"/>Today's Classes
                    </button>
                    <button class="o_di_hdr_btn" t-on-click="openMyStudents">
                        <i class="fa fa-users"/>My Students
                    </button>
                    <button class="o_di_hdr_btn o_di_hdr_btn_icon" t-on-click="_reload" title="Refresh">
                        <i class="fa fa-refresh"/>
                    </button>
                </div>
            </div>

            <!-- ── KPI Stat Chips ────────────────────────────────────── -->
            <div class="o_di_stat_row">

                <div class="o_di_stat_chip o_di_stat_blue is-clickable" t-on-click="openTodaysClasses">
                    <div class="o_di_stat_value" t-out="state.profile.sessions_today_count"/>
                    <div class="o_di_stat_label">Today's Classes</div>
                </div>

                <div class="o_di_stat_chip o_di_stat_green is-clickable" t-on-click="openMyStudents">
                    <div class="o_di_stat_value" t-out="state.profile.students_total_count"/>
                    <div class="o_di_stat_label">My Students</div>
                </div>

                <div class="o_di_stat_chip o_di_stat_orange">
                    <div class="o_di_stat_value"><t t-out="pct(state.profile.avg_fill_rate)"/></div>
                    <div class="o_di_stat_label">Avg Fill Rate</div>
                    <div class="o_di_stat_sub">last 30 days</div>
                </div>

                <div class="o_di_stat_chip o_di_stat_purple">
                    <div class="o_di_stat_value"><t t-out="pct(state.profile.attendance_rate)"/></div>
                    <div class="o_di_stat_label">Attendance Rate</div>
                    <div class="o_di_stat_sub">last 30 days</div>
                </div>

            </div>

            <!-- ── Quick Actions ─────────────────────────────────────── -->
            <div class="o_di_section_label">Quick Actions</div>
            <div class="o_di_quick_grid">

                <button class="o_di_quick_item" t-on-click="openTodaysClasses">
                    <div class="o_di_quick_icon o_di_quick_icon_blue">
                        <i class="fa fa-calendar-check-o"/>
                    </div>
                    <span class="o_di_quick_label">Today's Classes</span>
                </button>

                <button class="o_di_quick_item" t-on-click="openKiosk">
                    <div class="o_di_quick_icon o_di_quick_icon_green">
                        <i class="fa fa-tablet"/>
                    </div>
                    <span class="o_di_quick_label">Kiosk</span>
                </button>

                <button class="o_di_quick_item" t-on-click="openMyStudents">
                    <div class="o_di_quick_icon o_di_quick_icon_teal">
                        <i class="fa fa-users"/>
                    </div>
                    <span class="o_di_quick_label">My Students</span>
                </button>

                <button class="o_di_quick_item" t-on-click="openCalendar">
                    <div class="o_di_quick_icon o_di_quick_icon_purple">
                        <i class="fa fa-calendar"/>
                    </div>
                    <span class="o_di_quick_label">Class Calendar</span>
                </button>

                <button class="o_di_quick_item" t-on-click="openTodos">
                    <div class="o_di_quick_icon o_di_quick_icon_orange">
                        <i class="fa fa-tasks"/>
                    </div>
                    <span class="o_di_quick_label">My To-Dos</span>
                </button>

            </div>

            <!-- ── Content 2-col Grid ────────────────────────────────── -->
            <div class="o_di_content_grid">

                <!-- Today's Classes -->
                <div class="o_di_card">
                    <div class="o_di_card_header">
                        <div class="o_di_card_title">
                            Today's Classes
                            <span class="o_di_card_subtitle" t-out="todayLabel"/>
                        </div>
                        <button class="o_di_view_btn" t-on-click="openTodaysClasses">View All</button>
                    </div>
                    <div class="o_di_card_body">
                        <t t-if="state.sessionsToday.length === 0">
                            <div class="o_di_empty">
                                <i class="fa fa-calendar-o fa-2x"/>
                                <div>No classes scheduled for today</div>
                            </div>
                        </t>
                        <t t-else="">
                            <t t-foreach="state.sessionsToday" t-as="s" t-key="s.id">
                                <div class="o_di_session_row">
                                    <div class="o_di_session_info">
                                        <div class="o_di_session_name">
                                            <t t-out="s.template_id[1]"/>
                                        </div>
                                        <div class="o_di_session_meta">
                                            <i class="fa fa-clock-o me-1"/>
                                            <t t-out="fmtDt(s.start_datetime)"/>
                                            <span class="ms-2">
                                                <i class="fa fa-users me-1"/>
                                                <t t-out="s.seats_taken"/>/<t t-out="s.capacity"/>
                                            </span>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <span t-attf-class="o_di_badge {{ stateBadgeClass(s.state) }}">
                                            <t t-out="stateLabel(s.state)"/>
                                        </span>
                                        <t t-if="s.state !== 'cancelled'">
                                            <button class="o_di_attend_btn"
                                                    t-on-click="() => this.openQuickAttendance(s.id)">
                                                <i class="fa fa-check me-1"/>Attendance
                                            </button>
                                        </t>
                                    </div>
                                </div>
                            </t>
                        </t>
                    </div>
                </div>

                <!-- Upcoming Classes -->
                <div class="o_di_card">
                    <div class="o_di_card_header">
                        <div class="o_di_card_title">
                            Upcoming Classes
                            <span class="o_di_card_subtitle">next 14 days</span>
                        </div>
                        <button class="o_di_view_btn" t-on-click="openCalendar">Calendar</button>
                    </div>
                    <div class="o_di_card_body">
                        <t t-if="state.upcomingSessions.length === 0">
                            <div class="o_di_empty">
                                <i class="fa fa-calendar fa-2x"/>
                                <div>No upcoming classes in the next 14 days</div>
                            </div>
                        </t>
                        <t t-else="">
                            <t t-foreach="state.upcomingSessions" t-as="s" t-key="s.id">
                                <div class="o_di_session_row">
                                    <div class="o_di_session_info">
                                        <div class="o_di_session_name">
                                            <t t-out="s.template_id[1]"/>
                                        </div>
                                        <div class="o_di_session_meta">
                                            <i class="fa fa-calendar-o me-1"/>
                                            <t t-out="fmtDt(s.start_datetime)"/>
                                            <span class="ms-2">
                                                <i class="fa fa-users me-1"/>
                                                <t t-out="s.seats_taken"/>/<t t-out="s.capacity"/>
                                            </span>
                                        </div>
                                    </div>
                                    <span t-attf-class="o_di_badge {{ stateBadgeClass(s.state) }}">
                                        <t t-out="stateLabel(s.state)"/>
                                    </span>
                                </div>
                            </t>
                        </t>
                    </div>
                </div>

                <!-- Recent Students -->
                <div class="o_di_card">
                    <div class="o_di_card_header">
                        <div class="o_di_card_title">
                            <i class="fa fa-users me-2" style="color:#1a73e8"/>My Recent Students
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <t t-if="state.recentStudents.length > 0">
                                <button class="o_di_carousel_nav"
                                        t-on-click="prevStudentPage"
                                        t-att-disabled="state.studentPage === 0">
                                    <i class="fa fa-chevron-left"/>
                                </button>
                                <span class="o_di_carousel_pager">
                                    <t t-out="state.studentPage + 1"/>/<t t-out="totalStudentPages"/>
                                </span>
                                <button class="o_di_carousel_nav"
                                        t-on-click="nextStudentPage"
                                        t-att-disabled="state.studentPage >= totalStudentPages - 1">
                                    <i class="fa fa-chevron-right"/>
                                </button>
                            </t>
                            <button class="o_di_view_btn" t-on-click="openMyStudents">View All</button>
                        </div>
                    </div>
                    <div class="o_di_card_body">
                        <t t-if="state.recentStudents.length === 0">
                            <div class="o_di_empty">
                                <i class="fa fa-users fa-2x"/>
                                <div>No students found</div>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="o_di_student_grid">
                                <t t-foreach="visibleStudents" t-as="s" t-key="s.id">
                                    <button class="o_di_student_card"
                                            t-on-click="() => this.openStudentProfile(s.id)">
                                        <div class="o_di_student_avatar">
                                            <img t-att-src="'/web/image/res.partner/' + s.partner_id + '/image_128'"
                                                 alt=""
                                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"/>
                                            <div class="o_di_student_avatar_fallback">
                                                <i class="fa fa-user"/>
                                            </div>
                                        </div>
                                        <span class="o_di_student_name" t-out="s.name"/>
                                    </button>
                                </t>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- Kiosk -->
                <div class="o_di_card">
                    <div class="o_di_card_header">
                        <div class="o_di_card_title">Kiosk</div>
                        <button class="o_di_view_btn" t-on-click="openKiosk">Manage</button>
                    </div>
                    <div class="o_di_card_body">
                        <t t-if="state.kiosks.length === 0">
                            <div class="o_di_empty">
                                <i class="fa fa-tablet fa-2x"/>
                                <div>No kiosks configured</div>
                            </div>
                        </t>
                        <t t-else="">
                            <t t-foreach="state.kiosks" t-as="k" t-key="k.id">
                                <div class="o_di_session_row">
                                    <div class="o_di_session_info">
                                        <div class="o_di_session_name" t-out="k.name"/>
                                        <div class="o_di_session_meta">
                                            <i class="fa fa-link me-1"/>
                                            <t t-out="k.kiosk_url"/>
                                        </div>
                                    </div>
                                    <button class="o_di_attend_btn"
                                            t-on-click="() => this.launchKioskUrl(k.kiosk_url)">
                                        <i class="fa fa-external-link me-1"/>Launch
                                    </button>
                                </div>
                            </t>
                        </t>
                    </div>
                </div>

                <!-- My To-Dos -->
                <div class="o_di_card">
                    <div class="o_di_card_header">
                        <div class="o_di_card_title">My To-Dos</div>
                        <button class="o_di_view_btn" t-on-click="openTodos">View All</button>
                    </div>
                    <div class="o_di_card_body">
                        <t t-if="state.todos.length === 0">
                            <div class="o_di_empty">
                                <i class="fa fa-check-circle fa-2x" style="color:#1e8e3e"/>
                                <div>All caught up! No open to-dos.</div>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="o_di_todo_list">
                                <t t-foreach="state.todos" t-as="todo" t-key="todo.id">
                                    <div class="o_di_todo_item">
                                        <i class="fa fa-circle-o o_di_todo_icon"/>
                                        <div class="o_di_todo_body">
                                            <div class="o_di_todo_name" t-out="todo.name"/>
                                            <t t-if="todo.date_deadline">
                                                <div class="o_di_todo_due">
                                                    <i class="fa fa-calendar-o me-1"/>
                                                    Due <t t-out="fmtDate(todo.date_deadline)"/>
                                                </div>
                                            </t>
                                        </div>
                                        <span t-attf-class="o_di_badge {{ todo.priority === '1' ? 'o_di_badge_warning' : 'o_di_badge_secondary' }}">
                                            <t t-out="todo.priority === '1' ? 'High Priority' : 'Normal'"/>
                                        </span>
                                    </div>
                                </t>
                            </div>
                        </t>
                    </div>
                </div>

            </div><!-- /.o_di_content_grid -->

        </t>
    </t>

    <!-- ── AI Voice Assistant (floating) ──────────────── -->
    <DojoVoiceAssistant/>

</div>
</t>

</templates>
