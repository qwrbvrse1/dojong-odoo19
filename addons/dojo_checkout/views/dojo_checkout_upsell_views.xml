<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ── List view ────────────────────────────────────────────────── -->
    <record id="view_dojo_checkout_upsell_list" model="ir.ui.view">
        <field name="name">dojo.checkout.upsell.list</field>
        <field name="model">dojo.checkout.upsell</field>
        <field name="arch" type="xml">
            <list string="Upsell Items">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="type"/>
                <field name="price"/>
                <field name="plan_ids" widget="many2many_tags"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ── Form view ────────────────────────────────────────────────── -->
    <record id="view_dojo_checkout_upsell_form" model="ir.ui.view">
        <field name="name">dojo.checkout.upsell.form</field>
        <field name="model">dojo.checkout.upsell</field>
        <field name="arch" type="xml">
            <form string="Upsell Item">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Item Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="type"/>
                            <field name="price"/>
                            <field name="product_id"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="plan_ids" widget="many2many_tags"
                                   options="{'no_quick_create': True}"/>
                        </group>
                    </group>
                    <separator string="Description"/>
                    <field name="description" placeholder="Brief description shown to members at checkout…"/>
                    <separator string="Image"/>
                    <field name="image_1920" widget="image" class="oe_avatar"
                           options="{'preview_image': 'image_128'}"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action ──────────────────────────────────────────────────── -->
    <record id="action_dojo_checkout_upsell" model="ir.actions.act_window">
        <field name="name">Upsell Items</field>
        <field name="res_model">dojo.checkout.upsell</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No upsell items yet.</p>
            <p>Add uniforms, merchandise, or donation options to show during checkout.</p>
        </field>
    </record>

</odoo>
