<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_firebase_push_class_reminder" model="ir.cron">
            <field name="name">Dojo Firebase: Push Class Reminder Notifications</field>
            <field name="model_id" ref="model_dojo_firebase_push"/>
            <field name="state">code</field>
            <field name="code">model._cron_push_class_reminders()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).replace(hour=16, minute=0, second=0, microsecond=0)"/>
        </record>
    </data>
</odoo>
