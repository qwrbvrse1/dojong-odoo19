<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard form view -->
    <record id="view_dojo_credit_adjustment_wizard_form" model="ir.ui.view">
        <field name="name">dojo.credit.adjustment.wizard.form</field>
        <field name="model">dojo.credit.adjustment.wizard</field>
        <field name="arch" type="xml">
            <form string="Manual Credit Adjustment">
                <group>
                    <field name="subscription_id" options="{'no_create': True}"/>
                    <field name="member_id" readonly="1"/>
                    <field name="current_balance" readonly="1"/>
                </group>
                <group>
                    <field name="amount"
                           help="Use a positive number to add credits, negative to deduct."/>
                    <field name="note" placeholder="Reason for adjustment (required)"/>
                </group>
                <footer>
                    <button string="Apply Adjustment" type="object"
                            name="action_apply" class="btn-primary"
                            data-hotkey="q"/>
                    <button string="Cancel" special="cancel"
                            data-hotkey="z" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Standalone action so it can be launched from elsewhere -->
    <record id="action_dojo_credit_adjustment_wizard" model="ir.actions.act_window">
        <field name="name">Manual Credit Adjustment</field>
        <field name="res_model">dojo.credit.adjustment.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu entry under Credits -->
    <menuitem
        id="menu_dojo_credit_adjustment"
        name="Manual Adjustment"
        parent="dojo_credits.menu_dojo_credits_root"
        action="action_dojo_credit_adjustment_wizard"
        sequence="20"
        groups="dojo_base.group_dojo_admin"/>
</odoo>
