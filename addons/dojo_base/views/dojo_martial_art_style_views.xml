<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========== Martial Art Style ========== -->

    <record id="view_dojo_martial_art_style_list" model="ir.ui.view">
        <field name="name">dojo.martial.art.style.list</field>
        <field name="model">dojo.martial.art.style</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_dojo_martial_art_style_form" model="ir.ui.view">
        <field name="name">dojo.martial.art.style.form</field>
        <field name="model">dojo.martial.art.style</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="active"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dojo_martial_art_styles" model="ir.actions.act_window">
        <field name="name">Martial Art Styles</field>
        <field name="res_model">dojo.martial.art.style</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
