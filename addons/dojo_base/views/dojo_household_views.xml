<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Household list view (res.partner where is_household=True) -->
    <record id="view_dojo_household_list" model="ir.ui.view">
        <field name="name">res.partner.household.list</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="primary_guardian_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Household form view (res.partner where is_household=True) -->
    <record id="view_dojo_household_form" model="ir.ui.view">
        <field name="name">res.partner.household.form</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="primary_guardian_id"
                               domain="[('parent_id', '=', id), ('is_guardian', '=', True)]"
                               options="{'no_create': True}"
                               help="Pick a guardian contact in this household."/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <notebook>
                        <page string="Household Members">
                            <field name="child_ids"
                                   domain="[('is_household', '=', False)]"
                                   context="{'default_parent_id': id}">
                                <list>
                                    <field name="name"/>
                                    <field name="email"/>
                                    <field name="is_student"/>
                                    <field name="is_guardian"/>
                                    <field name="is_minor"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
