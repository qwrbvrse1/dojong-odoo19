<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="dojo_core.AdminDashboard">
<div class="o_di_root" t-ref="root">

    <t t-if="state.loading">
        <div class="d-flex justify-content-center align-items-center" style="min-height:360px">
            <div class="spinner-border" style="color:#1a73e8" role="status">
                <span class="visually-hidden">Loading…</span>
            </div>
        </div>
    </t>

    <t t-else="">

        <!-- ── Page Header ──────────────────────────────────────── -->
        <div class="o_di_page_header">
            <div class="o_di_header_left">
                <div class="o_di_header_icon">
                    <span class="material-symbols-outlined">dashboard</span>
                </div>
                <div>
                    <div class="o_ad_header_title">Dojang Dashboard</div>
                    <div class="o_ad_header_date" t-out="todayLabel"/>
                </div>
            </div>
            <div class="o_di_header_actions">
                <button class="o_ad_hdr_btn" t-on-click="openTodaysSessions">
                    <span class="material-symbols-outlined">history_edu</span>Today's Sessions
                </button>
                <button class="o_ad_hdr_btn" t-on-click="openCalendar">
                    <span class="material-symbols-outlined">calendar_month</span>Calendar
                </button>
                <button class="o_ad_hdr_btn" t-on-click="openAllStudents">
                    <span class="material-symbols-outlined">group</span>All Students
                </button>
                <button class="o_ad_hdr_btn o_ad_hdr_btn_icon o_ad_hdr_btn_refresh" t-on-click="_reload" title="Refresh">
                    <span class="material-symbols-outlined">refresh</span>
                </button>
            </div>
        </div>

        <!-- ── KPI Stat Chips ────────────────────────────────────── -->
        <t t-if="state.summary">
            <div class="o_ad_stat_row">

                <div class="o_ad_stat_chip o_ad_stat_indigo is-clickable" t-on-click="openInstructorKpis">
                    <div class="o_ad_stat_value" t-out="state.summary.total_instructors"/>
                    <div class="o_ad_stat_label">Instructors</div>
                </div>

                <div class="o_ad_stat_chip o_ad_stat_green is-clickable" t-on-click="openAllStudents">
                    <div class="o_ad_stat_value" t-out="state.summary.total_active_students"/>
                    <div class="o_ad_stat_label">Active Students</div>
                </div>

                <div class="o_ad_stat_chip o_ad_stat_blue is-clickable" t-on-click="openTodaysSessions">
                    <div class="o_ad_stat_value" t-out="state.summary.sessions_today"/>
                    <div class="o_ad_stat_label">Sessions Today</div>
                </div>

                <div class="o_ad_stat_chip o_ad_stat_orange">
                    <div class="o_ad_stat_value"><t t-out="pct(state.summary.overall_fill_rate)"/></div>
                    <div class="o_ad_stat_label">Avg Fill Rate</div>
                    <div class="o_ad_stat_sub">last 30 days</div>
                </div>

                <div class="o_ad_stat_chip o_ad_stat_purple">
                    <div class="o_ad_stat_value"><t t-out="pct(state.summary.overall_attendance_rate)"/></div>
                    <div class="o_ad_stat_label">Attendance Rate</div>
                    <div class="o_ad_stat_sub">last 30 days</div>
                </div>

                <div class="o_ad_stat_chip o_ad_stat_red">
                    <div class="o_ad_stat_value" t-out="state.summary.total_dropped_60d"/>
                    <div class="o_ad_stat_label">Dropped Enrollments</div>
                    <div class="o_ad_stat_sub">last 60 days</div>
                </div>

                <div class="o_ad_stat_chip o_ad_stat_teal is-clickable" t-on-click="openInvoices">
                    <div class="o_ad_stat_value" t-out="currency(state.summary.revenue_this_month)"/>
                    <div class="o_ad_stat_label">Revenue This Month</div>
                </div>

                <div class="o_ad_stat_chip o_ad_stat_teal is-clickable" t-on-click="openInvoices">
                    <div class="o_ad_stat_value" t-out="currency(state.summary.revenue_ytd)"/>
                    <div class="o_ad_stat_label">Revenue YTD</div>
                </div>

                <div class="o_ad_stat_chip o_ad_stat_amber">
                    <div class="o_ad_stat_value" t-out="currency(state.summary.outstanding_balance)"/>
                    <div class="o_ad_stat_label">Outstanding Balance</div>
                </div>

                <div class="o_ad_stat_chip o_ad_stat_green is-clickable" t-on-click="openAllStudents">
                    <div class="o_ad_stat_value" t-out="state.summary.new_members_this_month"/>
                    <div class="o_ad_stat_label">New Members</div>
                    <div class="o_ad_stat_sub">this month</div>
                </div>

            </div>
        </t>

        <!-- ── Command Center ─────────────────────────────────────── -->
        <div class="o_ad_section_label">Quick Actions</div>
        <div class="o_ad_quick_grid">

            <button class="o_ad_quick_item" t-on-click="openOnboarding">
                <div class="o_ad_quick_icon">
                    <span class="material-symbols-outlined">assignment_ind</span>
                </div>
                <span class="o_ad_quick_label">New Onboarding</span>
            </button>

            <button class="o_ad_quick_item" t-on-click="openNewMember">
                <div class="o_ad_quick_icon">
                    <span class="material-symbols-outlined">person_add</span>
                </div>
                <span class="o_ad_quick_label">Add Member</span>
            </button>

            <button class="o_ad_quick_item" t-on-click="openBeltTests">
                <div class="o_ad_quick_icon">
                    <span class="material-symbols-outlined">military_tech</span>
                </div>
                <span class="o_ad_quick_label">Belt Tests</span>
            </button>

            <button class="o_ad_quick_item" t-on-click="openSubscriptions">
                <div class="o_ad_quick_icon">
                    <span class="material-symbols-outlined">subscriptions</span>
                </div>
                <span class="o_ad_quick_label">Subscriptions</span>
            </button>

            <button class="o_ad_quick_item" t-on-click="openCommunications">
                <div class="o_ad_quick_icon">
                    <span class="material-symbols-outlined">send</span>
                </div>
                <span class="o_ad_quick_label">Send Message</span>
            </button>

            <button class="o_ad_quick_item" t-on-click="openInvoices">
                <div class="o_ad_quick_icon">
                    <span class="material-symbols-outlined">receipt_long</span>
                </div>
                <span class="o_ad_quick_label">Invoices</span>
            </button>

            <button class="o_ad_quick_item" t-on-click="openTodaysSessions">
                <div class="o_ad_quick_icon">
                    <span class="material-symbols-outlined">history_edu</span>
                </div>
                <span class="o_ad_quick_label">Today's Sessions</span>
            </button>

            <button class="o_ad_quick_item" t-on-click="openCalendar">
                <div class="o_ad_quick_icon">
                    <span class="material-symbols-outlined">calendar_month</span>
                </div>
                <span class="o_ad_quick_label">Calendar</span>
            </button>

        </div>

        <!-- ── Content 2-col Grid ────────────────────────────────── -->
        <div class="o_di_content_grid o_ad_content_grid">
            <!-- Mini Calendar -->
            <div class="o_ad_card">
                <div class="o_ad_card_header">
                    <div>
                        <div class="o_ad_card_title">
                            <span class="material-symbols-outlined" style="font-size:18px;vertical-align:middle;color:#1a73e8">calendar_month</span>
                            Calendar
                        </div>
                    </div>
                    <button class="o_ad_view_btn" t-on-click="openCalendar">Full View</button>
                </div>
                <div class="o_di_card_body" style="max-height:none;overflow:visible">
                    <MiniCalendar
                        sessionDates="calendarSessionDates"
                        onNavigateCalendar.bind="openCalendar"/>
                </div>
            </div>
            <!-- Instructor Performance -->
            <div class="o_ad_card">
                <div class="o_ad_watermark">STAFF</div>
                <div class="o_ad_card_header">
                    <div>
                        <div class="o_ad_card_title">Instructor Performance</div>
                        <div class="o_ad_card_subtitle">last 30 days</div>
                    </div>
                    <button class="o_ad_view_btn" t-on-click="openInstructorKpis">View All</button>
                </div>
                <div class="o_di_card_body">
                    <t t-if="state.instructors.length === 0">
                        <div class="o_ad_empty">
                            <span class="material-symbols-outlined">analytics</span>
                            <p>No instructor profiles found</p>
                        </div>
                    </t>
                    <t t-else="">
                        <table class="o_di_table">
                            <thead>
                                <tr>
                                    <th>Instructor</th>
                                    <th class="text-center">Today</th>
                                    <th class="text-center">Students</th>
                                    <th style="min-width:120px">Fill Rate</th>
                                    <th style="min-width:120px">Attendance</th>
                                    <th/>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="state.instructors" t-as="inst" t-key="inst.id">
                                    <tr>
                                        <td class="fw-semibold"><t t-out="inst.name"/></td>
                                        <td class="text-center">
                                            <span t-attf-class="o_di_badge {{ inst.sessions_today > 0 ? 'o_di_badge_success' : 'o_di_badge_secondary' }}">
                                                <t t-out="inst.sessions_today"/>
                                            </span>
                                        </td>
                                        <td class="text-center fw-semibold"><t t-out="inst.students_count"/></td>
                                        <td>
                                            <div class="o_ad_bar_wrap">
                                                <span t-attf-class="o_ad_bar_label {{ rateClass(inst.fill_rate) }}">
                                                    <t t-out="pct(inst.fill_rate)"/>
                                                </span>
                                                <div class="o_ad_bar_bg">
                                                    <div t-attf-class="o_ad_bar_fill {{ rateClass(inst.fill_rate) }}"
                                                         t-att-style="barFill(inst.fill_rate)"/>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="o_ad_bar_wrap">
                                                <span t-attf-class="o_ad_bar_label {{ rateClass(inst.attendance_rate) }}">
                                                    <t t-out="pct(inst.attendance_rate)"/>
                                                </span>
                                                <div class="o_ad_bar_bg">
                                                    <div t-attf-class="o_ad_bar_fill {{ rateClass(inst.attendance_rate) }}"
                                                         t-att-style="barFill(inst.attendance_rate)"/>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <button class="o_ad_view_btn"
                                                    t-on-click="() => this.openInstructorRecord(inst.id)">
                                                View
                                            </button>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                </div>
            </div>

            <!-- Dropped Enrollments -->
            <div class="o_ad_card">
                <div class="o_ad_watermark">EXIT</div>
                <div class="o_ad_card_header">
                    <div>
                        <div class="o_ad_card_title">Dropped Enrollments</div>
                        <div class="o_ad_card_subtitle">last 60 days</div>
                    </div>
                    <t t-if="state.droppedStudents.length > 10">
                        <button class="o_ad_view_btn" t-on-click="toggleDropped">
                            <t t-out="state.droppedExpanded ? 'Show Less' : 'Show All (' + state.droppedStudents.length + ')'"/>
                        </button>
                    </t>
                </div>
                <div class="o_di_card_body">
                    <t t-if="state.droppedStudents.length === 0">
                        <div class="o_ad_empty">
                            <span class="material-symbols-outlined">person_off</span>
                            <p>No dropped enrollments in the last 60 days</p>
                        </div>
                    </t>
                    <t t-else="">
                        <table class="o_di_table">
                            <thead>
                                <tr>
                                    <th>Student</th>
                                    <th>Status</th>
                                    <th>Class</th>
                                    <th>Instructor</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="visibleDropped" t-as="d" t-key="d.member_id + '_' + d_index">
                                    <tr>
                                        <td class="fw-semibold"><t t-out="d.member_name"/></td>
                                        <td>
                                            <span t-attf-class="o_di_badge {{ membershipBadgeClass(d.membership_state) }}">
                                                <t t-out="membershipLabel(d.membership_state)"/>
                                            </span>
                                        </td>
                                        <td><t t-out="d.class_name"/></td>
                                        <td style="color:#5f6368"><t t-out="d.instructor_name"/></td>
                                        <td style="color:#5f6368" class="text-nowrap"><t t-out="fmtDate(d.session_date)"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                </div>
            </div>

            <!-- Recent Students -->
            <div class="o_ad_card">
                <div class="o_ad_card_header">
                    <div>
                        <div class="o_ad_card_title">Recently Enrolled Students</div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <t t-if="state.recentStudents.length > 0">
                            <button class="o_di_carousel_nav"
                                    t-on-click="prevStudentPage"
                                    t-att-disabled="state.studentPage === 0">
                                <i class="fa fa-chevron-left"/>
                            </button>
                            <span class="o_di_carousel_pager">
                                <t t-out="state.studentPage + 1"/>/<t t-out="totalStudentPages"/>
                            </span>
                            <button class="o_di_carousel_nav"
                                    t-on-click="nextStudentPage"
                                    t-att-disabled="state.studentPage >= totalStudentPages - 1">
                                <i class="fa fa-chevron-right"/>
                            </button>
                        </t>
                        <button class="o_ad_view_btn" t-on-click="openAllStudents">View All</button>
                    </div>
                </div>
                <div class="o_di_card_body">
                    <t t-if="state.recentStudents.length === 0">
                        <div class="o_ad_empty">
                            <span class="material-symbols-outlined">group</span>
                            <p>No students found</p>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="o_di_student_grid">
                            <t t-foreach="visibleStudents" t-as="s" t-key="s.id">
                                <button class="o_di_student_card"
                                        t-on-click="() => this.openStudentProfile(s.id)">
                                    <div class="o_di_student_avatar">
                                        <img t-att-src="'/web/image/res.partner/' + s.partner_id + '/image_128'"
                                             alt=""
                                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"/>
                                        <div class="o_di_student_avatar_fallback">
                                            <i class="fa fa-user"/>
                                        </div>
                                    </div>
                                    <span class="o_di_student_name" t-out="s.name"/>
                                </button>
                            </t>
                        </div>
                    </t>
                </div>
            </div>

            <!-- Recent Sessions — full width -->
            <div class="o_ad_card o_di_card_full o_ad_card_footer">
                <div class="o_ad_card_header">
                    <div>
                        <div class="o_ad_card_title">Recent Sessions</div>
                        <div class="o_ad_card_subtitle">last 30 days</div>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="o_ad_view_btn" t-on-click="openCalendar">
                            <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle">calendar_month</span>Calendar
                        </button>
                        <t t-if="state.recentSessions.length > 15">
                            <button class="o_ad_view_btn" t-on-click="toggleSessions">
                                <t t-out="state.sessionsExpanded ? 'Show Less' : 'Show All (' + state.recentSessions.length + ')'"/>
                            </button>
                        </t>
                    </div>
                </div>
                <div class="o_di_card_body">
                    <t t-if="state.recentSessions.length === 0">
                        <div class="o_ad_empty">
                            <span class="material-symbols-outlined">event</span>
                            <p>No recent sessions</p>
                        </div>
                    </t>
                    <t t-else="">
                        <table class="o_di_table">
                            <thead>
                                <tr>
                                    <th>Class</th>
                                    <th>Instructor</th>
                                    <th>Date</th>
                                    <th class="text-center">Cap.</th>
                                    <th class="text-center">Enrolled</th>
                                    <th class="text-center">Present</th>
                                    <th class="text-center">Absent</th>
                                    <th class="o_di_table_fill_rate">Fill Rate</th>
                                    <th class="o_di_table_attendance">Attendance</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="visibleSessions" t-as="s" t-key="s.id">
                                    <tr>
                                        <td class="fw-semibold"><t t-out="s.class_name"/></td>
                                        <td style="color:#5f6368"><t t-out="s.instructor_name"/></td>
                                        <td style="color:#5f6368" class="text-nowrap"><t t-out="fmtDate(s.date)"/></td>
                                        <td class="text-center"><t t-out="s.capacity"/></td>
                                        <td class="text-center"><t t-out="s.enrolled"/></td>
                                        <td class="text-center fw-semibold" style="color:#1e8e3e"><t t-out="s.present"/></td>
                                        <td class="text-center fw-semibold" style="color:#d93025"><t t-out="s.absent"/></td>
                                        <td class="o_di_table_fill_rate">
                                            <div class="o_ad_bar_wrap">
                                                <span t-attf-class="o_ad_bar_label {{ rateClass(s.fill_rate) }}">
                                                    <t t-out="pct(s.fill_rate)"/>
                                                </span>
                                                <div class="o_ad_bar_bg">
                                                    <div t-attf-class="o_ad_bar_fill {{ rateClass(s.fill_rate) }}"
                                                         t-att-style="barFill(s.fill_rate)"/>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="o_di_table_attendance">
                                            <t t-if="s.attendance_rate !== null">
                                                <div class="o_ad_bar_wrap">
                                                    <span t-attf-class="o_ad_bar_label {{ rateClass(s.attendance_rate) }}">
                                                        <t t-out="pct(s.attendance_rate)"/>
                                                    </span>
                                                    <div class="o_ad_bar_bg">
                                                        <div t-attf-class="o_ad_bar_fill {{ rateClass(s.attendance_rate) }}"
                                                             t-att-style="barFill(s.attendance_rate)"/>
                                                    </div>
                                                </div>
                                            </t>
                                            <t t-else=""><span style="color:#9aa0a6">—</span></t>
                                        </td>
                                        <td>
                                            <span t-attf-class="o_di_badge {{ stateBadgeClass(s.state) }}">
                                                <t t-out="stateLabel(s.state)"/>
                                            </span>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                </div>
            </div>

        </div><!-- /.o_di_content_grid -->
    </t>

    <!-- ── AI Voice Assistant (floating) ──────────────── -->
    <DojoVoiceAssistant/>

</div>
</t>

</templates>
