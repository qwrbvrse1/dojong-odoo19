<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_check_belt_eligibility" model="ir.cron">
        <field name="name">Dojang: Check Belt Test Eligibility</field>
        <field name="model_id" ref="dojo_core.model_dojo_member"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_belt_eligibility()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_check_student_inactivity" model="ir.cron">
        <field name="name">Dojang: check student inactivity (30 days)</field>
        <field name="model_id" ref="dojo_core.model_dojo_member"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_student_inactivity()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_check_missed_attendance" model="ir.cron">
        <field name="name">Dojang: remind instructor of unrecorded attendance</field>
        <field name="model_id" ref="dojo_core.model_dojo_class_session"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_missed_attendance()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active">True</field>
    </record>
</odoo>
