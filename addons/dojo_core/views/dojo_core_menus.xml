<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════
         DOJANG MANAGEMENT — Root App Menu (dojo_core)
         Only menus for core models are defined here.
         Submodules add their own menus via their own XML files.
    ════════════════════════════════════════════════════════════════ -->

    <!-- ── Root ───────────────────────────────────────────────── -->

    <menuitem
