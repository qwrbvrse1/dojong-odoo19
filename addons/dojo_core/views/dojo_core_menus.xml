    <menuitem
        id="menu_dojo_core_dashboard"
        name="Command Center"
        parent="menu_dojo_core_root"
        action="dojo_core.action_admin_dashboard_client"
        sequence="5"
        groups="dojo_core.group_dojo_admin"/>

    <!-- ── Classes ────────────────────────────────────────────── -->

    <menuitem
        id="menu_dojo_core_classes"
        name="Schedules"
        parent="menu_dojo_core_root"
