<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════
         DOJO MANAGEMENT — Unified Root App Menu
         Actions that belong to modules with complex/optional
         dependencies (dojo_instructor_dashboard → project, account)
         are defined here directly or omitted to keep installation safe.
    ════════════════════════════════════════════════════════════════ -->

    <!-- Local Book Trial action — no active_id context (safe from top-level menu) -->
    <record id="action_dojo_core_book_trial" model="ir.actions.act_window">
        <field name="name">Book a Trial</field>
        <field name="res_model">dojo.book.trial.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Local action for CRM Leads (crm module may not expose crm_lead_all_leads externally) -->
    <record id="action_dojo_core_crm_leads" model="ir.actions.act_window">
        <field name="name">Leads &amp; Trials</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <!-- Local action for Instructor Profiles (model lives in dojo_base) -->
    <record id="action_dojo_core_instructor_profiles" model="ir.actions.act_window">
        <field name="name">Instructor Profiles</field>
        <field name="res_model">dojo.instructor.profile</field>
        <field name="view_mode">list,form</field>
    </record>

