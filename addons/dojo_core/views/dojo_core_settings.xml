<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_dojo_core" model="ir.ui.view">
            <field name="name">res.config.settings.view.dojo.core</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">

                    <div class="app_settings_block"
                         data-string="Dojo Integrations"
                         string="Dojo Integrations"
                         data-key="dojo_core">

                        <h2>Dojo Integration Status</h2>

                        <!-- External Services -->
                        <div class="row mt16 o_settings_container">

                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <span class="fa fa-credit-card fa-2x text-primary"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <span class="o_setting_name">Stripe Payments</span>
                                    <div class="text-muted">
                                        Handles member subscription billing and instructor virtual cards.
                                        Go to <strong>Invoicing → Configuration → Payment Providers → Stripe</strong>
                                        and enter your Publishable key and Secret key, then set to Published.
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <span class="fa fa-comment fa-2x text-success"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <span class="o_setting_name">Twilio SMS</span>
                                    <div class="text-muted">
                                        Sends check-in notifications, class reminders, and campaign messages.
                                        Go to <strong>Settings → Contacts → Send SMS → Switch to Twilio</strong>
                                        and configure your Account SID and Auth Token.
                                    </div>
                                </div>
                            </div>

                        </div>

                        <div class="row mt16 o_settings_container">

                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <span class="fa fa-microphone fa-2x text-warning"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <span class="o_setting_name">ElevenLabs Voice AI</span>
                                    <div class="text-muted">
                                        Powers the voice assistant at the kiosk.
                                        Go to <strong>Settings → ElevenLabs Voice Connector</strong>
                                        and enter your ElevenLabs API key and AI provider key, then test the connection.
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <span class="fa fa-facebook-square fa-2x text-primary"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <span class="o_setting_name">Facebook / Instagram</span>
                                    <div class="text-muted">
                                        Direct posting to Facebook Pages and Instagram Business.
                                        Go to <strong>Social Media → Accounts</strong>
                                        and connect your Facebook page via OAuth.
                                    </div>
                                </div>
                            </div>

                        </div>

                        <!-- QA Checklist -->
                        <h2 class="mt32">QA Testing Checklist</h2>

                        <div class="row mt16 o_settings_container">

                            <!-- LEFT COLUMN -->
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">

                                    <span class="o_setting_name">Onboarding &amp; CRM</span>
                                    <ul class="text-muted mt4">
                                        <li>Onboarding wizard opens → completes all 10 steps without error</li>
                                        <li>Guardian + household created (Phase 1)</li>
                                        <li>Student record + dojo.member created (Phase 2)</li>
                                        <li>Portal invite sent → guardian logs in → sees invoices + household</li>
                                        <li>Student portal shows schedule, belt rank, attendance</li>
                                        <li>"Add Another Student" reuses existing household</li>
                                        <li>Public trial booking (/dojo/book-trial) creates a CRM lead</li>
                                        <li>Staff books trial via wizard → session linked to lead</li>
                                        <li>Lead advances stage when trial member checks in</li>
                                        <li>Confirmation email fires automatically on stage change</li>
                                        <li>Convert Lead wizard → member + household + subscription created</li>
                                        <li>Walk-in onboarding → Won CRM lead auto-created</li>
                                    </ul>

                                    <span class="o_setting_name mt16 d-block">Classes &amp; Attendance</span>
                                    <ul class="text-muted mt4">
                                        <li>Program → Course → Subscription Plan structure created</li>
                                        <li>Recurring course generates sessions (60-day window)</li>
                                        <li>Student enrolled → session appears on kiosk today</li>
                                        <li>Student check-in via kiosk → attendance recorded</li>
                                        <li>Check-out flow works after check-in</li>
                                        <li>Check-in triggers guardian SMS/email notification</li>
                                        <li>Auto-enroll creates future session enrollments on schedule</li>
                                    </ul>

                                    <span class="o_setting_name mt16 d-block">Kiosk</span>
                                    <ul class="text-muted mt4">
                                        <li>Kiosk URL loads (student view — idle screen)</li>
                                        <li>Student name search returns member tiles</li>
                                        <li>Student taps tile → enrolled sessions for today appear</li>
                                        <li>Session tap → check-in recorded → success screen</li>
                                        <li>Instructor mode PIN (123456) unlocks instructor view</li>
                                        <li>Instructor can view roster per session</li>
                                        <li>Hold student icon → profile modal opens</li>
                                        <li>Profile modal: attendance, belt promo, contact guardian, add/remove sessions</li>
                                        <li>Checkmark on student tile marks attendance directly</li>
                                        <li>AI voice assistant (bottom-right) processes a command</li>
                                    </ul>

                                    <span class="o_setting_name mt16 d-block">Marketing Cards &amp; Campaigns</span>
                                    <ul class="text-muted mt4">
                                        <li>Book Trial card QR → /dojo/book-trial resolves</li>
                                        <li>Donate / Merch / Tournament cards → custom URL QR works</li>
                                        <li>Member Badge QR → kiosk check-in works</li>
                                        <li>Cards show on kiosk and/or portal as configured</li>
                                        <li>Campaign created → sends email/SMS to correct audience filter</li>
                                        <li>Recurring campaign advances next send date after dispatch</li>
                                    </ul>

                                </div>
                            </div>

                            <!-- RIGHT COLUMN -->
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">

                                    <span class="o_setting_name">Members &amp; Households</span>
                                    <ul class="text-muted mt4">
                                        <li>Household record shows Primary Guardian</li>
                                        <li>Family members flagged: Is Student, Is Guardian, Is Minor</li>
                                        <li>Payment Methods stat button visible on household</li>
                                        <li>Stripe card saved against primary guardian</li>
                                        <li>Off-session charge fires on billing date</li>
                                        <li>Portal access: guardian sees only their household</li>
                                    </ul>

                                    <span class="o_setting_name mt16 d-block">Subscriptions &amp; Billing</span>
                                    <ul class="text-muted mt4">
                                        <li>Subscription created → first invoice generated same day</li>
                                        <li>Stripe charge succeeds → invoice marked paid</li>
                                        <li>Failed payment → failure counter increments + dunning email (1st)</li>
                                        <li>2nd failure → member status set to Paused</li>
                                        <li>3rd failure → subscription Expired → re-engagement CRM lead</li>
                                        <li>Payment received → failure counter reset, member reactivated</li>
                                        <li>Subscription end date passes → status auto-set to Expired</li>
                                        <li>30-day and 7-day renewal reminder emails sent</li>
                                    </ul>

                                    <span class="o_setting_name mt16 d-block">Belt Progression &amp; Instructor Setup</span>
                                    <ul class="text-muted mt4">
                                        <li>Belt test created → members registered for test</li>
                                        <li>Promotion confirmed → rank record created on member</li>
                                        <li>Promotion logged on CRM lead chatter</li>
                                        <li>Instructor user created with Dojo Instructor role</li>
                                        <li>Instructor Profile created → Employee record auto-created</li>
                                        <li>Stripe virtual card issued to instructor (if Stripe configured)</li>
                                    </ul>

                                    <span class="o_setting_name mt16 d-block">Integrations &amp; AI</span>
                                    <ul class="text-muted mt4">
                                        <li>Stripe: Publishable + Secret key set, status = Published</li>
                                        <li>Twilio: configured in Settings → Contacts → Send SMS</li>
                                        <li>ElevenLabs: credentials entered, connection test passes</li>
                                        <li>Facebook OAuth: page connected, test connection passes</li>
                                        <li>Social post created → Post Now publishes successfully</li>
                                        <li>Social post scheduled → cron picks up and publishes</li>
                                        <li>AI text: "Check in [member] for [session]" → executes</li>
                                        <li>AI voice at kiosk: "Add [name] to next BJJ session" → confirm popup</li>
                                        <li>AI CRM: "What's the pipeline looking like?" → responds</li>
                                        <li>Undo: action → undo within 60 minutes works</li>
                                        <li>Action log visible in Settings → AI Assistant</li>
                                    </ul>

                                </div>
                            </div>

                        </div>

                    </div>

                </xpath>
            </field>
        </record>
    </data>
</odoo>
