<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dojo_member_list" model="ir.ui.view">
        <field name="name">dojo.member.list</field>
        <field name="model">dojo.member</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="member_number" optional="show"/>
                <field name="email"/>
                <field name="gender" optional="show"/>
                <field name="total_sessions" optional="show" string="Sessions"/>
                <field name="attendance_rate" optional="show" string="Att. Rate %"
                       widget="progressbar"/>
                <field name="is_student" optional="hide"/>
                <field name="is_guardian" optional="hide"/>
                <field name="is_minor" optional="hide"/>
                <field name="membership_state"/>
                <field name="parent_id" string="Household"/>
                <field name="has_portal_login"/>
            </list>
        </field>
    </record>

    <record id="view_dojo_member_form" model="ir.ui.view">
        <field name="name">dojo.member.form</field>
        <field name="model">dojo.member</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_create_household"
                        string="Create Household"
                        type="object"
                        class="btn-secondary"
                        invisible="parent_id != False"
                        groups="dojo_core.group_dojo_admin"/>
                    <button name="action_grant_portal_access"
                        string="Grant Portal Access"
                        type="object"
                        class="btn-secondary"
                        invisible="has_portal_login == True"
                        groups="dojo_core.group_dojo_admin"/>
                    <button name="action_set_trial" string="Set Trial"
                        type="object" class="btn-secondary"
                        invisible="membership_state not in ['lead']"/>
                    <button name="action_set_active" string="Activate"
                        type="object" class="btn-primary"
                        invisible="membership_state not in ['lead', 'trial', 'paused']"/>
                    <button name="action_set_paused" string="Pause"
                        type="object" class="btn-secondary"
                        invisible="membership_state not in ['active']"/>
                    <button name="action_set_cancelled" string="Cancel Membership"
                        type="object" class="btn-secondary"
                        invisible="membership_state in ['cancelled']"/>
                    <field name="membership_state" widget="statusbar"
                        statusbar_visible="lead,trial,active,paused,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Cancelled"
                        bg_color="text-bg-danger"
                        invisible="membership_state != 'cancelled'"/>
                    <widget name="web_ribbon" title="Paused"
                        bg_color="text-bg-warning"
                        invisible="membership_state != 'paused'"/>
                    <div class="oe_title d-flex align-items-center gap-3">
                        <field name="image_1920" widget="image" class="oe_avatar"
                            options="{'preview_image': 'image_128'}"/>
                        <div>
                            <label for="name"/>
                            <h1><field name="name" placeholder="Full Name"/></h1>
                        </div>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="date_of_birth"/>
                            <field name="gender"/>
                        </group>
                        <group>
                            <field name="member_number" readonly="1"/>
                            <field name="total_sessions" readonly="1"/>
                            <field name="attendance_rate" readonly="1"
                                   widget="progressbar"/>
                        </group>
                        <group>
                            <field name="parent_id" string="Household"
                                   domain="[('is_household', '=', True)]"/>
                            <field name="is_student"/>
                            <field name="is_guardian"/>
                            <field name="is_minor"/>
                            <field name="has_portal_login" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group>
                        <field name="emergency_note"/>
                    </group>
                    <notebook>
                        <page string="Medical Info">
                            <group>
                                <group>
                                    <field name="blood_type"/>
                                    <field name="allergies"/>
                                </group>
                                <group>
                                    <field name="medical_notes"/>
                                </group>
                            </group>
                        </page>
                        <page string="Emergency Contacts">
                            <field name="emergency_contact_ids" context="{'default_member_id': id}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="relationship"/>
                                    <field name="phone"/>
                                    <field name="email"/>
                                    <field name="is_primary"/>
                                </list>
                            </field>
                        </page>
                        <page string="Belt Progression">
                            <group>
                                <field name="current_rank_id" readonly="1"/>
                                <field name="current_stripe_count" readonly="1"
                                       help="Stripes on the current belt. Edit via the rank history entries below."/>
                                <field name="attendance_since_last_rank" readonly="1"/>
                                <field name="test_invite_pending" readonly="1"/>
                            </group>
                            <div invisible="not test_invite_pending" class="alert alert-info" role="alert">
                                A belt-test invitation has been created for this member.
                                Once the test is recorded (pass / fail / withdrew), this flag will reset automatically.
                                <button name="action_reset_test_invite" type="object" string="Reset Manually"
                                        class="btn btn-sm btn-secondary ms-2"
                                        groups="dojo_core.group_dojo_admin"/>
                            </div>
                            <field name="rank_history_ids">
                                <list>
                                    <field name="rank_id"/>
                                    <field name="stripe_count"/>
                                    <field name="program_id"/>
                                    <field name="date_awarded"/>
                                    <field name="awarded_by"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                        <page string="Auto-Enroll">
                            <field name="auto_enroll_pref_ids"
                                context="{'default_member_id': id}">
                                <list editable="bottom">
                                    <field name="template_id"
                                        options="{'no_quick_create': True, 'no_create_edit': True}"/>
                                    <field name="active" widget="boolean_toggle" string="Active"/>
                                    <field name="mode"/>
                                    <field name="date_from" string="From"/>
                                    <field name="date_to" string="To"/>
                                    <field name="pref_mon"/>
                                    <field name="pref_tue"/>
                                    <field name="pref_wed"/>
                                    <field name="pref_thu"/>
                                    <field name="pref_fri"/>
                                    <field name="pref_sat"/>
                                    <field name="pref_sun"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_dojo_members" model="ir.actions.act_window">
        <field name="name">Members</field>
        <field name="res_model">dojo.member</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_dojo_households" model="ir.actions.act_window">
        <field name="name">Households</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_household', '=', True)]</field>
        <field name="context">{'default_is_household': True, 'default_is_company': True}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('dojo_core.view_dojo_household_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('dojo_core.view_dojo_household_form')}),
        ]"/>
    </record>

    <record id="action_dojo_emergency_contacts" model="ir.actions.act_window">
        <field name="name">Emergency Contacts</field>
        <field name="res_model">dojo.emergency.contact</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
