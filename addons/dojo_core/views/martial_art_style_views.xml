<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Martial Art Style List View -->
    <record id="view_dojo_martial_art_style_list" model="ir.ui.view">
        <field name="name">dojo.martial.art.style.list</field>
        <field name="model">dojo.martial.art.style</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="belt_count"/>
                <field name="student_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Martial Art Style Form View -->
    <record id="view_dojo_martial_art_style_form" model="ir.ui.view">
        <field name="name">dojo.martial.art.style.form</field>
        <field name="model">dojo.martial.art.style</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Style Name (e.g., Karate, Taekwondo)"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="belt_count"/>
                            <field name="student_count"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Description of this martial arts style..."/>
                    </group>
                    <notebook>
                        <page string="Belt Ranking System" name="belt_ranks">
                            <field name="belt_rank_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="icon"/>
                                    <field name="name"/>
                                    <field name="color" widget="color"/>
                                    <field name="is_dan"/>
                                    <field name="active" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Martial Art Style Kanban View -->
    <record id="view_dojo_martial_art_style_kanban" model="ir.ui.view">
        <field name="name">dojo.martial.art.style.kanban</field>
        <field name="model">dojo.martial.art.style</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="id"/>
                <field name="name"/>
                <field name="code"/>
                <field name="belt_count"/>
                <field name="student_count"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click" style="padding: 15px;">
                            <div>
                                <strong style="font-size: 18px;">🥋 <field name="name"/></strong>
                            </div>
                            <div style="margin-top: 10px; color: #6b7280;">
                                Code: <field name="code"/>
                            </div>
                            <div style="margin-top: 10px;">
                                <span class="badge" style="background-color: #dbeafe; color: #1e40af;">
                                    <field name="belt_count"/> Belts
                                </span>
                                <span class="badge" style="background-color: #dcfce7; color: #166534; margin-left: 5px;">
                                    <field name="student_count"/> Students
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Martial Art Style Action -->
    <record id="action_dojo_martial_art_styles" model="ir.actions.act_window">
        <field name="name">Martial Art Styles</field>
        <field name="res_model">dojo.martial.art.style</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first martial arts style!
            </p>
            <p>
                Define custom belt ranking systems for different martial arts styles.
                Each style can have its own unique belt progression.
            </p>
        </field>
    </record>
</odoo>
