<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dojo_emergency_contact_list" model="ir.ui.view">
        <field name="name">dojo.emergency.contact.list</field>
        <field name="model">dojo.emergency.contact</field>
        <field name="arch" type="xml">
            <list>
                <field name="member_id"/>
                <field name="name"/>
                <field name="relationship"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="is_primary"/>
            </list>
        </field>
    </record>

    <record id="view_dojo_emergency_contact_form" model="ir.ui.view">
        <field name="name">dojo.emergency.contact.form</field>
        <field name="model">dojo.emergency.contact</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="member_id"/>
                        <field name="name"/>
                        <field name="relationship"/>
                        <field name="phone"/>
                        <field name="email"/>
                        <field name="is_primary"/>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
