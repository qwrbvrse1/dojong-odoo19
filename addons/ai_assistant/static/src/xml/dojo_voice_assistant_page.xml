<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ai_assistant.VoiceAssistantPage" owl="1">
        <div class="o_dojo_voice_assistant_page p-4">

            <!-- ── Header + Mode Tabs ─────────────────────────────────── -->
            <div class="text-center mb-3">
                <h2>Care Operations Copilot</h2>
                <p class="text-muted">Typed assistance for resident, staff, and follow-up workflows</p>
            </div>

            <div class="d-flex justify-content-center align-items-center gap-3 mb-4">
                <span class="btn btn-sm btn-primary disabled">
                    <i class="fa fa-keyboard-o me-1"/> Typed Mode
                </span>
                <button class="btn btn-sm btn-outline-secondary"
                        t-on-click="clearContext"
                        title="Clear conversation context (copilot starts fresh on the next request)">
                    <i class="fa fa-eraser me-1"/> Clear Context
                </button>
            </div>

            <!-- ── Voice Input ────────────────────────────────────────── -->
            <t t-if="state.mode === 'voice'">
                <div class="text-center mb-4">
                    <button t-attf-class="btn btn-lg rounded-circle #{state.isRecording ? 'btn-danger' : 'btn-primary'}"
                            t-on-click="toggleRecording"
                            t-att-disabled="state.isProcessing"
                            style="width: 100px; height: 100px;">
                        <i t-attf-class="fa fa-#{state.isRecording ? 'stop' : 'microphone'} fa-3x"/>
                    </button>
                </div>
                <div class="text-center mb-4">
                    <p class="text-muted" style="font-size: 16px;">
                        <t t-if="state.isRecording">Recording… Click to stop</t>
                        <t t-elif="state.isProcessing">Processing your request…</t>
                        <t t-else="">Click to start recording</t>
                    </p>
                </div>
            </t>

            <!-- ── Text Input ─────────────────────────────────────────── -->
            <t t-if="state.mode === 'text'">
                <div class="d-flex gap-2 mb-4 mx-auto" style="max-width: 560px;">
                    <textarea class="form-control" rows="2"
                              placeholder="Type a care operations request… (Enter to send)"
                              t-model="state.textInput"
                              t-on-keydown="onTextKeydown"
                              t-att-disabled="state.isProcessing"/>
                    <button class="btn btn-primary align-self-end"
                            t-on-click="submitText"
                            t-att-disabled="state.isProcessing or !state.textInput.trim()"
                            style="min-width: 48px;">
                        <t t-if="state.isProcessing"><i class="fa fa-spinner fa-spin"/></t>
                        <t t-else=""><i class="fa fa-paper-plane"/></t>
                    </button>
                </div>
            </t>

            <!-- ── Error ──────────────────────────────────────────────── -->
            <div t-if="state.error" class="alert alert-danger mt-3">
                <i class="fa fa-exclamation-triangle me-2"/>
                <t t-out="state.error"/>
                <button type="button" class="btn-close float-end" t-on-click="() => { this.state.error = null; }"/>
            </div>

            <!-- ── Pipeline step progress (visible while processing) ──── -->
            <div t-if="state.isProcessing" class="mt-4 mx-auto" style="max-width: 560px;">
                <t t-if="state.liveSteps.length">
                    <div class="dojo-vap-steps card shadow-sm border-primary p-3">
                        <t t-foreach="state.liveSteps" t-as="step" t-key="step_index">
                            <div t-attf-class="dojo-vap-step {{ stepClass(step_index) }}">
                                <span class="dojo-vap-step__icon">
                                    <i t-if="stepClass(step_index) === 'o-done'" class="fa fa-check-circle"/>
                                    <i t-elif="stepClass(step_index) === 'o-active'" class="fa fa-circle-o-notch fa-spin"/>
                                    <i t-else="" class="fa fa-circle-o"/>
                                </span>
                                <span class="dojo-vap-step__label">
                                    <span class="dojo-vap-step__name"><t t-esc="step.name or step"/></span>
                                    <span t-if="step.detail" class="dojo-vap-step__detail"><t t-esc="step.detail"/></span>
                                </span>
                            </div>
                        </t>
                    </div>
                </t>
                <t t-else="">
                    <div class="text-center py-3">
                        <i class="fa fa-spinner fa-spin fa-2x text-primary"/>
                    </div>
                </t>
            </div>

            <!-- ── Current result card ────────────────────────────────── -->
            <div t-if="state.transcribedText or state.aiResponse or state.awaitingConfirmation" class="mt-4" id="current-conversation-result">
                <div t-attf-class="card shadow-sm #{state.awaitingConfirmation ? 'border-warning' : 'border-primary'}">
                    <div class="card-body">

                        <!-- What user said -->
                        <div t-if="state.transcribedText" class="mb-3">
                            <h6 class="text-primary mb-2">
                                <i class="fa fa-keyboard-o me-2"/>Request:
                            </h6>
                            <p class="mb-0 p-2 bg-light rounded" style="white-space: pre-wrap; word-wrap: break-word;"
                               t-out="state.transcribedText"/>
                        </div>

                        <!-- Confirmation prompt -->
                        <div t-if="state.awaitingConfirmation and !state.isProcessing" class="mt-3">
                            <h6 class="text-warning mb-2">
                                <i class="fa fa-question-circle me-2"/>Confirm Follow-Up:
                            </h6>
                            <div class="p-3 bg-warning bg-opacity-10 rounded border border-warning border-opacity-25"
                                 style="white-space: pre-wrap; word-wrap: break-word;"
                                 t-out="state.confirmationPrompt"/>
                            <div class="mt-3 d-flex gap-2 justify-content-center">
                                <button class="btn btn-success" t-on-click="confirmAction" t-att-disabled="state.isProcessing">
                                    <i class="fa fa-check me-1"/> Confirm
                                </button>
                                <button class="btn btn-outline-secondary" t-on-click="cancelAction" t-att-disabled="state.isProcessing">
                                    <i class="fa fa-times me-1"/> Cancel
                                </button>
                            </div>
                        </div>

                        <!-- AI Response -->
                        <div t-if="state.aiResponse and !state.awaitingConfirmation and !state.isProcessing" class="mt-3">
                            <h6 class="text-success mb-2">
                                <i class="fa fa-robot me-2"/>Copilot Response:
                            </h6>
                            <div class="p-3 bg-success bg-opacity-10 rounded border border-success border-opacity-25"
                                 style="white-space: pre-wrap; word-wrap: break-word;"
                                 t-out="state.aiResponse"/>
                            <div class="mt-3 d-flex gap-2 justify-content-center">
                                <button t-if="state.undoAvailable" class="btn btn-sm btn-outline-primary" t-on-click="requestUndo">
                                    <i class="fa fa-undo me-1"/> Undo
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" t-on-click="clearConversation">
                                    <i class="fa fa-times me-1"/> Clear
                                </button>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- ── Recent Actions (from ai_assistant action log) ────── -->
            <div class="mt-5 pt-4 border-top">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">
                        <i class="fa fa-history me-2"/>Recent Actions
                    </h5>
                        <button class="btn btn-sm btn-outline-secondary" t-on-click="loadHistory">
                            <i class="fa fa-refresh"/>
                        </button>
                    </div>

                <div t-if="state.history.length === 0" class="text-muted text-center py-3">
                    <p class="mb-0">No recent copilot activity. Start with a typed request.</p>
                </div>

                <div t-else="" class="list-group">
                    <div t-foreach="state.history" t-as="rec" t-key="rec.id"
                         t-attf-class="list-group-item #{rec.undone ? 'opacity-50' : ''}">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <h6 class="mb-1 text-primary" t-out="rec.input_text or '(copilot request)'"/>
                                <div class="d-flex gap-2 align-items-center">
                                    <span t-if="rec._intent" class="text-muted small" t-out="rec._intent"/>
                                    <span t-att-class="rec._badge.cls" t-out="rec._badge.text"/>
                                </div>
                            </div>
                            <small class="text-muted ms-2 flex-shrink-0" t-out="rec._time"/>
                        </div>
                    </div>
                </div>

                <!-- Pagination -->
                <div t-if="state.historyTotal > state.historyPerPage" class="d-flex justify-content-between align-items-center mt-3">
                    <button class="btn btn-sm btn-outline-secondary"
                            t-att-disabled="!hasPrevPage"
                            t-on-click="prevPage">
                        <i class="fa fa-chevron-left me-1"/> Previous
                    </button>
                    <span class="text-muted small">
                        Page <t t-out="state.historyPage + 1"/> of <t t-out="historyTotalPages"/>
                    </span>
                    <button class="btn btn-sm btn-outline-secondary"
                            t-att-disabled="!hasNextPage"
                            t-on-click="nextPage">
                        Next <i class="fa fa-chevron-right ms-1"/>
                    </button>
                </div>
            </div>

        </div>
    </t>
</templates>
