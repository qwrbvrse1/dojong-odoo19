<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<!-- ─── DiscussAiPanel component template ───────────────────────────────── -->
<t t-name="ai_assistant.DiscussAiPanel">
    <div class="o-discuss-ai-panel" t-att-class="{ 'o-open': state.open }">

        <!-- Toggle tab: always visible on the right edge of Discuss -->
        <button
            class="o-discuss-ai-toggle"
            t-on-click="toggle"
            t-att-title="state.open ? 'Close AI Assistant' : 'Open AI Assistant (Dojo AI)'"
        >
            <span class="o-discuss-ai-toggle-icon">🤖</span>
            <span t-if="!state.open" class="o-discuss-ai-toggle-label">AI</span>
        </button>

        <!-- Slide-in panel (visible when open) -->
        <div t-if="state.open" class="o-discuss-ai-inner">

            <!-- Header -->
            <div class="o-discuss-ai-header">
                <div class="o-discuss-ai-header-left">
                    <i class="fa fa-robot o-discuss-ai-header-icon"/>
                    <span class="o-discuss-ai-title">AI Assistant</span>
                </div>
                <div class="o-discuss-ai-header-right">
                    <button
                        t-if="state.messages.length > 0"
                        class="btn btn-sm o-discuss-ai-clear"
                        title="Clear conversation"
                        t-on-click="clearChat"
                    >
                        <i class="fa fa-trash-o"/>
                    </button>
                    <button class="btn btn-sm o-discuss-ai-close" title="Close" t-on-click="toggle">
                        <i class="fa fa-times"/>
                    </button>
                </div>
            </div>

            <!-- Message list -->
            <div class="o-discuss-ai-messages">

                <!-- Empty state hint -->
                <t t-if="state.messages.length === 0">
                    <div class="o-discuss-ai-empty">
                        <div class="o-discuss-ai-empty-icon">🤖</div>
                        <div class="o-discuss-ai-empty-title">Dojo AI Assistant</div>
                        <div class="o-discuss-ai-empty-sub">
                            Ask anything about your dojo members, classes, belts, or subscriptions.
                        </div>
                        <div class="o-discuss-ai-suggestions">
                            <div class="o-discuss-ai-suggestion-label">Try asking:</div>
                            <div class="o-discuss-ai-suggestion">"Show overdue invoices"</div>
                            <div class="o-discuss-ai-suggestion">"Check in Jordan Smith"</div>
                            <div class="o-discuss-ai-suggestion">"Show belt test readiness"</div>
                            <div class="o-discuss-ai-suggestion">"Revenue this month"</div>
                        </div>
                    </div>
                </t>

                <!-- Messages -->
                <t t-foreach="state.messages" t-as="msg" t-key="msg.id">

                    <!-- User message -->
                    <div t-if="msg.type === 'user'" class="o-discuss-ai-row o-user">
                        <div class="o-discuss-ai-bubble o-user-bubble">
                            <t t-esc="msg.text"/>
                        </div>
                    </div>

                    <!-- AI message -->
                    <div t-elif="msg.type === 'ai'" class="o-discuss-ai-row o-ai">
                        <div class="o-discuss-ai-avatar">🤖</div>
                        <div class="o-discuss-ai-body">
                            <!-- Main response text -->
                            <div class="o-discuss-ai-bubble o-ai-bubble">
                                <t t-esc="msg.text"/>
                            </div>

                            <!-- Confirm / Cancel (two-phase flow) -->
                            <div
                                t-if="msg.state === 'pending_confirmation'"
                                class="o-discuss-ai-confirm-row"
                            >
                                <button
                                    class="btn btn-sm btn-success o-discuss-ai-confirm-btn"
                                    t-on-click="() => confirmAction(msg, true)"
                                    t-att-disabled="state.loading"
                                >
                                    <i class="fa fa-check me-1"/>Confirm
                                </button>
                                <button
                                    class="btn btn-sm btn-light o-discuss-ai-cancel-btn"
                                    t-on-click="() => confirmAction(msg, false)"
                                    t-att-disabled="state.loading"
                                >
                                    Cancel
                                </button>
                            </div>

                            <!-- Confirmed / Rejected badge -->
                            <div
                                t-if="msg.state === 'executed' or msg.state === 'rejected'"
                                class="o-discuss-ai-status-badge"
                                t-att-class="msg.state === 'executed' ? 'o-done' : 'o-cancelled'"
                            >
                                <i t-att-class="msg.state === 'executed' ? 'fa fa-check-circle' : 'fa fa-times-circle'"/>
                                <t t-esc="msg.state === 'executed' ? 'Executed' : 'Cancelled'"/>
                            </div>

                            <!-- Agent log (collapsible) -->
                            <div
                                t-if="msg.agent_name or msg.intent_type"
                                class="o-discuss-ai-log"
                            >
                                <button
                                    class="o-discuss-ai-log-toggle"
                                    t-on-click="() => toggleLog(msg)"
                                >
                                    <i t-att-class="msg.logOpen ? 'fa fa-chevron-up' : 'fa fa-chevron-down'"/>
                                    <span class="o-discuss-ai-log-agent">
                                        <t t-esc="msg.agent_name or 'AI'"/>
                                    </span>
                                </button>
                                <div t-if="msg.logOpen" class="o-discuss-ai-log-body">
                                    <div t-if="msg.agent_name" class="o-log-row">
                                        <span class="o-log-key">Agent</span>
                                        <span class="o-log-val"><t t-esc="msg.agent_name"/></span>
                                    </div>
                                    <div t-if="msg.intent_type" class="o-log-row">
                                        <span class="o-log-key">Intent</span>
                                        <span class="o-log-val o-log-mono"><t t-esc="msg.intent_type"/></span>
                                    </div>
                                    <div t-if="msg.confidence" class="o-log-row">
                                        <span class="o-log-key">Confidence</span>
                                        <span class="o-log-val"><t t-esc="msg.confidence"/></span>
                                    </div>
                                    <div t-if="msg.execution_time_ms" class="o-log-row">
                                        <span class="o-log-key">Time</span>
                                        <span class="o-log-val"><t t-esc="msg.execution_time_ms"/></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- System / status message -->
                    <div t-elif="msg.type === 'system'" class="o-discuss-ai-row o-system">
                        <div class="o-discuss-ai-system-text">
                            <i class="fa fa-info-circle me-1"/>
                            <t t-esc="msg.text"/>
                        </div>
                    </div>

                </t><!-- end t-foreach -->

                <!-- Progress steps (loading indicator) -->
                <div t-if="state.loading" class="o-discuss-ai-row o-ai">
                    <div class="o-discuss-ai-avatar">🤖</div>
                    <div class="o-discuss-ai-bubble o-ai-bubble o-progress-bubble">
                        <t t-foreach="state.liveSteps" t-as="step" t-key="step_index">
                            <div class="o-progress-step" t-att-class="stepClass(step_index)">
                                <span class="o-progress-icon">
                                    <i t-if="stepClass(step_index) === 'o-done'" class="fa fa-check-circle"/>
                                    <i t-elif="stepClass(step_index) === 'o-active'" class="fa fa-circle-o-notch fa-spin"/>
                                    <i t-else="" class="fa fa-circle-o"/>
                                </span>
                                <span class="o-progress-label">
                                    <span class="o-progress-name"><t t-esc="step.name or step"/></span>
                                    <span t-if="step.detail" class="o-progress-detail">
                                        <t t-esc="step.detail"/>
                                    </span>
                                </span>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- Scroll anchor -->
                <div t-ref="msgEnd" class="o-discuss-ai-scroll-anchor"/>
            </div><!-- end messages -->

            <!-- Input area -->
            <div class="o-discuss-ai-input-area">
                <textarea
                    class="o-discuss-ai-input"
                    placeholder="Ask the AI assistant…  (Enter to send)"
                    t-model="state.input"
                    t-on-keydown="onKeydown"
                    t-att-disabled="state.loading"
                    rows="2"
                />
                <button
                    class="btn btn-primary o-discuss-ai-send"
                    title="Send"
                    t-on-click="sendMessage"
                    t-att-disabled="state.loading"
                >
                    <i class="fa fa-paper-plane"/>
                </button>
            </div>

        </div><!-- end o-discuss-ai-inner -->

    </div><!-- end o-discuss-ai-panel -->
</t>

<!-- ─── Inject panel into mail.Discuss ─────────────────────────────────── -->
<t t-inherit="mail.Discuss" t-inherit-mode="extension">
    <xpath expr="//div[hasclass('o-mail-Discuss')]" position="inside">
        <DiscussAiPanel t-if="!ui.isSmall"/>
    </xpath>
</t>

</templates>
