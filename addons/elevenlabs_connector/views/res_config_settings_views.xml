<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherit base settings view to add ElevenLabs section -->
        <record id="res_config_settings_view_form_elevenlabs" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.elevenlabs</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <div class="app_settings_block" data-string="ElevenLabs Voice Connector" string="ElevenLabs Voice Connector" data-key="elevenlabs_connector">
                        <h2>ElevenLabs Voice Connector</h2>
                        
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <span class="o_setting_name">Use your own ElevenLabs account</span>
                                    <div class="text-muted">
                                        Provide your API key to connect with your account
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane" style="width: 100%;">
                                    <label for="elevenlabs_api_key" style="display: block; margin-bottom: 8px; font-weight: 500;">ElevenLabs API Key</label>
                                    <field name="elevenlabs_api_key" password="True" placeholder="Enter your ElevenLabs API key" style="width: 100%; margin-bottom: 8px;"/>
                                    <div class="text-muted">
                                        Get your API key from <a href="https://elevenlabs.io/app/settings/api-keys" target="_blank">ElevenLabs Settings</a>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane" style="width: 100%;">
                                    <label for="elevenlabs_voice_id" style="display: block; margin-bottom: 8px; font-weight: 500;">Default Voice ID</label>
                                    <field name="elevenlabs_voice_id" placeholder="Voice ID (e.g., 21m00Tcm4TlvDq8ikWAM)" style="width: 100%; margin-bottom: 8px;"/>
                                    <div class="text-muted">
                                        Default voice model ID. Leave empty to use default (Rachel).
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane" style="width: 100%;">
                                    <label for="elevenlabs_language" style="display: block; margin-bottom: 8px; font-weight: 500;">Language</label>
                                    <field name="elevenlabs_language" style="width: 100%; margin-bottom: 8px;"/>
                                    <div class="text-muted">
                                        Language for voice output and transcription.
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane" style="width: 100%;">
                                    <label for="action_test_elevenlabs_connection" style="display: block; margin-bottom: 8px; font-weight: 500;">Connection Test</label>
                                    <button name="action_test_elevenlabs_connection" type="object" string="Test Connection" class="btn btn-primary" style="margin-bottom: 8px;"/>
                                    <div class="text-muted">
                                        Test the connection to ElevenLabs API.
                                    </div>
                                    <field name="elevenlabs_connection_status" invisible="1"/>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <span class="o_setting_name">AI Provider Configuration</span>
                                    <div class="text-muted">
                                        Configure which AI provider to use for processing voice queries.
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane" style="width: 100%;">
                                    <label for="ai_provider" style="display: block; margin-bottom: 8px; font-weight: 500;">AI Provider</label>
                                    <field name="ai_provider" style="width: 100%; margin-bottom: 8px;"/>
                                    <div class="text-muted">
                                        Select the AI provider for processing queries.
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane" style="width: 100%;">
                                    <label for="openai_api_key" style="display: block; margin-bottom: 8px; font-weight: 500;">OpenAI API Key</label>
                                    <field name="openai_api_key" password="True" placeholder="Enter your OpenAI API key" style="width: 100%; margin-bottom: 8px;"/>
                                    <div class="text-muted">
                                        Required if using OpenAI. Get it from <a href="https://platform.openai.com/api-keys" target="_blank">OpenAI Platform</a>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane" style="width: 100%;">
                                    <label for="gemini_api_key" style="display: block; margin-bottom: 8px; font-weight: 500;">Gemini API Key</label>
                                    <field name="gemini_api_key" password="True" placeholder="Enter your Gemini API key" style="width: 100%; margin-bottom: 8px;"/>
                                    <div class="text-muted">
                                        Required if using Gemini. Get it from <a href="https://makersuite.google.com/app/apikey" target="_blank">Google AI Studio</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

