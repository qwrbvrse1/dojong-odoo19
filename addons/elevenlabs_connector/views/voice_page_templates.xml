<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="voice_page_template" name="Voice Assistant Page">
            <t t-call="web.layout">
                <t t-set="title">Voice Assistant</t>
                <div class="oe_structure">
                    <div class="container mt-4">
                        <div class="row">
                            <div class="col-12">
                                <h1 class="text-center mb-4">Voice Assistant</h1>
                                <p class="text-center text-muted">Ask questions about your Odoo database using natural voice</p>
                            </div>
                        </div>
                        
                        <div class="row mt-4">
                            <div class="col-12 col-md-8 offset-md-2">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <div id="voice-controls" class="mb-4">
                                            <button id="record-btn" class="btn btn-primary btn-lg rounded-circle" style="width: 100px; height: 100px;">
                                                <i class="fa fa-microphone fa-2x"></i>
                                            </button>
                                            <p class="mt-3" id="status-text">Click to start recording</p>
                                        </div>
                                        
                                        <div id="audio-upload" class="mb-4">
                                            <input type="file" id="audio-file-input" accept="audio/*" class="d-none"/>
                                            <button id="upload-btn" class="btn btn-secondary">
                                                <i class="fa fa-upload"></i> Upload Audio File
                                            </button>
                                        </div>
                                        
                                        <div id="audio-player" class="mb-4" style="display: none;">
                                            <audio id="response-audio" class="w-100"></audio>
                                        </div>
                                        
                                        <div id="conversation-display" class="text-left">
                                            <div id="user-input-display" class="alert alert-info" style="display: none;">
                                                <strong>You:</strong> <span id="user-input-text"></span>
                                            </div>
                                            <div id="response-display" class="alert alert-success" style="display: none;">
                                                <strong>Assistant:</strong> <span id="response-text"></span>
                                            </div>
                                        </div>
                                        
                                        <div id="error-display" class="alert alert-danger" style="display: none;">
                                            <span id="error-text"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row mt-4">
                            <div class="col-12 col-md-8 offset-md-2">
                                <div class="card">
                                    <div class="card-header">
                                        <h5>Recent Conversations</h5>
                                    </div>
                                    <div class="card-body">
                                        <div id="conversation-history">
                                            <p class="text-muted">No conversations yet. Start by recording a question!</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </template>
    </data>
</odoo>
