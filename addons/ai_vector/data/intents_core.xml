<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="1">

    <record id="intent_member_lookup" model="ai.intent.schema">
        <field name="intent_type">member_lookup</field>
        <field name="name">Member Lookup</field>
        <field name="description">Look up member information by name or ID</field>
        <field name="category">read</field>
        <field name="parameters_schema">{
    "type": "object",
    "properties": {
        "member_name": {"type": "string", "description": "Name of the member to look up"},
        "member_id": {"type": "integer", "description": "ID of the member to look up"}
    }
}</field>
        <field name="example_phrases">Look up John Smith
Find member Sarah
What's Test8's information?
Show me details for Mike
Who is Jane Doe?</field>
        <field name="allowed_roles">kiosk,instructor,admin</field>
        <field name="requires_confirmation">False</field>
        <field name="is_undoable">False</field>
        <field name="supports_bulk">False</field>
        <field name="active">True</field>
    </record>

    <record id="intent_phone_lookup" model="ai.intent.schema">
        <field name="intent_type">phone_lookup</field>
        <field name="name">Phone Lookup</field>
        <field name="description">Look up members AND CRM leads by phone number (searches both dojo.member and crm.lead)</field>
        <field name="category">read</field>
        <field name="parameters_schema">{
    "type": "object",
    "properties": {
        "phone": {"type": "string", "description": "Phone number to search for (any format: 555-1234, (408) 867-5309, +1 555-123-4567, etc.)"}
    },
    "required": ["phone"]
}</field>
        <field name="example_phrases">Who has phone number 555-1234?
What member has this number: (408) 867-5309
Look up +1 555 123 4567
Find the student with number 555-0112
Who does this number belong to?
Search by phone 4085551234</field>
        <field name="allowed_roles">kiosk,instructor,admin</field>
        <field name="requires_confirmation">False</field>
        <field name="is_undoable">False</field>
        <field name="supports_bulk">False</field>
        <field name="active">True</field>
    </record>

    <record id="intent_member_create" model="ai.intent.schema">
        <field name="intent_type">member_create</field>
        <field name="name">Create Member</field>
        <field name="description">Create a new member record</field>
        <field name="category">member</field>
        <field name="parameters_schema">{
    "type": "object",
    "properties": {
        "name": {"type": "string", "description": "Full name of the new member"},
        "email": {"type": "string", "format": "email", "description": "Email address"},
        "phone": {"type": "string", "description": "Phone number"}
    },
    "required": ["name"]
}</field>
        <field name="allowed_roles">admin</field>
        <field name="requires_confirmation">True</field>
        <field name="example_phrases">Create a new member named John Smith
Add a new student Sarah Jones
Register new member Test8
Create a profile for Mike Williams
Add a new student Jane Doe with email jane@example.com</field>
        <field name="confirmation_template">Create new member "{name}"?</field>
        <field name="is_undoable">True</field>
        <field name="supports_bulk">False</field>
        <field name="active">True</field>
    </record>

    <record id="intent_member_update" model="ai.intent.schema">
        <field name="intent_type">member_update</field>
        <field name="name">Update Member</field>
        <field name="description">Update an existing member's information</field>
        <field name="category">member</field>
        <field name="parameters_schema">{
    "type": "object",
    "properties": {
        "member_name": {"type": "string", "description": "Name of the member to update"},
        "member_id": {"type": "integer", "description": "ID of the member"},
        "name": {"type": "string", "description": "New name"},
        "email": {"type": "string", "format": "email", "description": "New email"},
        "phone": {"type": "string", "description": "New phone"}
    },
    "required": ["member_name"]
}</field>
        <field name="allowed_roles">admin</field>
        <field name="requires_confirmation">True</field>
        <field name="example_phrases">Update John's email to john@example.com
Change Sarah's phone number
Update Test8's name
Edit Mike's contact information
Update Jane's profile details</field>
        <field name="confirmation_template">Update {member_name}'s profile?</field>
        <field name="is_undoable">True</field>
        <field name="supports_bulk">False</field>
        <field name="active">True</field>
    </record>

    <record id="intent_undo_action" model="ai.intent.schema">
        <field name="intent_type">undo_action</field>
        <field name="name">Undo Action</field>
        <field name="description">Undo the most recent undoable action</field>
        <field name="category">system</field>
        <field name="parameters_schema">{
    "type": "object",
    "properties": {
        "original_action_log_id": {"type": "integer", "description": "ID of the action to undo"}
    }
}</field>
