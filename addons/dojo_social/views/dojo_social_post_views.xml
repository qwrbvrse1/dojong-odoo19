<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Kanban View ─────────────────────────────────────────────────────── -->
    <record id="view_dojo_social_post_kanban" model="ir.ui.view">
        <field name="name">dojo.social.post.kanban</field>
        <field name="model">dojo.social.post</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="state"/>
                <field name="account_id"/>
                <field name="platform"/>
                <field name="scheduled_date"/>
                <field name="posted_at"/>
                <field name="name"/>
                <field name="image"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div t-if="record.image.raw_value" class="o_kanban_image mb-2">
                                <img t-att-src="'data:image/png;base64,' + record.image.raw_value"
                                     style="max-height:80px; width:100%; object-fit:cover; border-radius:4px;"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <p class="mb-1" style="font-size:13px; line-height:1.4;">
                                    <t t-out="record.name.value"/>
                                </p>
                            </div>
                            <div class="o_kanban_record_bottom mt-2">
                                <div class="oe_kanban_bottom_left text-muted" style="font-size:11px;">
                                    <span t-out="record.account_id.value"/>
                                    <t t-if="record.scheduled_date.raw_value">
                                        · <span t-out="record.scheduled_date.value"/>
                                    </t>
                                    <t t-if="record.posted_at.raw_value">
                                        · <span t-out="record.posted_at.value"/>
                                    </t>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="state" widget="badge"
                                        decoration-info="state == 'draft'"
                                        decoration-warning="state == 'scheduled'"
                                        decoration-success="state == 'posted'"
                                        decoration-danger="state == 'failed'"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ── List View ──────────────────────────────────────────────────────── -->
    <record id="view_dojo_social_post_list" model="ir.ui.view">
        <field name="name">dojo.social.post.list</field>
        <field name="model">dojo.social.post</field>
        <field name="arch" type="xml">
            <list decoration-muted="state == 'draft'" decoration-success="state == 'posted'"
                  decoration-danger="state == 'failed'">
                <field name="scheduled_date"/>
                <field name="account_id"/>
                <field name="platform"/>
                <field name="name" string="Message Preview"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'draft'"
                    decoration-warning="state == 'scheduled'"
                    decoration-success="state == 'posted'"
                    decoration-danger="state == 'failed'"/>
                <field name="posted_at"/>
            </list>
        </field>
    </record>

    <!-- ── Form View ──────────────────────────────────────────────────────── -->
    <record id="view_dojo_social_post_form" model="ir.ui.view">
        <field name="name">dojo.social.post.form</field>
        <field name="model">dojo.social.post</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_post_now" string="Post Now"
                        type="object" class="btn-primary"
                        invisible="state == 'posted'"
                        confirm="Post this to social media now?"/>
                    <button name="action_schedule" string="Schedule"
                        type="object"
                        invisible="state != 'draft'"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                        type="object"
                        invisible="state not in ['scheduled', 'failed']"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,scheduled,posted"/>
                </header>
                <sheet>
                    <!-- Error banner -->
                    <div class="alert alert-danger mb-3" role="alert"
                         invisible="not error_message">
                        <strong>Post Failed:</strong>
                        <field name="error_message" nolabel="1"/>
                    </div>
                    <group>
                        <group string="Message">
                            <field name="message" nolabel="1"
                                   placeholder="Write your post message here..."
                                   style="min-height:120px;"/>
                        </group>
                        <group string="Image (optional)">
                            <field name="image" widget="image" class="oe_avatar"/>
                            <field name="image_filename" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Publishing">
                            <field name="account_id"/>
                            <field name="platform" readonly="1"/>
                            <field name="scheduled_date" invisible="state == 'posted'"/>
                            <field name="posted_at" invisible="state != 'posted'" readonly="1"/>
                            <field name="external_post_id" invisible="state != 'posted'" readonly="1" string="Platform Post ID"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Action ─────────────────────────────────────────────────────────── -->
    <record id="action_dojo_social_post" model="ir.actions.act_window">
        <field name="name">Social Posts</field>
        <field name="res_model">dojo.social.post</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first social post
            </p>
            <p>
                Write a message, optionally attach an image, then post immediately
                or schedule it for a future date.
            </p>
        </field>
    </record>

</odoo>
