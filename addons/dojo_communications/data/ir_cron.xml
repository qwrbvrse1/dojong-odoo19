<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_session_reminders" model="ir.cron">
        <field name="name">Dojang: Send 24-Hour Session Reminders</field>
        <field name="model_id" ref="dojo_classes.model_dojo_class_session"/>
        <field name="state">code</field>
        <field name="code">model._cron_send_reminders()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
