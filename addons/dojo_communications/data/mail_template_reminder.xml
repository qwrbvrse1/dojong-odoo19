<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         Session Reminder EMAIL template
         Model: dojo.class.session
         ================================================================ -->
    <record id="mail_template_reminder_email" model="mail.template">
        <field name="name">Dojang: Upcoming Session Reminder (Email)</field>
        <field name="model_id" ref="dojo_classes.model_dojo_class_session"/>
        <field name="subject">Reminder: {{ object.name }} is tomorrow</field>
        <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
    <h2 style="color: #2c3e50;">Class Reminder</h2>
    <p>Hello,</p>
    <p>This is a friendly reminder that a class is scheduled for <strong>tomorrow</strong>.</p>
    <table style="width:100%; border-collapse: collapse; margin: 16px 0;">
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold; background: #f9f9f9;">Class</td>
            <td style="padding: 8px; border: 1px solid #ddd;">{{ object.name }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold; background: #f9f9f9;">Date &amp; Time</td>
            <td style="padding: 8px; border: 1px solid #ddd;">{{ object.start_datetime | datetime }}</td>
        </tr>
        {% if object.instructor_profile_id %}
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold; background: #f9f9f9;">Instructor</td>
            <td style="padding: 8px; border: 1px solid #ddd;">{{ object.instructor_profile_id.name }}</td>
        </tr>
        {% endif %}
    </table>
    <p>We look forward to seeing you!</p>
    <p style="color: #7f8c8d; font-size: 12px;">
        This is an automated reminder from {{ object.company_id.name }}.
        To unsubscribe from reminders, contact the Dojang directly.
    </p>
</div>
        ]]></field>
        <field name="auto_delete" eval="True"/>
    </record>

    <!-- ================================================================
         Session Reminder SMS template
         ================================================================ -->
    <record id="mail_template_reminder_sms" model="mail.template">
        <field name="name">Dojang: Upcoming Session Reminder (SMS)</field>
        <field name="model_id" ref="dojo_classes.model_dojo_class_session"/>
        <field name="subject">Reminder SMS</field>
        <field name="body_html"><![CDATA[Reminder: {{ object.name }} is tomorrow at {{ object.start_datetime | time }}. See you there! - {{ object.company_id.name }}]]></field>
        <field name="auto_delete" eval="True"/>
    </record>
</odoo>
