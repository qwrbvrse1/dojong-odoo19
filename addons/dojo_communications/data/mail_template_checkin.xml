<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         Check-in EMAIL template
         Model: dojo.attendance.log
         ================================================================ -->
    <record id="mail_template_checkin_email" model="mail.template">
        <field name="name">Dojang: Student Check-In Notification (Email)</field>
        <field name="model_id" ref="dojo_attendance.model_dojo_attendance_log"/>
        <field name="subject">✅ {{ object.member_id.name }} just checked in</field>
        <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
    <h2 style="color: #2c3e50;">Check-In Notification</h2>
    <p>Hello,</p>
    <p>
        <strong>{{ object.member_id.name }}</strong> has just checked in to class.
    </p>
    <table style="width:100%; border-collapse: collapse; margin: 16px 0;">
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold; background: #f9f9f9;">Session</td>
            <td style="padding: 8px; border: 1px solid #ddd;">{{ object.session_id.name }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold; background: #f9f9f9;">Check-In Time</td>
            <td style="padding: 8px; border: 1px solid #ddd;">{{ object.checkin_datetime | datetime }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold; background: #f9f9f9;">Status</td>
            <td style="padding: 8px; border: 1px solid #ddd;">{{ object.status | title }}</td>
        </tr>
    </table>
    <p style="color: #7f8c8d; font-size: 12px;">
        This is an automated notification from {{ object.company_id.name }}.
    </p>
</div>
        ]]></field>
        <field name="auto_delete" eval="True"/>
    </record>

    <!-- ================================================================
         Check-in SMS template  (body_html is rendered then stripped to plain text)
         ================================================================ -->
    <record id="mail_template_checkin_sms" model="mail.template">
        <field name="name">Dojang: Student Check-In Notification (SMS)</field>
        <field name="model_id" ref="dojo_attendance.model_dojo_attendance_log"/>
        <field name="subject">Check-In SMS</field>
        <field name="body_html"><![CDATA[{{ object.member_id.name }} checked in to {{ object.session_id.name }} at {{ object.checkin_datetime | time }}. - {{ object.company_id.name }}]]></field>
        <field name="auto_delete" eval="True"/>
    </record>
</odoo>
