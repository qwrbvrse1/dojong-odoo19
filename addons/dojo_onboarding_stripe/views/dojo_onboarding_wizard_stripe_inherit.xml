<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_dojo_onboarding_wizard_stripe_payment_inherit" model="ir.ui.view">
        <field name="name">dojo.onboarding.wizard.form.stripe.payment.inherit</field>
        <field name="model">dojo.onboarding.wizard</field>
        <field name="inherit_id" ref="dojo_onboarding.view_dojo_onboarding_wizard_form"/>
        <field name="arch" type="xml">

            <!-- 1. Hidden fields so the OWL widget and Python can read/write them -->
            <xpath expr="//field[@name='step']" position="after">
                <field name="payment_captured" invisible="1"/>
                <field name="skip_payment" invisible="1"/>
                <field name="stripe_card_display" invisible="1"/>
            </xpath>

            <!-- 2. Payment breadcrumb in the guardian-phase progress header -->
            <xpath expr="//div[hasclass('alert-info')]//span[@invisible=&quot;step != 'guardian_portal'&quot;]"
                   position="after">
                <span invisible="step != 'payment'">
                    ✓ Guardian Contact  ›  ✓ Household  ›  ✓ Guardian Portal  ›  <b>Payment</b>
                </span>
            </xpath>

            <!-- 3. Payment step content (inserted after Guardian Portal, still in guardian phase area) -->
            <xpath expr="//group[@name='group_guardian_portal']" position="after">
                <group string="Payment Method" invisible="step != 'payment'" name="group_payment">
                    <div class="alert alert-info py-3 px-3 mb-0"
                         colspan="2" role="alert">
                        <div class="d-flex align-items-start gap-2">
                            <i class="fa fa-credit-card fa-lg mt-1 flex-shrink-0" title="Payment"/>
                            <div>
                                <div class="fw-semibold mb-1">
                                    Save a payment method for this household
                                </div>
                                <div class="text-muted">
                                    Student invoices will be automatically charged to the saved card.
                                    You can skip this step to use invoice-only billing.
                                </div>
                            </div>
                        </div>
                    </div>
                    <div colspan="2" class="pt-3">
                        <widget name="onboarding_stripe_payment"/>
                    </div>
                </group>
            </xpath>

            <!-- 4. Hide "Pay Later" toggle on subscription step (defer_payment) -->
            <xpath expr="//field[@name='defer_payment']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- 5. Replace footer with payment-aware navigation -->
            <xpath expr="//footer" position="replace">
                <footer>
                    <!-- Guardian contact with existing household → Next (to payment or student) -->
                    <button name="action_next" type="object"
                            string="Next →"
                            class="btn btn-primary"
                            invisible="step != 'guardian_contact' or not use_existing_household"/>
                    <!-- Guardian phase: Next (new guardian flow, not on portal/payment steps) -->
                    <button name="action_next" type="object" string="Next →"
                            class="btn btn-primary"
                            invisible="wizard_phase != 'guardian' or step in ('guardian_portal', 'payment') or use_existing_household"/>
                    <!-- Guardian portal: Create Guardian &amp; Next (to payment) -->
                    <button name="action_next" type="object"
                            string="Create Guardian &amp; Next →"
                            class="btn btn-primary"
                            invisible="step != 'guardian_portal'"/>
                    <!-- Payment step: Continue to Students -->
                    <button name="action_next" type="object"
                            string="Continue to Students →"
                            class="btn btn-primary"
                            invisible="step != 'payment'"/>

                    <!-- Student phase: Next (not on student_portal or summary) -->
                    <button name="action_next" type="object" string="Next →"
                            class="btn btn-primary"
                            invisible="wizard_phase != 'student' or step in ('student_portal', 'summary')"/>
                    <!-- Student phase: Confirm Student (on student_portal step) -->
                    <button name="action_confirm_student" type="object"
                            string="Confirm &amp; Register Student"
                            class="btn btn-primary"
                            invisible="step != 'student_portal'"/>
                    <!-- Summary: Add another -->
                    <button name="action_add_another_student" type="object"
                            string="Register Another Student"
                            class="btn btn-primary"
                            invisible="step != 'summary'"/>
                    <!-- Summary: Finish -->
                    <button name="action_finish" type="object"
                            string="Finish Onboarding"
                            class="btn btn-success"
                            invisible="step != 'summary'"/>

                    <!-- Back button -->
                    <button name="action_back" type="object" string="← Previous"
                            class="btn btn-secondary"
                            invisible="step in ('guardian_contact', 'summary')"/>
                    <button special="cancel" string="Cancel" class="btn btn-secondary"/>
                </footer>
            </xpath>

        </field>
    </record>

</odoo>
