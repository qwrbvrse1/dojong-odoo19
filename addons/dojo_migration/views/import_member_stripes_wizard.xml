<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_import_member_stripes_wizard_form" model="ir.ui.view">
        <field name="name">dojo.migration.import.member.stripes.form</field>
        <field name="model">dojo.migration.import.member.stripes</field>
        <field name="arch" type="xml">
            <form string="Import Member Stripe Counts">
                <header>
                    <button name="action_preview" string="Preview" type="object"
                            class="btn-primary" invisible="state != 'upload'"/>
                    <button name="action_import" string="Import" type="object"
                            class="btn-primary" invisible="state != 'preview'"/>
                    <button name="action_preview" string="Re-preview" type="object"
                            class="btn-secondary" invisible="state != 'preview'"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>09. Import Member Stripe Counts</h1>
                    </div>
                    <group invisible="state == 'done'">
                        <field name="csv_file" widget="binary" filename="filename"/>
                        <field name="filename" invisible="1"/>
                        <field name="state" invisible="1"/>
                    </group>
                    <div class="alert alert-info" role="alert" invisible="state != 'upload'">
                        <strong>Expected columns:</strong>
                        <code>id</code> (member external ID, required),
                        <code>current_stripe_count</code> (integer)
                        — Updates the stripe count on the member's most recent belt rank record.
                        Run <strong>after</strong> importing member belt ranks (step 08).
                    </div>
                    <group invisible="state != 'preview'" string="Preview (first 5 rows)">
                        <field name="preview_html" widget="html" nolabel="1"/>
                    </group>
                    <div class="alert alert-success" role="alert" invisible="state != 'done'">
                        Import complete.
                        <a type="object" name="action_open_log">View log →</a>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_import_member_stripes_wizard" model="ir.actions.act_window">
        <field name="name">09. Import Member Stripe Counts</field>
        <field name="res_model">dojo.migration.import.member.stripes</field>
        <field name="view_mode">form</field>
        <field name="target">main</field>
    </record>
</odoo>
