<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Migration Log: List ─────────────────────────────────────────── -->
    <record id="view_migration_log_tree" model="ir.ui.view">
        <field name="name">dojo.migration.log.tree</field>
        <field name="model">dojo.migration.log</field>
        <field name="arch" type="xml">
            <list string="Import History" decoration-danger="state == 'failed'"
                  decoration-warning="state == 'partial'"
                  decoration-success="state == 'done'">
                <field name="name"/>
                <field name="import_type"/>
                <field name="filename"/>
                <field name="date"/>
                <field name="total_rows"/>
                <field name="success_count" string="Imported"/>
                <field name="skip_count" string="Skipped"/>
                <field name="error_count" string="Errors"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- ── Migration Log: Form ─────────────────────────────────────────── -->
    <record id="view_migration_log_form" model="ir.ui.view">
        <field name="name">dojo.migration.log.form</field>
        <field name="model">dojo.migration.log</field>
        <field name="arch" type="xml">
            <form string="Import Log" create="false" edit="false">
                <header>
                    <button name="action_download_error_report"
                            string="Download Error Report"
                            type="object"
                            class="btn-secondary"
                            invisible="error_count == 0 and skip_count == 0"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="import_type"/>
                            <field name="filename"/>
                            <field name="date"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="total_rows"/>
                            <field name="success_count" string="Imported"/>
                            <field name="skip_count" string="Skipped (duplicates)"/>
                            <field name="error_count" string="Errors"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Row Details" name="row_details">
                            <field name="log_line_ids" nolabel="1">
                                <list decoration-danger="status == 'error'"
                                      decoration-warning="status == 'skip'"
                                      decoration-success="status == 'success'">
                                    <field name="row_number"/>
                                    <field name="status"/>
                                    <field name="message"/>
                                    <field name="raw_data" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── ir.sequence for log names ───────────────────────────────────── -->
    <record id="seq_migration_log" model="ir.sequence">
        <field name="name">Migration Import Log</field>
        <field name="code">dojo.migration.log</field>
        <field name="prefix">MIG-</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- ── Actions ─────────────────────────────────────────────────────── -->
    <record id="action_migration_log" model="ir.actions.act_window">
        <field name="name">Import History</field>
        <field name="res_model">dojo.migration.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
