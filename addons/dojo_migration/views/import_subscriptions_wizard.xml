<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_import_subscriptions_wizard_form" model="ir.ui.view">
        <field name="name">dojo.migration.import.subscriptions.form</field>
        <field name="model">dojo.migration.import.subscriptions</field>
        <field name="arch" type="xml">
            <form string="Import Subscriptions">
                <header>
                    <button name="action_preview" string="Preview" type="object"
                            class="btn-primary" invisible="state != 'upload'"/>
                    <button name="action_download_template" string="Download Template"
                            type="object" class="btn-secondary"/>
                    <button name="action_import" string="Import" type="object"
                            class="btn-primary" invisible="state != 'preview'"/>
                    <button name="action_preview" string="Re-preview" type="object"
                            class="btn-secondary" invisible="state != 'preview'"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>Import Subscriptions</h1>
                    </div>
                    <group invisible="state == 'done'">
                        <field name="csv_file" widget="binary" filename="filename"/>
                        <field name="filename" invisible="1"/>
                        <field name="state" invisible="1"/>
                    </group>
                    <div class="alert alert-info" role="alert" invisible="state != 'upload'">
                        <strong>Required:</strong>
                        Run <em>Import Members</em> first so members exist.<br/>
                        <strong>Expected columns:</strong>
                        <code>member_email</code> (required),
                        <code>plan_name</code> (required),
                        <code>billing_period</code> (monthly/weekly/yearly),
                        <code>price</code>, <code>initial_fee</code>,
                        <code>start_date</code> (required),
                        <code>state</code> (active/paused/cancelled/expired),
                        <code>end_date</code>, <code>next_billing_date</code>,
                        <code>program_name</code>, <code>billing_reference</code>
                    </div>
                    <group invisible="state != 'preview'" string="Preview (first 5 rows)">
                        <field name="preview_html" widget="html" nolabel="1"/>
                    </group>
                    <div class="alert alert-success" role="alert" invisible="state != 'done'">
                        Import complete.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_import_subscriptions_wizard" model="ir.actions.act_window">
        <field name="name">Import Subscriptions</field>
        <field name="res_model">dojo.migration.import.subscriptions</field>
        <field name="view_mode">form</field>
        <field name="target">main</field>
    </record>
</odoo>
