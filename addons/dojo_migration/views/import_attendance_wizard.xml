<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_import_attendance_wizard_form" model="ir.ui.view">
        <field name="name">dojo.migration.import.attendance.form</field>
        <field name="model">dojo.migration.import.attendance</field>
        <field name="arch" type="xml">
            <form string="Import Attendance History">
                <header>
                    <button name="action_preview" string="Preview" type="object"
                            class="btn-primary" invisible="state != 'upload'"/>
                    <button name="action_download_template" string="Download Template"
                            type="object" class="btn-secondary"/>
                    <button name="action_import" string="Import" type="object"
                            class="btn-primary" invisible="state != 'preview'"/>
                    <button name="action_preview" string="Re-preview" type="object"
                            class="btn-secondary" invisible="state != 'preview'"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>Import Attendance History</h1>
                    </div>
                    <group invisible="state == 'done'">
                        <field name="csv_file" widget="binary" filename="filename"/>
                        <field name="filename" invisible="1"/>
                        <field name="state" invisible="1"/>
                    </group>
                    <div class="alert alert-info" role="alert" invisible="state != 'upload'">
                        <strong>Required:</strong>
                        Run <em>Import Members</em> first so members exist.<br/>
                        <strong>Expected columns:</strong>
                        <code>member_email</code> (required),
                        <code>class_date</code> (required; YYYY-MM-DD),
                        <code>class_name</code> (default: "Imported Class"),
                        <code>program_name</code>,
                        <code>status</code> (present/late/absent/excused),
                        <code>class_time</code> (HH:MM 24h; default 09:00)<br/>
                        <em>Note:</em> If no matching session is found, a placeholder
                        session is automatically created (flagged as import placeholder).
                    </div>
                    <group invisible="state != 'preview'" string="Preview (first 5 rows)">
                        <field name="preview_html" widget="html" nolabel="1"/>
                    </group>
                    <div class="alert alert-success" role="alert" invisible="state != 'done'">
                        Import complete.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_import_attendance_wizard" model="ir.actions.act_window">
        <field name="name">Import Attendance History</field>
        <field name="res_model">dojo.migration.import.attendance</field>
        <field name="view_mode">form</field>
        <field name="target">main</field>
    </record>
</odoo>
