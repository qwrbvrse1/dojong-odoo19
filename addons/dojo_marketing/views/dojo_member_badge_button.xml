<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
        Injects a "Print Badge" stat button into the dojo.member form view.
        Only present when dojo_marketing is installed.
        Visible to instructors and admins only.
    -->
    <record id="view_dojo_member_badge_button" model="ir.ui.view">
        <field name="name">dojo.member.badge.button</field>
        <field name="model">dojo.member</field>
        <field name="inherit_id" ref="dojo_base.view_dojo_member_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button type="object"
                        name="action_print_badge"
                        class="oe_stat_button"
                        icon="fa-print"
                        groups="dojo_base.group_dojo_instructor,dojo_base.group_dojo_admin">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Print Badge</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
