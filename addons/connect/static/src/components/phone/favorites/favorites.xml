<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Activities (replaces Favorites tab) -->
    <t t-name="connect.favorites" owl="1">
        <div class="o_activities_panel">

            <!--Loading state-->
            <div t-if="state.loading" class="o_activities_loading">
                <i class="fa fa-spinner fa-spin"/>
            </div>

            <!--Empty state-->
            <div t-elif="state.activities.length === 0" class="o_activities_empty">
                <span class="o_activities_empty_emoji">🎉</span>
                <span class="o_activities_empty_title">All caught up!</span>
                <span class="o_activities_empty_sub">No calls or follow-ups due today.</span>
            </div>

            <!--Activity list-->
            <div t-else="" class="o_activities_list">
                <t t-foreach="state.activities" t-as="act" t-key="act.id">
                    <div t-attf-class="o_activity_row{{ act.isOverdue ? ' overdue' : '' }}" t-on-click="() => this._onClickActivity(act)">
                        <div class="o_activity_icon_wrap">
                            <i t-attf-class="fa {{ this._getActivityIcon(act) }} o_activity_type_icon"/>
                        </div>
                        <div class="o_activity_body">
                            <div class="o_activity_name" t-out="act.res_name"/>
                            <div class="o_activity_summary" t-if="act.summary" t-out="act.summary"/>
                            <div class="o_activity_type" t-if="act.activity_type_id">
                                <t t-out="act.activity_type_id[1]"/>
                            </div>
                        </div>
                        <div class="o_activity_actions">
                            <span t-attf-class="o_activity_badge{{ act.isOverdue ? ' overdue' : '' }}" t-out="act.badge"/>
                            <button class="o_activity_call_btn" title="Call" t-on-click="(ev) => this._onClickCallActivity(ev, act)">
                                <i class="fa fa-phone"/>
                            </button>
                        </div>
                    </div>
                </t>
            </div>

        </div>
    </t>

</templates>