<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="connect.contacts" owl="1">
        <div class="o_contacts_root">
            <div t-attf-class="{{ state.isContactMode ? '' : 'd-none' }} o_phone_number_content">
                <input class="o_phone_number_input" placeholder="Enter name or number" t-ref="contact-input" t-on-keyup="_onSearchContact" autocomplete="off"/>
                <div aria-label="Clear" class="fa fa-times-circle o_phone_number_back" role="img" title="Clear" t-on-click="_onClickClearSearchContact"/>
            </div>
            <div class="o_dial_contact_list">
                <!--No results message-->
                <div t-if="state.hasSearched and state.users.length === 0 and state.partners.length === 0 and !this.isFavoritesMode" class="o_no_results">
                    <i class="fa fa-search"/>
                    <span>No contact or number found</span>
                </div>
                <!--Empty favorites-->
                <div t-if="state.hasSearched and state.users.length === 0 and state.partners.length === 0 and this.isFavoritesMode" class="o_no_results">
                    <i class="fa fa-star-o"/>
                    <span>No favorites yet</span>
                </div>
                <table class="o_contact_table" t-if="state.users.length > 0 or state.partners.length > 0">
                    <!-- Users -->
                    <t t-foreach="state.users" t-as="user" t-key="user.id">
                        <tr>
                            <td class="o_contact_avatar">
                                <img alt="Avatar" class="o_contact_avatar" t-attf-src="/web/image?model=res.users&amp;field=avatar_128&amp;id={{ user.user[0] }}"/>
                            </td>
                            <td class="o_contact_info">
                                <div>
                                    <span><t t-out="user.name"/></span>
                                </div>
                                <div>
                                    <span class="icon-dialer_sip o_contact_phone"><t t-out="user.exten_number"/></span>
                                </div>
                            </td>
                            <td class="o_contact_call_button">
                                <button aria-label="Call" t-on-click="() => this._onClickMakeCall(user.exten_number)">
                                    <i class="fa fa-phone"/>
                                </button>
                            </td>
                        </tr>
                    </t>
                    <!-- Partners -->
                    <t t-foreach="state.partners" t-as="partner" t-key="partner.id">
                        <tr>
                            <td class="o_contact_avatar" t-on-click="() => partner.id > 0 and this._openPartner(partner.id)">
                                <img t-if="partner.id > 0" alt="Avatar" class="o_contact_avatar" t-attf-src="/web/image?model=res.partner&amp;field=avatar_128&amp;id={{ partner.id }}"/>
                                <img t-else="" alt="Avatar" class="o_contact_avatar" src="/connect/static/src/images/default_contact.jpg"/>
                            </td>
                            <td class="o_contact_info" t-on-click="() => partner.id > 0 and this._openPartner(partner.id)">
                                <div>
                                    <span><t t-out="partner.name"/></span>
                                    <div t-if="partner.connect_phone_normalized">
                                        <span class="icon-phone o_contact_phone"><t t-out="partner.connect_phone_normalized"/></span>
                                    </div>
                                    <div t-if="partner.connect_mobile_normalized">
                                        <span class="fa fa-mobile o_contact_phone"><t t-out="partner.connect_mobile_normalized"/></span>
                                    </div>
                                </div>
                            </td>
                            <td class="o_contact_call_button">
                                <button aria-label="Call" t-on-click="() => this._onClickMakeCall(partner.connect_phone_normalized || partner.connect_mobile_normalized)">
                                    <i class="fa fa-phone"/>
                                </button>
                            </td>
                        </tr>
                    </t>

                </table>
            </div>
        </div>
    </t>

</templates>