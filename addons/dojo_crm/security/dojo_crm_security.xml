<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="0">

    <!--
        Add dojo_core.group_dojo_instructor to the core CRM "All Leads" rule so
        instructors can see every crm.lead record regardless of the user_id owner.
        Without this, instructors fall through to the "Personal Leads" rule
        (group_sale_salesman) which filters leads to only those assigned to them.
    -->
    <record id="crm.crm_rule_all_lead" model="ir.rule">
        <field name="groups" eval="[
            (4, ref('sales_team.group_sale_salesman_all_leads')),
            (4, ref('dojo_core.group_dojo_instructor')),
        ]"/>
    </record>

</odoo>
