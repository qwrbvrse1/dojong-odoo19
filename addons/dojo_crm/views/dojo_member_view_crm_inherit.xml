<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Leads smart button to dojo.member form -->
    <record id="view_dojo_member_form_crm_inherit" model="ir.ui.view">
        <field name="name">dojo.member.form.crm.inherit</field>
        <field name="model">dojo.member</field>
        <field name="inherit_id" ref="dojo_base.view_dojo_member_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_view_leads"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-bullhorn"
                    invisible="lead_count == 0"
                >
                    <field name="lead_count" widget="statinfo" string="Lead(s)"/>
                </button>
            </xpath>
            <!-- computed field needed by the button visibility -->
            <xpath expr="//sheet" position="inside">
                <field name="lead_count" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>
