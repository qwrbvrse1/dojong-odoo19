<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Root CRM menu — points directly to the custom pipeline board -->
    <menuitem
        id="crm.crm_menu_root"
        name="CRM"
        action="dojo_crm.action_dojo_crm_pipeline_board"
        groups="sales_team.group_sale_salesman,sales_team.group_sale_manager,dojo_core.group_dojo_instructor"/>

    <!-- Hide all standard CRM submenus (Sales, Reporting, Configuration) -->
    <menuitem id="crm.crm_menu_sales" active="False" groups="base.group_no_one"/>
    <menuitem id="crm.crm_menu_report" active="False" groups="base.group_no_one"/>
    <menuitem id="crm.crm_menu_config" active="False" groups="base.group_no_one"/>
</odoo>
