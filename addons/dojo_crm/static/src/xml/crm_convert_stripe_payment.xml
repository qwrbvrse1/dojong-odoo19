<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="dojo_crm.CrmConvertStripePayment">
        <div class="dojo-crm-stripe-widget w-100">

            <!-- Idle — waiting for user to start card capture -->
            <t t-if="state.status === 'idle'">
                <button class="btn btn-outline-primary"
                        t-on-click="_initStripe">
                    <i class="fa fa-credit-card me-1"/>Add Payment Card
                </button>
            </t>

            <!-- Loading -->
            <t t-if="state.status === 'loading'">
                <div class="d-flex align-items-center gap-2 text-muted py-3">
                    <i class="fa fa-spinner fa-spin fa-lg"/>
                    <span>Loading secure payment form…</span>
                </div>
            </t>

            <!-- Card entry form -->
            <t t-if="state.status === 'ready' or state.status === 'processing'">
                <div class="border rounded p-3 bg-white">
                    <p class="text-muted small mb-2">
                        <i class="fa fa-lock me-1"/>
                        Card details are securely processed by Stripe and never stored on our servers.
                    </p>
                    <div t-ref="stripe-mount" class="py-1"/>
                    <div class="mt-3">
                        <button
                            class="btn btn-primary"
                            t-on-click="onSaveCard"
                            t-att-disabled="state.status === 'processing'">
                            <t t-if="state.status === 'processing'">
                                <i class="fa fa-spinner fa-spin me-1"/>Saving card…
                            </t>
                            <t t-else="">
                                <i class="fa fa-lock me-1"/>Save Card
                            </t>
                        </button>
                    </div>
                </div>
            </t>

            <!-- Success -->
            <t t-if="state.status === 'done'">
                <div class="alert alert-success d-flex align-items-center gap-2 py-3 px-3">
                    <i class="fa fa-check-circle fa-lg flex-shrink-0"/>
                    <div>
                        <div class="fw-semibold">Payment method saved</div>
                        <div class="text-muted small" t-out="state.cardDisplay"/>
                    </div>
                </div>
            </t>

            <!-- Error -->
            <t t-if="state.status === 'error'">
                <div class="alert alert-danger d-flex align-items-start gap-2 py-3 px-3">
                    <i class="fa fa-exclamation-circle fa-lg flex-shrink-0 mt-1"/>
                    <div>
                        <div class="fw-semibold">Payment error</div>
                        <div class="small" t-out="state.errorMessage"/>
                    </div>
                </div>
                <button class="btn btn-outline-secondary btn-sm mt-2" t-on-click="onRetry">
                    <i class="fa fa-refresh me-1"/>Try Again
                </button>
            </t>

            <!-- Skip option -->
            <div class="mt-3 pt-3 border-top" t-if="state.status !== 'done'">
                <div class="form-check">
                    <input
                        type="checkbox"
                        class="form-check-input"
                        id="skip-stripe-crm-convert"
                        t-att-checked="props.record.data.skip_payment"
                        t-on-change="onSkipChange"
                    />
                    <label class="form-check-label fw-medium" for="skip-stripe-crm-convert">
                        Skip — guardian can add a card later via the portal
                    </label>
                </div>
                <div class="alert alert-info py-2 px-3 mt-2 small"
                     t-if="props.record.data.skip_payment">
                    <i class="fa fa-envelope me-2"/>
                    Invoices will be emailed to the billing contact. The guardian can add a card
                    at any time via the member portal.
                </div>
            </div>

        </div>
    </t>

</templates>
