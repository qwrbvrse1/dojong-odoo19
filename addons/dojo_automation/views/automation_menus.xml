<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Hide automation_oca's top-level menu ─────────────────────────────
         dojo_automation owns the user-facing entry point now. The OCA menu
         is gated behind the developer (no_one) group so power users can
         still reach the raw form when needed. -->
    <record id="automation_oca.automation_root_menu" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- ── Window action: list of configurations using the rebranded kanban
         (AutomationStatPanel + filter chips already injected). -->
    <record id="action_dojo_automations" model="ir.actions.act_window">
        <field name="name">Care Workflows</field>
        <field name="res_model">automation.configuration</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Set up your first care workflow
            </p>
            <p>
                Pick a pre-built care trigger and chain updates, follow-up tasks,
                and outreach steps in a simple day-by-day response timeline.
            </p>
        </field>
    </record>

    <!-- ── Client action: the Spark-style 3-panel OWL builder.
         Triggered from a per-card button on the kanban; opens with
         ``params={"config_id": <int>}`` or no params for create. -->
    <record id="action_open_builder" model="ir.actions.client">
        <field name="name">Open Workflow Studio</field>
        <field name="tag">dojo_automation_builder</field>
        <field name="target">current</field>
    </record>

    <!-- ── Top-level menu, sibling to CRM / Contacts. -->
    <menuitem id="menu_root"
              name="Care Workflows"
              sequence="55"
              groups="dojo_core.group_dojo_admin,dojo_core.group_dojo_instructor,base.group_system"
              web_icon="dojo_automation,static/description/icon.png"/>

    <menuitem id="menu_automations"
              name="Care Workflows"
              parent="menu_root"
              action="action_dojo_automations"
              groups="dojo_core.group_dojo_admin,dojo_core.group_dojo_instructor,base.group_system"
              sequence="10"/>

    <menuitem id="menu_trigger_templates"
              name="Trigger Templates"
              parent="menu_root"
              groups="dojo_core.group_dojo_admin,base.group_system"
              sequence="80"/>

    <record id="action_trigger_templates" model="ir.actions.act_window">
        <field name="name">Trigger Templates</field>
        <field name="res_model">dojo.automation.trigger.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_trigger_templates_list"
              name="Pre-built Triggers"
              parent="menu_trigger_templates"
              action="action_trigger_templates"
              sequence="10"/>

</odoo>
