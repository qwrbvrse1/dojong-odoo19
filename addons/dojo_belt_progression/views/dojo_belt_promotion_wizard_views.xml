<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_dojo_belt_promotion_wizard_form" model="ir.ui.view">
        <field name="name">dojo.belt.promotion.wizard.form</field>
        <field name="model">dojo.belt.promotion.wizard</field>
        <field name="arch" type="xml">
            <form string="Belt Promotion Wizard">
                <sheet>
                    <group>
                        <field name="test_id" readonly="1"/>
                        <field name="program_id" readonly="1"/>
                    </group>
                    <group string="Candidates">
                        <field name="line_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="do_promote" string="Promote"/>
                                <field name="member_id" readonly="1"/>
                                <field name="current_rank_id" readonly="1"/>
                                <field name="current_stripe_count" readonly="1" string="Current Stripes"/>
                                <field name="target_rank_id"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <footer>
                    <button name="action_promote"
                            string="Apply Promotions"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
