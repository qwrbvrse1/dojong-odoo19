<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        AI Assistant Admin Views
        
        Provides admin interface for:
        - AI Action Log (monitoring/audit)
        - AI Intent Schema (configuration)
        - AI Undo Snapshots (debugging)
    -->

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- AI Action Log Views                                                     -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->

    <record id="view_dojo_ai_action_log_tree" model="ir.ui.view">
        <field name="name">dojo.ai.action.log.tree</field>
        <field name="model">dojo.ai.action.log</field>
        <field name="arch" type="xml">
            <list string="AI Action Logs" decoration-danger="execution_status == 'error'" decoration-warning="confirmation_status == 'rejected'" decoration-muted="undone">
                <field name="timestamp"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="input_text" optional="show"/>
                <field name="intent_type"/>
                <field name="confidence" widget="progressbar"/>
                <field name="role"/>
                <field name="confirmation_status" widget="badge" 
                    decoration-info="confirmation_status == 'pending'"
                    decoration-success="confirmation_status in ('confirmed', 'auto')"
                    decoration-danger="confirmation_status == 'rejected'"/>
                <field name="execution_status" widget="badge"
                    decoration-success="execution_status == 'success'"
                    decoration-danger="execution_status == 'error'"/>
                <field name="execution_time_ms" optional="hide"/>
                <field name="is_undoable" optional="hide"/>
                <field name="undone" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_dojo_ai_action_log_form" model="ir.ui.view">
        <field name="name">dojo.ai.action.log.form</field>
        <field name="model">dojo.ai.action.log</field>
        <field name="arch" type="xml">
            <form string="AI Action Log">
                <header>
                    <field name="confirmation_status" widget="statusbar" statusbar_visible="pending,confirmed,rejected"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_undo_snapshots" type="object" class="oe_stat_button" icon="fa-history"
                            invisible="not is_undoable">
                            <field name="is_undoable" widget="statinfo" string="Undo Data"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Undone" bg_color="text-bg-secondary" invisible="not undone"/>
                    <group>
                        <group string="Request">
                            <field name="session_key"/>
                            <field name="timestamp"/>
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="role"/>
                            <field name="input_type"/>
                            <field name="input_text"/>
                            <field name="audio_attachment_id" invisible="input_type != 'voice'"/>
                        </group>
                        <group string="Intent">
                            <field name="intent_type"/>
                            <field name="confidence" widget="progressbar"/>
                            <field name="parsed_intent"/>
                            <field name="resolved_data"/>
                        </group>
                    </group>
                    <group>
                        <group string="Confirmation">
                            <field name="confirmation_prompt"/>
                            <field name="confirmation_status"/>
                            <field name="confirmed_by" widget="many2one_avatar_user"/>
                            <field name="confirmed_at"/>
                        </group>
                        <group string="Execution">
                            <field name="execution_status"/>
                            <field name="execution_result"/>
                            <field name="error_message"/>
                            <field name="execution_time_ms"/>
                        </group>
                    </group>
                    <group string="Undo" invisible="not is_undoable">
                        <field name="is_undoable"/>
                        <field name="undone"/>
                        <field name="undone_at" invisible="not undone"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_dojo_ai_action_log_search" model="ir.ui.view">
        <field name="name">dojo.ai.action.log.search</field>
        <field name="model">dojo.ai.action.log</field>
        <field name="arch" type="xml">
            <search string="AI Action Logs">
                <field name="input_text"/>
                <field name="intent_type"/>
                <field name="user_id"/>
                <field name="session_key"/>
                <filter name="timestamp" string="Date" date="timestamp"/>
                <separator/>
                <filter name="pending" string="Pending" domain="[('confirmation_status', '=', 'pending')]"/>
                <filter name="confirmed" string="Confirmed" domain="[('confirmation_status', '=', 'confirmed')]"/>
                <filter name="rejected" string="Rejected" domain="[('confirmation_status', '=', 'rejected')]"/>
                <separator/>
                <filter name="success" string="Successful" domain="[('execution_status', '=', 'success')]"/>
                <filter name="error" string="Errors" domain="[('execution_status', '=', 'error')]"/>
                <separator/>
                <filter name="undoable" string="Undoable" domain="[('is_undoable', '=', True)]"/>
                <filter name="undone" string="Undone" domain="[('undone', '=', True)]"/>
                <separator/>
                <filter name="my_actions" string="My Actions" domain="[('user_id', '=', uid)]"/>
                <group>
                    <filter name="group_by_intent" string="Intent" context="{'group_by': 'intent_type'}"/>
                    <filter name="group_by_user" string="User" context="{'group_by': 'user_id'}"/>
                    <filter name="group_by_status" string="Status" context="{'group_by': 'confirmation_status'}"/>
                    <filter name="group_by_date" string="Date" context="{'group_by': 'timestamp:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_dojo_ai_action_log" model="ir.actions.act_window">
        <field name="name">AI Action Log</field>
        <field name="res_model">dojo.ai.action.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_dojo_ai_action_log_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No AI actions recorded yet
            </p>
            <p>
                AI action logs appear here when users interact with the voice assistant.
            </p>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- AI Intent Schema Views                                                  -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->

    <record id="view_dojo_ai_intent_schema_tree" model="ir.ui.view">
        <field name="name">dojo.ai.intent.schema.tree</field>
        <field name="model">dojo.ai.intent.schema</field>
        <field name="arch" type="xml">
            <list string="AI Intent Schemas" editable="bottom"
                  decoration-muted="not active"
                  decoration-danger="error_log_count &gt; 0"
                  decoration-warning="example_count &lt; 5">
                <field name="active" column_invisible="True"/>
                <field name="intent_type"/>
                <field name="name"/>
                <field name="category" optional="show"/>
                <field name="example_count" string="Examples" readonly="1"
                       decoration-danger="example_count &lt; 3"
                       decoration-warning="example_count &lt; 6"/>
                <field name="error_log_count" string="Errors" readonly="1"
                       decoration-danger="error_log_count &gt; 0" optional="show"/>
                <field name="allowed_roles"/>
                <field name="requires_confirmation" widget="boolean_toggle"/>
                <field name="is_undoable" widget="boolean_toggle"/>
                <field name="supports_bulk" widget="boolean_toggle" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_dojo_ai_intent_schema_form" model="ir.ui.view">
        <field name="name">dojo.ai.intent.schema.form</field>
        <field name="model">dojo.ai.intent.schema</field>
        <field name="arch" type="xml">
            <form string="AI Intent Schema">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_error_logs" type="object"
                                class="oe_stat_button" icon="fa-exclamation-triangle"
                                invisible="error_log_count == 0">
                            <field name="error_log_count" widget="statinfo" string="Errors"/>
                        </button>
                        <field name="example_count" invisible="1"/>
                        <button name="action_test_intent" type="object"
                                class="oe_stat_button" icon="fa-flask">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Test Intent</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Intent Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Identification">
                            <field name="intent_type"/>
                            <field name="category"/>
                            <field name="description"/>
                            <field name="active"/>
                        </group>
                        <group string="Permissions">
                            <field name="allowed_roles" placeholder="kiosk,instructor,admin"/>
                        </group>
                    </group>
                    <group>
                        <group string="Behavior">
                            <field name="requires_confirmation"/>
                            <field name="is_undoable"/>
                            <field name="supports_bulk"/>
                        </group>
                        <group string="Confirmation">
                            <field name="confirmation_template" placeholder="Confirm {action} for {member_name}?" invisible="not requires_confirmation"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Parameters Schema" name="parameters">
                            <field name="parameters_schema" widget="ace" options="{'mode': 'json'}"/>
                        </page>
                        <page string="Example Phrases" name="example_phrases">
                            <field name="example_phrases" placeholder="One example phrase per line..."
                                   help="Natural language phrases that should trigger this intent. Used to guide the AI model."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_dojo_ai_intent_schema_search" model="ir.ui.view">
        <field name="name">dojo.ai.intent.schema.search</field>
        <field name="model">dojo.ai.intent.schema</field>
        <field name="arch" type="xml">
            <search string="AI Intent Schemas">
                <field name="name"/>
                <field name="intent_type"/>
                <field name="category"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Archived" domain="[('active', '=', False)]"/>
                <separator/>
                <filter name="requires_confirmation" string="Requires Confirmation" domain="[('requires_confirmation', '=', True)]"/>
                <filter name="undoable" string="Undoable" domain="[('is_undoable', '=', True)]"/>
                <group>
                    <filter name="group_by_category" string="Category" context="{'group_by': 'category'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_dojo_ai_intent_schema" model="ir.actions.act_window">
        <field name="name">AI Intent Schemas</field>
        <field name="res_model">dojo.ai.intent.schema</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_dojo_ai_intent_schema_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define AI intent schemas
            </p>
            <p>
                Intent schemas define what actions the AI assistant can perform,
                their parameters, and required permissions.
            </p>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- AI Undo Snapshot Views                                                  -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->

    <record id="view_dojo_ai_undo_snapshot_tree" model="ir.ui.view">
        <field name="name">dojo.ai.undo.snapshot.tree</field>
        <field name="model">dojo.ai.undo.snapshot</field>
        <field name="arch" type="xml">
            <list string="AI Undo Snapshots" decoration-muted="undo_executed">
                <field name="create_date"/>
                <field name="action_log_id"/>
                <field name="model_name"/>
                <field name="record_id"/>
                <field name="operation"/>
                <field name="undo_expires_at"/>
                <field name="undo_executed"/>
            </list>
        </field>
    </record>

    <record id="view_dojo_ai_undo_snapshot_form" model="ir.ui.view">
        <field name="name">dojo.ai.undo.snapshot.form</field>
        <field name="model">dojo.ai.undo.snapshot</field>
        <field name="arch" type="xml">
            <form string="AI Undo Snapshot">
                <sheet>
                    <group>
                        <group>
                            <field name="action_log_id"/>
                            <field name="model_name"/>
                            <field name="record_id"/>
                            <field name="operation"/>
                        </group>
                        <group>
                            <field name="undo_expires_at"/>
                            <field name="undo_executed"/>
                            <field name="undo_executed_at" invisible="not undo_executed"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Snapshot Data" name="data">
                            <field name="snapshot_data"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dojo_ai_undo_snapshot" model="ir.actions.act_window">
        <field name="name">AI Undo Snapshots</field>
        <field name="res_model">dojo.ai.undo.snapshot</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No undo snapshots
            </p>
            <p>
                Undo snapshots store the state before undoable AI actions,
                allowing users to reverse changes.
            </p>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- Dojo AI Voice Assistant — client action (full-page widget)               -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->

    <record id="action_dojo_voice_assistant_page" model="ir.actions.client">
        <field name="name">AI Voice Assistant</field>
        <field name="tag">dojo_assistant.voice_assistant_page</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- Menu Items                                                              -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- Top-Level App Menu                                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->

    <menuitem id="menu_ai_assistant_root"
        name="AI Assistant"
        sequence="95"
        web_icon="dojo_assistant,static/description/icon.png"
        groups="base.group_user"/>

    <!-- Voice Assistant (dojo AI widget — uses elevenlabs STT + dojo intent AI) -->
    <menuitem id="menu_ai_voice_assistant"
        name="Voice Assistant"
        parent="menu_ai_assistant_root"
        action="action_dojo_voice_assistant_page"
        sequence="5"
        groups="base.group_user"/>

    <!-- Conversation History (dojo AI action log) -->
    <menuitem id="menu_ai_conversation_history"
        name="Conversation History"
        parent="menu_ai_assistant_root"
        action="action_dojo_ai_action_log"
        sequence="10"
        groups="base.group_user"/>

    <!-- Action Log -->
    <menuitem id="menu_ai_action_log"
        name="Action Log"
        parent="menu_ai_assistant_root"
        action="action_dojo_ai_action_log"
        sequence="20"
        groups="dojo_core.group_dojo_admin"/>

    <!-- Configuration submenu -->
    <menuitem id="menu_ai_config"
        name="Configuration"
        parent="menu_ai_assistant_root"
        sequence="90"
        groups="dojo_core.group_dojo_admin"/>

    <menuitem id="menu_ai_intent_schema"
        name="Intent Schemas"
        parent="menu_ai_config"
        action="action_dojo_ai_intent_schema"
        sequence="10"/>

    <menuitem id="menu_ai_undo_snapshots"
        name="Undo Snapshots"
        parent="menu_ai_config"
        action="action_dojo_ai_undo_snapshot"
        sequence="20"/>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- AI Walkie-Talkie — client action (push-to-talk voice page)             -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Raw client action (launched programmatically from action_launch()) -->
    <record id="action_dojo_walkie_talkie" model="ir.actions.client">
        <field name="name">AI Walkie-Talkie</field>
        <field name="tag">dojo_assistant.walkie_talkie</field>
    </record>

    <!-- PROTOTYPE: Channel Beta client action -->
    <record id="action_dojo_walkie_channel" model="ir.actions.client">
        <field name="name">AI Walkie-Talkie — Channel Beta</field>
        <field name="tag">dojo_assistant.walkie_channel</field>
    </record>

    <!-- PROTOTYPE: Elder Beta client action -->
    <record id="action_dojo_walkie_elder" model="ir.actions.client">
        <field name="name">AI Walkie-Talkie — Elder Beta</field>
        <field name="tag">dojo_assistant.walkie_elder</field>
    </record>

    <!-- ── Walkie-Talkie Instance list view ─────────────────────────────── -->
    <record id="view_dojo_walkie_talkie_list" model="ir.ui.view">
        <field name="name">dojo.walkie.talkie.list</field>
        <field name="model">dojo.walkie.talkie</field>
        <field name="arch" type="xml">
            <list string="AI Walkie-Talkies">
                <field name="name"/>
                <field name="mode" widget="badge"
                    decoration-info="mode == 'channel_beta'"
                    decoration-warning="mode == 'elder_beta'"/>
                <field name="walkie_url" widget="url" string="Standalone URL" readonly="1"/>
                <field name="last_used" string="Last Used"/>
                <field name="active"/>
                <button name="action_launch" type="object"
                        string="Launch" icon="fa-podcast"
                        class="btn-primary"/>
            </list>
        </field>
    </record>

    <!-- ── Walkie-Talkie Instance form view ─────────────────────────────── -->
    <record id="view_dojo_walkie_talkie_form" model="ir.ui.view">
        <field name="name">dojo.walkie.talkie.form</field>
        <field name="model">dojo.walkie.talkie</field>
        <field name="arch" type="xml">
            <form string="Walkie-Talkie Station">
                <header>
                    <button name="action_launch" type="object"
                            string="Launch" icon="fa-podcast"
                            class="btn-primary"/>
                    <button name="action_generate_token" type="object"
                            string="Generate Standalone URL" icon="fa-link"
                            class="btn-secondary"
                            confirm="This will replace the current standalone URL. Continue?"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Front Desk, Mat 1"/></h1>
                    </div>
                    <group>
                        <group string="Station Settings">
                            <field name="description" placeholder="Optional description…"/>
                            <field name="mode"
                                   help="Default: original walkie-talkie. Channel Beta / Elder Beta are prototypes — do not use in production."/>
                            <field name="stt_language"
                                   help="Language used for speech-to-text on the standalone URL. Backend users use their Odoo language preference instead."/>
                            <field name="active"/>
                            <field name="last_used" readonly="1"/>
                        </group>
                        <group string="Access Control">
                            <field name="walkie_pin"
                                   password="True"
                                   placeholder="e.g. 1234"
                                   help="PIN required to access this station on the standalone URL. Set by admin."/>
                        </group>
                    </group>
                    <div class="alert alert-warning" role="alert"
                         invisible="mode == 'default'">
                        <strong>Prototype Mode:</strong> Channel Beta and Elder Beta are experimental prototypes
                        being tested with martial arts data. They are not production-ready.
                    </div>
                    <group string="Discuss Integration"
                           invisible="mode == 'default'">
                        <field name="discuss_post_as_id"
                               help="Voice messages from the standalone URL will be posted as this contact. If blank, defaults to OdooBot."/>
                        <field name="channel_mapping_ids" nolabel="1"
                               invisible="mode not in ('channel_beta', 'elder_beta')">
                            <list editable="bottom">
                                <field name="channel_type"/>
                                <field name="discuss_channel_id"/>
                            </list>
                        </field>
                        <div class="text-muted" invisible="mode not in ('channel_beta', 'elder_beta')">
                            Map each AI channel to a Discuss channel. Voice messages and AI responses
                            will be posted automatically. Create channels in Discuss first, then select them here.
                        </div>
                    </group>
                    <group string="Standalone URL" invisible="not walkie_token">
                        <field name="walkie_url" widget="url" readonly="1"
                               help="Open on any device — no Odoo login required. Keep this link private."/>
                        <field name="walkie_token" readonly="1"
                               help="Unique token embedded in the standalone URL."/>
                    </group>
                    <div class="alert alert-info" role="alert" invisible="walkie_token">
                        Click <strong>Generate Standalone URL</strong> to create a unique link
                        that instructors can open on any device — no Odoo login required.
                        Set an <strong>Access PIN</strong> to restrict who can use it.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Walkie-Talkie list window action ─────────────────────────────── -->
    <record id="action_dojo_walkie_talkie_list" model="ir.actions.act_window">
        <field name="name">AI Walkie-Talkies</field>
        <field name="res_model">dojo.walkie.talkie</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Walkie-Talkie station
            </p>
            <p>
                Each station gets its own conversation context window.
                Admins create stations; instructors click <strong>Launch</strong> to open them.
            </p>
        </field>
    </record>

    <menuitem id="menu_ai_walkie_talkie"
        name="Walkie-Talkies"
        parent="menu_ai_assistant_root"
        action="action_dojo_walkie_talkie_list"
        sequence="7"
        groups="dojo_core.group_dojo_instructor,dojo_core.group_dojo_admin"/>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- AI Assistant — Settings tile (Settings → AI Assistant)                -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <record id="res_config_settings_view_dojo_assistant" model="ir.ui.view">
        <field name="name">res.config.settings.view.dojo.assistant</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <div class="app_settings_block"
                     data-string="AI Assistant"
                     string="AI Assistant"
                     data-key="dojo_assistant">

                    <h2>AI Assistant Settings</h2>

                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <span class="fa fa-comments fa-2x text-primary"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="ai_context_window_turns"
                                       string="Context Window (turns)"/>
                                <div class="text-muted">
                                    Number of previous conversation turns sent to the AI
                                    with each request. 1 turn = one user message + one AI reply.
                                    Higher values give the AI more context but use more tokens.
                                    Allowed range: 1–50. Default: 10.
                                </div>
                                <div class="content-group mt8">
                                    <field name="ai_context_window_turns"/>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </xpath>
        </field>
    </record>

</odoo>
