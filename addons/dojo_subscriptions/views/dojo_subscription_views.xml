<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Remove legacy view that added billing_partner_id (field now removed) -->
    <delete model="ir.ui.view" search="[('name', '=', 'dojo.household.form.billing')]"/>

    <record id="action_dojo_subscription_plans" model="ir.actions.act_window">
        <field name="name">Subscription Plans</field>
        <field name="res_model">dojo.subscription.plan</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_dojo_member_subscriptions" model="ir.actions.act_window">
        <field name="name">Member Subscriptions</field>
        <field name="res_model">dojo.member.subscription</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_dojo_subscriptions_root"
        name="Subscriptions"
        sequence="40"
        web_icon="dojo_subscriptions,static/description/icon.png"
    />
    <menuitem
        id="menu_dojo_member_subscriptions"
        name="Member Subscriptions"
        parent="menu_dojo_subscriptions_root"
        action="action_dojo_member_subscriptions"
        sequence="10"
    />
    <menuitem
        id="menu_dojo_subscription_plans"
        name="Subscription Plans"
        parent="menu_dojo_subscriptions_root"
        action="action_dojo_subscription_plans"
        sequence="20"
    />



    <record id="view_dojo_subscription_plan_list" model="ir.ui.view">
        <field name="name">dojo.subscription.plan.list</field>
        <field name="model">dojo.subscription.plan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="plan_type"/>
                <field name="program_id"/>
                <field name="price"/>
                <field name="initial_fee"/>
                <field name="billing_period"/>
                <field name="duration" string="Duration (mo)"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_dojo_subscription_plan_form" model="ir.ui.view">
        <field name="name">dojo.subscription.plan.form</field>
        <field name="model">dojo.subscription.plan</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="plan_type" widget="radio"/>
                        <field name="program_id"
                               invisible="plan_type != 'program'"
                               required="plan_type == 'program'"/>
                        <field name="price"/>
                        <field name="initial_fee"/>
                        <field name="currency_id"/>
                        <field name="billing_period"/>
                        <field name="duration"
                               string="Duration (Months)"
                               help="Fixed membership length in months. 0 = ongoing (no fixed end date)."/>
                        <field name="active"/>
                    </group>
                    <group string="Session Restrictions"
                          invisible="plan_type != 'course'">
                        <field name="allowed_template_ids"
                               widget="many2many_tags"
                               placeholder="Leave empty to allow all courses in the program…"/>
                        <div class="alert alert-info small py-1 px-2"
                             invisible="not allowed_template_ids"
                             colspan="2" role="alert">
                            <b>Enrollment rules enforced on save:</b>
                            <ul class="mb-0 mt-1">
                                <li>Members may only enrol in sessions for the listed courses.</li>
                            </ul>
                        </div>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                    <group string="Billing Behaviour">
                        <field name="auto_send_invoice"
                               help="When on, Odoo emails the invoice PDF to the billing partner every time an invoice is generated by the cron or manually."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_dojo_member_subscription_list" model="ir.ui.view">
        <field name="name">dojo.member.subscription.list</field>
        <field name="model">dojo.member.subscription</field>
        <field name="arch" type="xml">
            <list>
                <field name="member_id"/>
                <field name="plan_id"/>
                <field name="plan_type"/>
                <field name="program_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="next_billing_date"/>
                <field name="state"/>
                <field name="billing_failure_count" string="Failures" optional="show"
                       decoration-danger="billing_failure_count >= 3"
                       decoration-warning="billing_failure_count == 2"/>
            </list>
        </field>
    </record>

    <record id="view_dojo_member_subscription_form" model="ir.ui.view">
        <field name="name">dojo.member.subscription.form</field>
        <field name="model">dojo.member.subscription</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_set_active"
                            type="object"
                            string="Set Active"
                            class="btn-success"
                            invisible="state == 'active'"
                            confirm="Activate this subscription? Credits will be issued immediately."/>
                    <button name="action_set_pending"
                            type="object"
                            string="Set Pending"
                            invisible="state in ('pending', 'cancelled', 'expired')"/>
                    <button name="action_set_paused"
                            type="object"
                            string="Pause"
                            invisible="state != 'active'"/>
                    <button name="action_set_cancelled"
                            type="object"
                            string="Cancel"
                            invisible="state in ('cancelled', 'expired')"
                            confirm="Cancel this subscription? This cannot be easily undone."/>
                    <button name="action_set_draft"
                            type="object"
                            string="Reset to Draft"
                            invisible="state not in ('pending', 'cancelled')"/>
                    <button name="action_generate_invoice"
                            type="object"
                            string="Generate Invoice"
                            class="btn-primary"
                            invisible="state not in ('active', 'pending')"
                            groups="account.group_account_invoice"
                            confirm="This will create and post an invoice for the current billing cycle and advance the next billing date. Continue?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,pending,active,paused,cancelled"/>
                </header>
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button name="action_view_invoices"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-text-o"
                                groups="account.group_account_invoice">
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="invoice_count"/></span>
                                <span class="o_stat_text">Invoices</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <field name="member_id"/>
                        <field name="plan_id"/>
                        <field name="plan_type" readonly="1"/>
                        <field name="program_id" readonly="1"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="next_billing_date"/>
                        <field name="last_invoice_id" groups="account.group_account_invoice"/>
                        <field name="billing_reference"/>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                    <!-- Dunning / billing failures – hidden when all is well -->
                    <group string="Billing Issues"
                           name="billing_issues_group"
                           invisible="billing_failure_count == 0">
                        <group>
                            <field name="billing_failure_count" readonly="1"
                                   widget="integer"
                                   string="Consecutive Failures"/>
                            <field name="last_billing_failure_date" readonly="1"/>
                            <field name="grace_period_end" readonly="1"
                                   invisible="billing_failure_count &lt; 3"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_dojo_member_subscription_search" model="ir.ui.view">
        <field name="name">dojo.member.subscription.search</field>
        <field name="model">dojo.member.subscription</field>
        <field name="arch" type="xml">
            <search>
                <field name="member_id" string="Member"/>
                <field name="plan_id" string="Plan"/>
                <separator/>
                <filter name="active_subs" string="Active"
                        domain="[('state', '=', 'active')]"/>
                <filter name="paused_subs" string="Paused"
                        domain="[('state', '=', 'paused')]"/>
                <filter name="in_grace_period" string="In Grace Period"
                        domain="[('billing_failure_count', '&gt;=', 3), ('state', '!=', 'expired')]"/>
                <filter name="has_failures" string="Has Billing Failures"
                        domain="[('billing_failure_count', '&gt;', 0)]"/>
                <group>
                    <filter name="group_state" string="State"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_plan" string="Plan"
                            context="{'group_by': 'plan_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Plans count column injected into Program list ─────────────── -->
    <record id="view_dojo_program_list_subscription_inherit" model="ir.ui.view">
        <field name="name">dojo.program.list.subscription.inherit</field>
        <field name="model">dojo.program</field>
        <field name="inherit_id" ref="dojo_classes.view_dojo_program_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='active']" position="before">
                <field name="plan_count" string="Plans"/>
            </xpath>
        </field>
    </record>

    <!-- ── Plans stat button + tab injected into Program form ─────────── -->
    <record id="view_dojo_program_form_subscription_inherit" model="ir.ui.view">
        <field name="name">dojo.program.form.subscription.inherit</field>
        <field name="model">dojo.program</field>
        <field name="inherit_id" ref="dojo_classes.view_dojo_program_form"/>
        <field name="arch" type="xml">
            <!-- Plans stat button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_plans"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-credit-card">
                    <div class="o_stat_info">
                        <span class="o_stat_value"><field name="plan_count"/></span>
                        <span class="o_stat_text">Plans</span>
                    </div>
                </button>
            </xpath>
            <!-- Subscription Plans tab -->
            <xpath expr="//notebook" position="inside">
                <page string="Subscription Plans" name="plans">
                    <field name="plan_ids">
                        <list>
                            <field name="name"/>
                            <field name="plan_type"/>
                            <field name="price"/>
                            <field name="billing_period"/>
                            <field name="active"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ── Subscription smart button + tab injected into Member form ──── -->
    <record id="view_dojo_member_form_subscription_inherit" model="ir.ui.view">
        <field name="name">dojo.member.form.subscription.inherit</field>
        <field name="model">dojo.member</field>
        <field name="inherit_id" ref="dojo_base.view_dojo_member_form"/>
        <field name="arch" type="xml">
            <!-- Smart button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_member_subscriptions"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-credit-card">
                    <div class="o_stat_info">
                        <span class="o_stat_value"><field name="subscription_count"/></span>
                        <span class="o_stat_text">Subscriptions</span>
                    </div>
                </button>
            </xpath>
            <!-- Subscriptions tab -->
            <xpath expr="//notebook" position="inside">
                <page string="Subscriptions" name="subscriptions">
                    <group>
                        <field name="active_subscription_id" readonly="1"
                               options="{'no_open': False}"/>
                    </group>
                    <field name="subscription_ids" readonly="1">
                        <list>
                            <field name="plan_id"/>
                            <field name="start_date"/>
                            <field name="next_billing_date"/>
                            <field name="state"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
