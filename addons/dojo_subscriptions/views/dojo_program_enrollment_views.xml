<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── List view ──────────────────────────────────────────────────── -->
    <record id="view_dojo_program_enrollment_list" model="ir.ui.view">
        <field name="name">dojo.program.enrollment.list</field>
        <field name="model">dojo.program.enrollment</field>
        <field name="arch" type="xml">
            <list decoration-muted="not is_active">
                <field name="member_id"/>
                <field name="program_id"/>
                <field name="is_active" widget="boolean_toggle" string="Active"/>
                <field name="enrolled_date"/>
                <field name="deactivated_date" optional="show"/>
                <field name="subscription_id" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ── Form view ─────────────────────────────────────────────────── -->
    <record id="view_dojo_program_enrollment_form" model="ir.ui.view">
        <field name="name">dojo.program.enrollment.form</field>
        <field name="model">dojo.program.enrollment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="member_id"/>
                            <field name="program_id"/>
                            <field name="subscription_id"/>
                        </group>
                        <group>
                            <field name="is_active"/>
                            <field name="enrolled_date"/>
                            <field name="deactivated_date"
                                   invisible="is_active"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Optional notes…"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Search view ───────────────────────────────────────────────── -->
    <record id="view_dojo_program_enrollment_search" model="ir.ui.view">
        <field name="name">dojo.program.enrollment.search</field>
        <field name="model">dojo.program.enrollment</field>
        <field name="arch" type="xml">
            <search>
                <field name="member_id" string="Member"/>
                <field name="program_id" string="Program"/>
                <separator/>
                <filter name="active_only" string="Active"
                        domain="[('is_active', '=', True)]"/>
                <filter name="inactive_only" string="Inactive / Previous"
                        domain="[('is_active', '=', False)]"/>
                <group>
                    <filter name="group_program" string="Program"
                            context="{'group_by': 'program_id'}"/>
                    <filter name="group_member" string="Member"
                            context="{'group_by': 'member_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Window action ─────────────────────────────────────────────── -->
    <record id="action_dojo_program_enrollments" model="ir.actions.act_window">
        <field name="name">Program Enrollments</field>
        <field name="res_model">dojo.program.enrollment</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active_only': 1}</field>
    </record>

    <!-- ── Menu item (under Subscriptions root) ──────────────────────── -->
    <menuitem
        id="menu_dojo_program_enrollments"
        name="Program Enrollments"
        parent="menu_dojo_subscriptions_root"
        action="action_dojo_program_enrollments"
        sequence="30"
    />

    <!-- ── Program Enrollment tab injected into Member form ──────────── -->
    <record id="view_dojo_member_form_program_enrollment_inherit" model="ir.ui.view">
        <field name="name">dojo.member.form.program.enrollment.inherit</field>
        <field name="model">dojo.member</field>
        <field name="inherit_id" ref="dojo_base.view_dojo_member_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Programs" name="program_enrollments">
                    <field name="program_enrollment_ids">
                        <list decoration-muted="not is_active" editable="bottom">
                            <field name="program_id"/>
                            <field name="is_active" widget="boolean_toggle" string="Active"/>
                            <field name="enrolled_date"/>
                            <field name="deactivated_date" optional="show"
                                   invisible="is_active"/>
                            <field name="subscription_id" readonly="1" optional="show"/>
                            <field name="notes" optional="hide"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
