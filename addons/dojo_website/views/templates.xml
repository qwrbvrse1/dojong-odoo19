    <!-- ═══════════════════════════════════════════
         CONTACT PAGE
    ═══════════════════════════════════════════ -->
    <template id="contact" name="Dojo Contact">
        <t t-call="website.layout">
            <div id="wrap" class="dojo-page">
                <div class="dj-page-hero">
                    <div class="dj-container">
                        <p class="dj-eyebrow" style="color:#F39C12">We'd Love to Hear From You</p>
                        <h1>Contact Us</h1>
                        <p>Have a question or want to schedule a free trial? Reach out — we're happy to help!</p>
                    </div>
                </div>
                <section class="dj-section">
                    <div class="dj-container">
                        <div class="dj-contact-grid">
                            <div class="dj-contact-info">
                                <h2>Get in <span>Touch</span></h2>
                                <p>Whether you're ready to enroll or have questions — we're here for you. Reach us by phone, email, or stop by the dojang!</p>
                                <div class="dj-info-cards">
                                    <div class="dj-info-card">
                                        <div class="dj-info-icon"><i class="fa fa-map-marker-alt"/></div>
                                        <div><h4>Our Location</h4><p>123 Main Street, Suite 100<br/>Your City, State 00000</p></div>
                                    </div>
                                    <div class="dj-info-card">
                                        <div class="dj-info-icon"><i class="fa fa-phone"/></div>
                                        <div><h4>Call Us</h4><a href="tel:+15550000000">(555) 000-0000</a></div>
                                    </div>
                                    <div class="dj-info-card">
                                        <div class="dj-info-icon"><i class="fa fa-envelope"/></div>
                                        <div><h4>Email Us</h4><a href="mailto:info@dragonpeaktkd.com">info@dragonpeaktkd.com</a></div>
                                    </div>
                                </div>
                                <div class="dj-hours-card">
                                    <h4>School Hours</h4>
                                    <div class="dj-hours-row"><span>Monday – Friday</span><span>1:00 PM – 8:00 PM</span></div>
                                    <div class="dj-hours-row"><span>Saturday</span><span>10:30 AM – 1:30 PM</span></div>
                                    <div class="dj-hours-row dj-closed"><span>Sunday</span><span>Closed</span></div>
                                </div>
                            </div>
                            <div class="dj-form-wrap">
                                <form class="dj-trial-form"
                                      action="/trial/submit"
                                      method="post">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="success_url" value="/thank-you"/>
                                    <input type="hidden" name="error_url" value="/contact"/>
                                    <h3>Book Your Free Trial</h3>
                                    <div class="dj-form-group">
                                        <label for="c_name">Full Name *</label>
                                        <input class="form-control" type="text" id="c_name" name="name" placeholder="Jane Smith" required="required" autocomplete="name"/>
                                    </div>
                                    <div class="dj-form-row">
                                        <div class="dj-form-group">
                                            <label for="c_email">Email *</label>
                                            <input class="form-control" type="email" id="c_email" name="email" placeholder="jane@example.com" required="required" autocomplete="email"/>
                                        </div>
                                        <div class="dj-form-group">
                                            <label for="c_phone">Phone *</label>
                                            <input class="form-control" type="tel" id="c_phone" name="phone" placeholder="(555) 123-4567" required="required" autocomplete="tel"/>
                                        </div>
                                    </div>
                                    <div class="dj-form-group">
                                        <label for="c_discipline">Program Interest</label>
                                        <t t-set="programs" t-value="request.env['dojo.program'].sudo().search([('active','=',True),('is_trial','=',False)])"/>
                                        <select class="form-select" id="c_discipline" name="discipline">
                                            <option value="">&#x2014; Select a program &#x2014;</option>
                                            <t t-foreach="programs" t-as="prog">
                                                <option t-att-value="prog.name" t-out="prog.name"/>
                                            </t>
                                        </select>
                                    </div>
                                    <div class="dj-form-group">
                                        <label for="c_message">Anything else? (optional)</label>
                                        <textarea class="form-control" id="c_message" name="message" rows="2" placeholder="Age, experience level, questions…"/>
                                    </div>
                                    <button type="submit" class="dj-btn dj-btn-primary dj-btn-block">
                                        Request My Free Trial <i class="fa fa-arrow-right"/>
                                    </button>
                                    <p class="dj-form-note"><i class="fa fa-lock"/> We'll email you a link to pick your class time. No commitment.</p>
                                </form>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <!-- ═══════════════════════════════════════════
         THANK YOU PAGE (after form submission)
    ═══════════════════════════════════════════ -->
    <template id="thank_you" name="Dojo Thank You">
        <t t-call="website.layout">
            <div id="wrap" class="dojo-page">
                <div class="dj-thankyou-section">
                    <div class="dj-container" style="text-align:center">
                        <div class="dj-success-icon"><i class="fa fa-check-circle"/></div>
                        <h1>You're All Set!</h1>
                        <p>Thanks for reaching out! We'll contact you within 24 hours to confirm your free trial class. We can't wait to meet you and your family!</p>
                        <a href="/" class="dj-btn dj-btn-primary" style="margin-top:2rem">Back to Home</a>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
