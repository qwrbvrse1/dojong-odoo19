<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- noupdate="0" so the homepage URL is always enforced on upgrade -->
    <data noupdate="0">
        <record id="page_dojo_home" model="website.page">
            <field name="view_id" ref="home"/>
            <field name="url">/</field>
            <field name="website_published">True</field>
            <field name="is_homepage">True</field>
        </record>
    </data>

    <data noupdate="1">

        <record id="page_dojo_programs" model="website.page">
            <field name="view_id" ref="programs"/>
            <field name="url">/programs</field>
            <field name="website_published">True</field>
        </record>

        <record id="page_dojo_about" model="website.page">
            <field name="view_id" ref="about"/>
            <field name="url">/about</field>
            <field name="website_published">True</field>
        </record>

        <record id="page_dojo_contact" model="website.page">
            <field name="view_id" ref="contact"/>
            <field name="url">/contact</field>
            <field name="website_published">True</field>
        </record>

        <record id="page_dojo_thank_you" model="website.page">
            <field name="view_id" ref="thank_you"/>
            <field name="url">/thank-you</field>
            <field name="website_published">True</field>
        </record>

    </data>
</odoo>
