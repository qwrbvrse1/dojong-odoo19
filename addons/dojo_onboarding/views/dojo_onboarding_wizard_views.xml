<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ── Onboarding Wizard Form View ──────────────────────────────────── -->
    <record id="view_dojo_onboarding_wizard_form" model="ir.ui.view">
        <field name="name">dojo.onboarding.wizard.form</field>
        <field name="model">dojo.onboarding.wizard</field>
        <field name="arch" type="xml">
            <form string="Member Onboarding">

                <!-- Progress header: Guardian Phase -->
                <div class="alert alert-info py-2 mb-3 mx-3" role="status"
                     invisible="wizard_phase != 'guardian'">
                    <span invisible="step != 'guardian_contact'">
                        <b>Step 1:</b> Guardian Contact  ›  Household  ›  Guardian Portal
                    </span>
                    <span invisible="step != 'household'">
                        ✓ Guardian Contact  ›  <b>Step 2: Household</b>  ›  Guardian Portal
                    </span>
                    <span invisible="step != 'guardian_portal'">
                        ✓ Guardian Contact  ›  ✓ Household  ›  <b>Step 3: Guardian Portal</b>
                    </span>
                </div>

                <!-- Progress header: Student Phase -->
                <div class="alert alert-primary py-2 mb-3 mx-3" role="status"
                     invisible="wizard_phase != 'student'">
                    <span invisible="step != 'student_contact'">
                        <b>Step 1:</b> Student Contact  ›  Details  ›  Enrollment  ›  Subscription  ›  Portal  ›  Summary
                    </span>
                    <span invisible="step != 'member_details'">
                        ✓ Student Contact  ›  <b>Step 2: Details</b>  ›  Enrollment  ›  Subscription  ›  Portal  ›  Summary
                    </span>
                    <span invisible="step != 'enrollment'">
                        ✓ Student Contact  ›  ✓ Details  ›  <b>Step 3: Enrollment</b>  ›  Subscription  ›  Portal  ›  Summary
                    </span>
                    <span invisible="step != 'auto_enroll'">
                        ✓ Student Contact  ›  ✓ Details  ›  ✓ Enrollment  ›  <b>Step 3b: Auto-Enroll</b>  ›  Subscription  ›  Portal  ›  Summary
                    </span>
                    <span invisible="step != 'subscription'">
                        ✓ Student Contact  ›  ✓ Details  ›  ✓ Enrollment  ›  <b>Step 4: Subscription</b>  ›  Portal  ›  Summary
                    </span>
                    <span invisible="step != 'student_portal'">
                        ✓ Student Contact  ›  ✓ Details  ›  ✓ Enrollment  ›  ✓ Subscription  ›  <b>Step 5: Portal</b>  ›  Summary
                    </span>
                    <span invisible="step != 'summary'">
                        ✓ Student Contact  ›  ✓ Details  ›  ✓ Enrollment  ›  ✓ Subscription  ›  ✓ Portal  ›  <b>Summary</b>
                    </span>
                </div>

                <field name="step" invisible="1"/>
                <field name="wizard_phase" invisible="1"/>
                <field name="created_household_id" invisible="1"/>
                <field name="created_guardian_partner_id" invisible="1"/>

                <!-- ══════════════════════════════════════════════════════════ -->
                <!-- GUARDIAN PHASE                                           -->
                <!-- ══════════════════════════════════════════════════════════ -->

                <!-- ── Step 1: Guardian Contact ──────────────────────────── -->
                <group string="Guardian / Account Holder" invisible="step != 'guardian_contact'">
                    <!-- Existing household shortcut -->
                    <group colspan="2">
                        <field name="use_existing_household"
                               widget="boolean_toggle"
                               string="Join Existing Household"/>
                    </group>
                    <group invisible="not use_existing_household" colspan="2">
                        <field name="household_id"
                               string="Existing Household *"
                               placeholder="Search for an existing household"/>
                    </group>
                    <div class="alert alert-info py-2 px-3" colspan="2"
                         invisible="not use_existing_household" role="alert">
                        <i class="fa fa-info-circle me-2" title="Info"/>
                        The guardian from this household will be used as the account holder.
                        You'll proceed directly to registering students.
                    </div>
                    <!-- New guardian fields (hidden when joining existing household) -->
                    <group invisible="use_existing_household">
                        <field name="guardian_name" string="Full Name *" placeholder="Full name"/>
                        <field name="guardian_email" string="Email *" placeholder="email@example.com"/>
                        <field name="guardian_phone" string="Phone *" placeholder="e.g. +1 555 000 0000"/>
                    </group>
                    <group invisible="use_existing_household">
                        <field name="guardian_street" placeholder="Street address"/>
                        <field name="guardian_street2" placeholder="Apt, suite, etc."/>
                        <field name="guardian_city" placeholder="City"/>
                        <field name="guardian_state_id" placeholder="State / Province"/>
                        <field name="guardian_zip" placeholder="ZIP / Postal code"/>
                        <field name="guardian_country_id" placeholder="Country"/>
                    </group>
                    <group colspan="2" invisible="use_existing_household">
                        <field name="guardian_is_also_student"
                               widget="boolean_toggle"
                               help="Check this if the guardian also trains at the dojo — they will be registered as a student after the first student."/>
                    </group>
                </group>

                <!-- ── Step 2: Household ────────────────────────────────── -->
                <group string="Household" invisible="step != 'household'">
                    <group>
                        <field name="new_household_name"
                               placeholder="Auto-generated from guardian name if left blank"/>
                    </group>
                    <div class="alert alert-info py-2 px-3" colspan="2" role="alert">
                        <i class="fa fa-home me-2" title="Household"/>
                        A new household will be created for <b><field name="guardian_name" readonly="1" nolabel="1"/></b>.
                    </div>
                </group>

                <!-- ── Step 3: Guardian Portal ──────────────────────────── -->
                <group string="Guardian Portal Access" name="group_guardian_portal" invisible="step != 'guardian_portal'">
                    <group>
                        <field name="create_guardian_portal_login"/>
                        <field name="send_guardian_welcome_email"
                               invisible="not create_guardian_portal_login"/>
                        <field name="send_guardian_welcome_sms"
                               invisible="not create_guardian_portal_login"/>
                    </group>
                    <div class="alert alert-info" invisible="not create_guardian_portal_login"
                         colspan="2" role="alert">
                        A portal account will be created for
                        <b><field name="guardian_name" readonly="1" nolabel="1"/></b>
                        using their email as the login. Guardians can view household info,
                        track attendance, and manage billing online.
                    </div>
                </group>

                <!-- ══════════════════════════════════════════════════════════ -->
                <!-- STUDENT PHASE                                            -->
                <!-- ══════════════════════════════════════════════════════════ -->

                <!-- Student count badge -->
                <div class="alert alert-light py-1 px-3 mx-3 mb-2 d-flex justify-content-between align-items-center"
                     invisible="wizard_phase != 'student'" role="status">
                    <span>
                        <i class="fa fa-home me-1" title="Household"/>
                        Household: <b><field name="created_household_id" readonly="1" nolabel="1"/></b>
                    </span>
                    <span class="badge bg-info">
                        <field name="students_created_ids" widget="many2many_tags" readonly="1" nolabel="1"/>
                    </span>
                </div>

                <!-- ── Step 4: Student Contact ──────────────────────────── -->
                <group string="Student Contact Information" invisible="step != 'student_contact'">
                    <group>
                        <field name="student_name" string="Full Name *" placeholder="Full name"/>
                        <field name="student_email" string="Email" placeholder="email@example.com"/>
                        <field name="student_phone" string="Phone" placeholder="e.g. +1 555 000 0000"/>
                    </group>
                    <group>
                        <field name="student_date_of_birth"/>
                        <field name="student_is_minor" widget="boolean_toggle"/>
                    </group>
                </group>

                <!-- ── Step 5: Member Details ───────────────────────────── -->
                <group string="Member Details" invisible="step != 'member_details'">
                    <group colspan="2">
                        <field name="emergency_note"
                               placeholder="Allergies, medical conditions, emergency notes…"
                               widget="text"/>
                    </group>
                </group>

                <!-- ── Step 6: Enrollment ───────────────────────────────── -->
                <group string="Program Enrollment" invisible="step != 'enrollment'">
                    <group>
                        <field name="program_id"
                               string="Program *"
                               placeholder="Select a program…"/>
                    </group>
                    <div class="alert alert-warning py-2 px-3" invisible="program_id"
                         colspan="2" role="alert">
                        <i class="fa fa-exclamation-circle me-2" title="Warning"/>
                        A program is required to continue.
                    </div>
                    <div class="alert alert-info py-2 px-3" invisible="not program_id"
                         colspan="2" role="alert">
                        <i class="fa fa-info-circle me-2" title="Info"/>
                        Select the class rosters this student attends. Once rosters are chosen,
                        you can optionally pre-register them in specific upcoming sessions.
                    </div>
                    <group colspan="2" invisible="not program_id">
                        <field name="template_ids" widget="many2many_tags"
                               string="Classes *"
                               domain="[('program_id', '=', program_id)]"
                               placeholder="Add to class rosters for this program…"/>
                    </group>
                    <group colspan="2" invisible="not template_ids">
                        <field name="session_ids" widget="many2many_tags"
                               string="Specific Sessions"
                               domain="[('state', '=', 'open'), ('template_id', 'in', template_ids)]"
                               placeholder="Optionally pick specific upcoming sessions…"/>
                    </group>
                </group>

                <!-- ── Step 7: Auto-Enroll ──────────────────────────────── -->
                <group string="Auto-Enroll Schedule" invisible="step != 'auto_enroll'">
                    <div class="alert alert-info small py-1 px-2 mb-2" colspan="2" role="alert">
                        <i class="fa fa-calendar-check-o me-1" title="Schedule"/>
                        The system can automatically enroll this student into recurring sessions.
                        Choose which days of the week they are available.
                    </div>
                    <group>
                        <field name="auto_enroll_active" widget="boolean_toggle"
                               string="Enable Auto-Enroll"/>
                        <field name="auto_enroll_mode" invisible="not auto_enroll_active"/>
                    </group>
                    <group string="Preferred Days" invisible="not auto_enroll_active">
                        <group>
                            <field name="auto_enroll_mon"/>
                            <field name="auto_enroll_tue"/>
                            <field name="auto_enroll_wed"/>
                            <field name="auto_enroll_thu"/>
                        </group>
                        <group>
                            <field name="auto_enroll_fri"/>
                            <field name="auto_enroll_sat"/>
                            <field name="auto_enroll_sun"/>
                        </group>
                    </group>
                    <group string="Date Range"
                           invisible="not auto_enroll_active or auto_enroll_mode != 'multiday'">
                        <field name="auto_enroll_date_from" string="From *"/>
                        <field name="auto_enroll_date_to" string="To *"/>
                    </group>
                </group>

                <!-- ── Step 8: Subscription ─────────────────────────────── -->
                <group string="Subscription Plan" invisible="step != 'subscription'">
                    <group>
                        <field name="plan_id"
                               string="Subscription Plan *"
                               domain="['|', '&amp;', ('plan_type', '=', 'program'), ('program_id', '=', program_id), ('plan_type', '=', 'course')]"
                               placeholder="Select a subscription plan…"/>
                        <field name="subscription_start_date" invisible="not plan_id"/>
                    </group>
                    <div class="alert alert-warning py-2 px-3" invisible="plan_id"
                         colspan="2" role="alert">
                        <i class="fa fa-exclamation-circle me-2" title="Warning"/>
                        A subscription plan is required to continue.
                    </div>
                    <group string="Billing Summary" invisible="not plan_id" colspan="2">
                        <field name="plan_currency_id" invisible="1"/>
                        <field name="plan_initial_fee"
                               widget="monetary"
                               options="{'currency_field': 'plan_currency_id'}"
                               readonly="1"/>
                        <field name="plan_price"
                               widget="monetary"
                               options="{'currency_field': 'plan_currency_id'}"
                               readonly="1"/>
                        <field name="plan_billing_period" readonly="1"/>
                        <field name="plan_credits_per_period" readonly="1"
                               invisible="plan_credits_per_period == 0"
                               string="Credits / Billing Cycle"/>
                        <div class="text-muted small" invisible="plan_credits_per_period != 0" colspan="2">
                            <b>Credits / Billing Cycle:</b> Unlimited
                        </div>
                        <field name="plan_description" readonly="1" widget="text"
                               invisible="not plan_description"/>
                    </group>
                    <group colspan="2" invisible="not plan_id">
                        <field name="defer_payment" widget="boolean_toggle"
                               string="Pay Later (create as pending)"/>
                    </group>
                </group>

                <!-- ── Step 9: Student Portal ───────────────────────────── -->
                <group string="Student Portal Access" name="group_student_portal" invisible="step != 'student_portal'">
                    <group>
                        <field name="create_portal_login"/>
                        <field name="send_welcome_email" invisible="not create_portal_login"/>
                        <field name="send_welcome_sms" invisible="not create_portal_login"/>
                    </group>
                    <div class="alert alert-info" invisible="not create_portal_login"
                         colspan="2" role="alert">
                        A portal account will be created for
                        <b><field name="student_name" readonly="1" nolabel="1"/></b>
                        using their email as the login.
                    </div>
                    <div class="alert alert-warning" invisible="create_portal_login"
                         colspan="2" role="alert">
                        No portal login will be created. They cannot log in until
                        a user account is linked manually.
                    </div>
                </group>

                <!-- ── Step 10: Summary ─────────────────────────────────── -->
                <group string="Registration Summary" invisible="step != 'summary'">
                    <div class="alert alert-success py-3 px-4" colspan="2" role="status">
                        <h4><i class="fa fa-check-circle me-2" title="Success"/>Student Registered</h4>
                        <p class="mb-1">
                            <b><field name="student_name" readonly="1" nolabel="1"/></b>
                            has been registered successfully.
                        </p>
                        <p class="mb-0 text-muted">
                            You can register another student in this household or finish the onboarding.
                        </p>
                    </div>
                    <group string="Students Registered So Far" colspan="2">
                        <field name="students_created_ids" widget="many2many_tags"
                               readonly="1" nolabel="1" colspan="2"/>
                    </group>
                </group>

                <!-- ── Footer navigation ────────────────────────────────── -->
                <footer>
                    <!-- Guardian contact with existing household → skip to students -->
                    <button name="action_next" type="object"
                            string="Continue to Students →"
                            class="btn btn-primary"
                            invisible="step != 'guardian_contact' or not use_existing_household"/>
                    <!-- Guardian phase: Next (new guardian flow) -->
                    <button name="action_next" type="object" string="Next →"
                            class="btn btn-primary"
                            invisible="wizard_phase != 'guardian' or step in ('guardian_portal', 'payment') or use_existing_household"/>
                    <!-- Guardian phase: Create Guardian &amp; Continue -->
                    <button name="action_next" type="object"
                            string="Create Guardian &amp; Continue to Students →"
                            class="btn btn-primary"
                            invisible="step != 'guardian_portal'"/>

                    <!-- Student phase: Next (not on student_portal or summary) -->
                    <button name="action_next" type="object" string="Next →"
                            class="btn btn-primary"
                            invisible="wizard_phase != 'student' or step in ('student_portal', 'summary')"/>
                    <!-- Student phase: Confirm Student (on student_portal step) -->
                    <button name="action_confirm_student" type="object"
                            string="Confirm &amp; Register Student"
                            class="btn btn-primary"
                            invisible="step != 'student_portal'"/>
                    <!-- Summary: Add another -->
                    <button name="action_add_another_student" type="object"
                            string="Register Another Student"
                            class="btn btn-primary"
                            invisible="step != 'summary'"/>
                    <!-- Summary: Finish -->
                    <button name="action_finish" type="object"
                            string="Finish Onboarding"
                            class="btn btn-success"
                            invisible="step != 'summary'"/>

                    <!-- Back button (hidden on first step of each phase) -->
                    <button name="action_back" type="object" string="← Previous"
                            class="btn btn-secondary"
                            invisible="step in ('guardian_contact', 'summary')"/>
                    <button special="cancel" string="Cancel" class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ── Wizard Launch Action ──────────────────────────────────────────── -->
    <record id="action_dojo_onboarding_wizard" model="ir.actions.act_window">
        <field name="name">New Member Onboarding</field>
        <field name="res_model">dojo.onboarding.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{"dialog_size": "large"}</field>
    </record>

</odoo>
