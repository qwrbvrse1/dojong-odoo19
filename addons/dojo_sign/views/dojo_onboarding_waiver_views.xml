<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Inject the Waiver step into the onboarding wizard view ─────────── -->
    <record id="view_dojo_onboarding_wizard_waiver_inherit" model="ir.ui.view">
        <field name="name">dojo.onboarding.wizard.waiver.inherit</field>
        <field name="model">dojo.onboarding.wizard</field>
        <field name="inherit_id" ref="dojo_onboarding.view_dojo_onboarding_wizard_form"/>
        <field name="arch" type="xml">

            <!-- ── Add waiver step label to the student-phase progress header ── -->
            <xpath expr="//div[hasclass('alert-primary')]//span[@invisible=&quot;step != 'subscription'&quot;]"
                   position="after">
                <span invisible="step != 'waiver'">
                    ✓ Student Contact  ›  ✓ Details  ›  ✓ Enrollment  ›  ✓ Subscription  ›  <b>Waiver</b>  ›  Portal  ›  Summary
                </span>
            </xpath>

            <!-- ── Waiver step content (inserted before Student Portal Access) ── -->
            <xpath expr="//group[@name='group_student_portal']" position="before">

                <group string="Liability Waiver" invisible="step != 'waiver'">

                    <!-- Waiver text display -->
                    <div colspan="2" class="mb-3">
                        <div class="alert alert-info py-2 px-3" role="alert">
                            <i class="fa fa-file-text me-2"/>
                            Please read the waiver carefully, then draw your signature
                            and tick the acknowledgment box before proceeding.
                        </div>
                        <!-- Scrollable waiver body -->
                        <div style="max-height:320px; overflow-y:auto;
                                    border:1px solid #dee2e6; border-radius:4px;
                                    padding:16px; background:#fafafa;">
                            <field name="waiver_preview_html"
                                   widget="html"
                                   readonly="1"
                                   nolabel="1"
                                   colspan="2"/>
                        </div>
                    </div>

                    <!-- Legal authority checkbox -->
                    <div colspan="2" class="mb-3">
                        <field name="waiver_legal_authority"
                               widget="boolean_toggle"
                               string="I confirm I have the legal authority to sign this waiver (on my own behalf, or as the legal guardian/representative of the above student)"/>
                    </div>

                    <!-- Signer name -->
                    <group colspan="2">
                        <field name="waiver_signed_by"
                               string="Signing As"
                               placeholder="Full legal name of signatory"
                               help="Your full name as it will appear on the signed waiver PDF."/>
                    </group>

                    <!-- Signature canvas -->
                    <div colspan="2" class="mt-2">
                        <label class="o_form_label d-block mb-1" for="waiver_signature">
                            Signature <span class="text-danger">*</span>
                        </label>
                        <field name="waiver_signature"
                               widget="signature"
                               options="{'width': 500, 'height': 160}"
                               string="Signature"
                               nolabel="1"/>
                        <small class="text-muted">
                            Draw your signature above using the mouse or a touchscreen stylus.
                        </small>
                    </div>

                    <!-- Validation reminder -->
                    <div class="alert alert-warning mt-3" colspan="2"
                         invisible="waiver_legal_authority and waiver_signature"
                         role="alert">
                        <i class="fa fa-exclamation-triangle me-1"/>
                        Both the <b>acknowledgment checkbox</b> and a <b>drawn signature</b>
                        are required before you can proceed.
                    </div>
                </group>

            </xpath>
        </field>
    </record>
</odoo>
